<div class="vl-flash-sale-cta" style="
  --sale-bg: {{ section.settings.bg_color }};
  --heading-color: {{ section.settings.heading_color }};
  --subtext-color: {{ section.settings.subtext_color }};
  --button-bg: {{ section.settings.button_bg_color }};
  --button-text: {{ section.settings.button_text_color }};
">
  <div class="vl-flash-sale-cta__inner">
    <h2 class="vl-flash-sale-cta__heading">{{ section.settings.heading }}</h2>
    {% if section.settings.subtext != blank %}
      <p class="vl-flash-sale-cta__subtext">{{ section.settings.subtext }}</p>
    {% endif %}
    <a href="{{ section.settings.button_url }}" class="vl-flash-sale-cta__button" target="_blank" rel="noopener">
      {{ section.settings.button_text }}
    </a>
  </div>
</div>

{% stylesheet %}
  .vl-flash-sale-cta {
    background-color: var(--sale-bg, #ffffff);
    padding: 32px 16px;
  }

  .vl-flash-sale-cta__inner {
    max-width: 402px;
    margin: 0 auto;
    text-align: center;
  }

  .vl-flash-sale-cta__heading {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 24px;
    font-weight: 700;
    color: var(--heading-color, #5C1A33);
    margin: 0 0 8px;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .vl-flash-sale-cta__subtext {
    font-size: 14px;
    color: var(--subtext-color, #666666);
    margin: 0 0 20px;
  }

  .vl-flash-sale-cta__button {
    display: block;
    width: 100%;
    padding: 16px 24px;
    background-color: var(--button-bg, #5C1A33);
    color: var(--button-text, #ffffff);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    text-decoration: none;
    border-radius: 30px;
    transition: opacity 0.2s ease;
  }

  .vl-flash-sale-cta__button:hover {
    opacity: 0.9;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "VL Flash Sale CTA",
  "tag": "section",
  "class": "vl-flash-sale-cta-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "SUPER FLASH SALE — TODAY ONLY!"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Save big on our best-selling product."
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button text",
      "default": "CLAIM OFFER NOW"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#5C1A33"
    },
    {
      "type": "color",
      "id": "subtext_color",
      "label": "Subtext color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#5C1A33"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "VL Flash Sale CTA"
    }
  ]
}
{% endschema %}
