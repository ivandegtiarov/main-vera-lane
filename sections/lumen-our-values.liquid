<script>
  (() => {
    const section = document.getElementById('lumen-our-values-{{ section.id }}');
    if (!section) return;

    // Mark JS-enabled so CSS animations don't hide content without JS.
    section.classList.add('lumen-our-values--js');

    // Accordion (single-open)
    const items = Array.from(section.querySelectorAll('.lumen-our-values__item'));
    const triggers = Array.from(section.querySelectorAll('.lumen-our-values__trigger'));

    const openItem = (nextItem) => {
      items.forEach((item) => {
        const trigger = item.querySelector('.lumen-our-values__trigger');
        const panel = item.querySelector('.lumen-our-values__panel');
        const isTarget = item === nextItem;

        item.classList.toggle('is-open', isTarget);
        if (trigger) trigger.setAttribute('aria-expanded', isTarget ? 'true' : 'false');
        if (panel) panel.setAttribute('aria-hidden', isTarget ? 'false' : 'true');
      });
    };

    triggers.forEach((btn) => {
      btn.addEventListener('click', () => {
        const item = btn.closest('.lumen-our-values__item');
        if (!item) return;
        openItem(item);
      });
    });

    // Ensure one default open (matches prototype: 2nd item)
    const defaultIndex = Number(section.getAttribute('data-default-open-index') || '0');
    if (items.length) openItem(items[Math.min(Math.max(defaultIndex, 0), items.length - 1)]);

    // Fade-in on scroll (single trigger)
    const animated = Array.from(section.querySelectorAll('.lumen-our-values__anim'));
    if (!animated.length) return;

    if (!('IntersectionObserver' in window)) {
      animated.forEach((el) => el.classList.add('is-inview'));
      return;
    }

    const io = new IntersectionObserver(
      (entries, observer) => {
        entries.forEach((entry) => {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-inview');
          observer.unobserve(entry.target);
        });
      },
      { root: null, threshold: 0.15 }
    );

    animated.forEach((el) => io.observe(el));
  })();
</script>

