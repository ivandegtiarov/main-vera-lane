{% comment %}
  Lumen – Our Values (Accordion + Image)
  - Production-ready Shopify section
  - Scoped CSS + CSS variables for editor-controlled values
  - Vanilla JS accordion + scroll fade-in (IntersectionObserver)
{% endcomment %}

{%- liquid
  assign default_open_index = 1
-%}

<section
  id="lumen-our-values-{{ section.id }}"
  class="lumen-our-values"
  aria-label="Our Values"
  data-default-open-index="{{ default_open_index }}"
>
  <div class="lumen-our-values__inner">
    <div class="lumen-our-values__stack">
      <h2 class="lumen-our-values__title lumen-our-values__anim">Our Values</h2>

      <div class="lumen-our-values__content">
        <div class="lumen-our-values__media lumen-our-values__anim" aria-hidden="{% if section.settings.image == blank %}true{% else %}false{% endif %}">
          {%- if section.settings.image != blank -%}
            <img
              class="lumen-our-values__img"
              src="{{ section.settings.image | image_url: width: 1600 }}"
              alt="{{ section.settings.image_alt | escape }}"
              loading="lazy"
              decoding="async"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}"
            >
          {%- endif -%}
        </div>

        <div class="lumen-our-values__accordion" role="list">
          {%- for block in section.blocks -%}
            {%- liquid
              assign is_open = false
              if forloop.index0 == default_open_index
                assign is_open = true
              endif
              assign trigger_id = 'lumen-our-values-trigger-' | append: section.id | append: '-' | append: block.id
              assign panel_id = 'lumen-our-values-panel-' | append: section.id | append: '-' | append: block.id
            -%}

            <div
              class="lumen-our-values__item lumen-our-values__anim {% if is_open %}is-open{% endif %}"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              <button
                id="{{ trigger_id }}"
                class="lumen-our-values__trigger"
                type="button"
                aria-controls="{{ panel_id }}"
                aria-expanded="{% if is_open %}true{% else %}false{% endif %}"
              >
                <span class="lumen-our-values__triggerRow">
                  <span class="lumen-our-values__iconWrap" aria-hidden="true">
                    {%- if block.settings.icon != blank -%}
                      <img
                        class="lumen-our-values__icon"
                        src="{{ block.settings.icon | image_url: width: 64 }}"
                        alt=""
                        loading="lazy"
                        decoding="async"
                        width="{{ block.settings.icon.width }}"
                        height="{{ block.settings.icon.height }}"
                        draggable="false"
                      >
                    {%- endif -%}
                  </span>

                  <span class="lumen-our-values__label">{{ block.settings.question | escape }}</span>
                </span>
              </button>

              <div
                id="{{ panel_id }}"
                class="lumen-our-values__panel"
                role="region"
                aria-labelledby="{{ trigger_id }}"
                aria-hidden="{% if is_open %}false{% else %}true{% endif %}"
              >
                <p class="lumen-our-values__body">
                  {{ block.settings.answer | escape }}
                </p>
              </div>
            </div>
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

