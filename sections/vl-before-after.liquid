<div class="vl-before-after" style="
  --ba-bg: {{ section.settings.bg_color }};
  --heading-color: {{ section.settings.heading_color }};
  --name-color: {{ section.settings.name_color }};
  --title-color: {{ section.settings.title_color }};
  --arrow-bg: {{ section.settings.arrow_bg_color }};
  --arrow-color: {{ section.settings.arrow_color }};
">
  <div class="vl-before-after__inner">
    <div class="vl-before-after__header">
      <h2 class="vl-before-after__heading">{{ section.settings.heading }}</h2>

      {% if section.blocks.size > 1 %}
        <div class="vl-before-after__arrows">
          <button class="vl-before-after__arrow vl-before-after__arrow--prev" data-prev aria-label="Previous">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M15 18l-6-6 6-6"/>
            </svg>
          </button>
          <button class="vl-before-after__arrow vl-before-after__arrow--next" data-next aria-label="Next">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M9 18l6-6-6-6"/>
            </svg>
          </button>
        </div>
      {% endif %}
    </div>

    <div class="vl-before-after__carousel" data-carousel>
      <div class="vl-before-after__track" data-track>
        {% for block in section.blocks %}
          <div class="vl-before-after__slide" {{ block.shopify_attributes }}>
            <div class="vl-before-after__image-wrap">
              {% if block.settings.image != blank %}
                <img
                  src="{{ block.settings.image | image_url: width: 400 }}"
                  alt="{{ block.settings.name }}"
                  class="vl-before-after__image"
                  loading="lazy"
                >
              {% else %}
                <div class="vl-before-after__placeholder">
                  {{ 'image' | placeholder_svg_tag: 'vl-before-after__placeholder-svg' }}
                </div>
              {% endif %}
            </div>
            <div class="vl-before-after__info">
              <span class="vl-before-after__name">{{ block.settings.name }}</span>
              <span class="vl-before-after__title">{{ block.settings.title }}</span>
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.vl-before-after');
    if (!section) return;

    const track = section.querySelector('[data-track]');
    const slides = section.querySelectorAll('.vl-before-after__slide');
    const prevBtn = section.querySelector('[data-prev]');
    const nextBtn = section.querySelector('[data-next]');

    if (slides.length <= 1) return;

    let currentIndex = 0;
    const slideWidth = slides[0].offsetWidth + 16; // width + gap

    function updateCarousel() {
      track.style.transform = `translateX(-${currentIndex * slideWidth}px)`;
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        currentIndex = Math.max(0, currentIndex - 1);
        updateCarousel();
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        currentIndex = Math.min(slides.length - 1, currentIndex + 1);
        updateCarousel();
      });
    }
  });
</script>

{% stylesheet %}
  .vl-before-after {
    background-color: var(--ba-bg, #ffffff);
    padding: 40px 0;
    overflow: hidden;
  }

  .vl-before-after__inner {
    max-width: 402px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .vl-before-after__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .vl-before-after__heading {
    font-family: var(--font-accent--family, 'Times New Roman', serif);
    font-size: 28px;
    font-weight: 400;
    font-style: italic;
    color: var(--heading-color, #5C1A33);
    margin: 0;
  }

  .vl-before-after__arrows {
    display: flex;
    gap: 8px;
  }

  .vl-before-after__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--arrow-bg, #F5F5F5);
    color: var(--arrow-color, #000000);
    border: none;
    cursor: pointer;
    transition: opacity 0.2s ease;
  }

  .vl-before-after__arrow:hover {
    opacity: 0.8;
  }

  .vl-before-after__carousel {
    overflow: visible;
    margin: 0 -16px;
    padding: 0 16px;
  }

  .vl-before-after__track {
    display: flex;
    gap: 16px;
    transition: transform 0.3s ease;
  }

  .vl-before-after__slide {
    flex-shrink: 0;
    width: calc(50% - 8px);
  }

  .vl-before-after__image-wrap {
    aspect-ratio: 1 / 1;
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 12px;
  }

  .vl-before-after__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .vl-before-after__placeholder {
    width: 100%;
    height: 100%;
    background-color: #E5E5E5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vl-before-after__placeholder-svg {
    width: 40%;
    height: auto;
    opacity: 0.5;
  }

  .vl-before-after__info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .vl-before-after__name {
    font-family: var(--font-heading--family, serif);
    font-size: 14px;
    font-weight: 600;
    color: var(--name-color, #000000);
  }

  .vl-before-after__title {
    font-size: 12px;
    color: var(--title-color, #666666);
  }
{% endstylesheet %}

