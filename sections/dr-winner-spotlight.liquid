<div class="dr-winner-spotlight">
  <div class="dr-winner-spotlight__container">
    <h2 class="dr-winner-spotlight__heading">{{ section.settings.heading }}</h2>
    <div class="dr-winner-spotlight__body">
      {{ section.settings.body | newline_to_br }}
    </div>
    {% if section.settings.cta_text != blank %}
      <a href="{{ section.settings.cta_url }}" class="dr-winner-spotlight__cta">{{ section.settings.cta_text }} &rarr;</a>
    {% endif %}
  </div>
</div>

{% stylesheet %}
.dr-winner-spotlight {
  background: #f5f5f5;
  padding: 40px 24px;
}

.dr-winner-spotlight__container {
  max-width: 700px;
  margin: 0 auto;
  text-align: left;
}

.dr-winner-spotlight__heading {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 22px;
  font-weight: 700;
  color: #222;
  margin: 0 0 20px;
  text-align: left;
}

.dr-winner-spotlight__body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  font-size: 16px;
  line-height: 1.7;
  color: #444;
  margin-bottom: 24px;
}

.dr-winner-spotlight__cta {
  display: inline-block;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  font-size: 16px;
  color: #4A90D9;
  text-decoration: none;
  font-weight: 600;
}

.dr-winner-spotlight__cta:hover {
  text-decoration: underline;
}
{% endstylesheet %}

{% schema %}
{
  "name": "DR - Winner Spotlight",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why Vera Lane Won This Review"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "After weeks of testing, one product consistently outperformed the rest..."
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Text",
      "default": "Click here to try Vera Lane Foundation"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA URL"
    }
  ],
  "presets": [
    {
      "name": "DR - Winner Spotlight"
    }
  ]
}
{% endschema %}
