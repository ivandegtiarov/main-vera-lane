<div class="vl-icon-grid" style="
  --section-bg: {{ section.settings.bg_color }};
  --icon-color: {{ section.settings.icon_color }};
  --icon-bg: {{ section.settings.icon_bg_color }};
  --label-color: {{ section.settings.label_color }};
  --text-color: {{ section.settings.text_color }};
">
  <div class="vl-icon-grid__inner">
    {% if section.settings.heading != blank %}
      <h2 class="vl-icon-grid__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="vl-icon-grid__grid">
      {% for block in section.blocks %}
        <div class="vl-icon-grid__item" {{ block.shopify_attributes }}>
          <div class="vl-icon-grid__icon">
            {% case block.settings.icon %}
              {% when 'check' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              {% when 'shield' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
              {% when 'heart' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path>
                </svg>
              {% when 'star' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                  <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                </svg>
              {% when 'leaf' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M11 20A7 7 0 0 1 9.8 6.1C15.5 5 17 4.48 19 2c1 2 2 4.18 2 8 0 5.5-4.78 10-10 10Z"></path>
                  <path d="M2 21c0-3 1.85-5.36 5.08-6C9.5 14.52 12 13 13 12"></path>
                </svg>
              {% when 'droplet' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"></path>
                </svg>
              {% when 'sun' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="5"></circle>
                  <line x1="12" y1="1" x2="12" y2="3"></line>
                  <line x1="12" y1="21" x2="12" y2="23"></line>
                  <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
                  <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
                  <line x1="1" y1="12" x2="3" y2="12"></line>
                  <line x1="21" y1="12" x2="23" y2="12"></line>
                  <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
                  <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
                </svg>
              {% when 'award' %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="8" r="7"></circle>
                  <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88"></polyline>
                </svg>
              {% else %}
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
            {% endcase %}
          </div>
          <span class="vl-icon-grid__label">{{ block.settings.label }}</span>
          {% if block.settings.description != blank %}
            <span class="vl-icon-grid__description">{{ block.settings.description }}</span>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .vl-icon-grid {
    background-color: var(--section-bg, #F5F5F5);
    padding: 32px 16px;
  }

  .vl-icon-grid__inner {
    max-width: 402px;
    margin: 0 auto;
  }

  .vl-icon-grid__heading {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--label-color, #000000);
    text-align: center;
    margin: 0 0 24px;
  }

  .vl-icon-grid__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }

  .vl-icon-grid__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .vl-icon-grid__icon {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: var(--icon-bg, #ffffff);
    color: var(--icon-color, #5C1A33);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 10px;
  }

  .vl-icon-grid__icon svg {
    width: 24px;
    height: 24px;
  }

  .vl-icon-grid__label {
    font-size: 13px;
    font-weight: 600;
    color: var(--label-color, #000000);
    line-height: 1.3;
  }

  .vl-icon-grid__description {
    font-size: 12px;
    color: var(--text-color, #666666);
    margin-top: 4px;
    line-height: 1.4;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "VL Icon Grid",
  "tag": "section",
  "class": "vl-icon-grid-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "info": "Optional section heading"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5F5F5"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon color",
      "default": "#5C1A33"
    },
    {
      "type": "color",
      "id": "icon_bg_color",
      "label": "Icon background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Label color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Description color",
      "default": "#666666"
    }
  ],
  "blocks": [
    {
      "type": "icon_item",
      "name": "Icon Item",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "check", "label": "Checkmark" },
            { "value": "shield", "label": "Shield" },
            { "value": "heart", "label": "Heart" },
            { "value": "star", "label": "Star" },
            { "value": "leaf", "label": "Leaf" },
            { "value": "droplet", "label": "Droplet" },
            { "value": "sun", "label": "Sun" },
            { "value": "award", "label": "Award" }
          ],
          "default": "check"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Feature"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "info": "Optional short description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VL Icon Grid",
      "blocks": [
        {
          "type": "icon_item",
          "settings": {
            "icon": "shield",
            "label": "SPF 15",
            "description": "Daily protection"
          }
        },
        {
          "type": "icon_item",
          "settings": {
            "icon": "leaf",
            "label": "Clean Formula",
            "description": "No harsh chemicals"
          }
        },
        {
          "type": "icon_item",
          "settings": {
            "icon": "heart",
            "label": "Dermatologist Tested",
            "description": "Safe for all skin"
          }
        },
        {
          "type": "icon_item",
          "settings": {
            "icon": "award",
            "label": "Award Winning",
            "description": "Best foundation 2024"
          }
        }
      ]
    }
  ]
}
{% endschema %}
