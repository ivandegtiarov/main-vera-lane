      {% else %}
        {% comment %} Collection fallback (defaults to All products when not set) {% endcomment %}
        {% assign fp_collection = section.settings.collection %}
        {% if fp_collection == blank %}
          {% assign fp_collection = collections.all %}
        {% endif %}

        {% assign has_products = fp_collection.products_count | default: 0 %}

        {% if has_products > 0 %}
          {% for product in fp_collection.products limit: 5 %}
            {% assign first_variant = product.selected_or_first_available_variant %}
            <li class="vl-fp__product">
              <article class="vl-fp-card">
                {% if forloop.first %}
                  {% if section.settings.collection_pill_text != blank %}
                    <div class="vl-fp-card__pill">{{ section.settings.collection_pill_text }}</div>
                  {% endif %}
                  {% if section.settings.collection_show_discount %}
                    <div class="vl-fp-card__discount" aria-label="{{ section.settings.collection_discount_text | escape }} {{ section.settings.collection_discount_pct | escape }}">
                      <div class="vl-fp-card__discountInner">
                        <div class="vl-fp-card__discountPct">{{ section.settings.collection_discount_pct | default: '20%' }}</div>
                        <div class="vl-fp-card__discountText">{{ section.settings.collection_discount_text | default: 'Save with subscription' }}</div>
                      </div>
                    </div>
                  {% endif %}
                {% endif %}

                <a class="vl-fp-card__link" href="{{ product.url }}" aria-label="{{ product.title }} - {{ first_variant.price | money }}">
                  <div class="vl-fp-card__media">
                    <div class="vl-fp-card__mediaInner">
                      {% if product.featured_image != blank %}
                        {{
                          product.featured_image
                          | image_url: width: 520
                          | image_tag:
                            class: 'vl-fp-card__overlay',
                            loading: 'lazy',
                            alt: product.featured_image.alt | default: product.title
                        }}
                      {% else %}
                        <svg class="vl-fp-card__overlay" viewBox="0 0 254 254" role="img" aria-label="{{ product.title }}" focusable="false">
                          <rect width="254" height="254" rx="16" fill="#F3F3F3"></rect>
                        </svg>
                      {% endif %}
                    </div>
