{% comment %}
  ---------------------------------------------------------------------------
  Lumen Featured Products (production Shopify section)
  - Mobile-first, scoped CSS
  - CSS variables for all customizable properties
  - IntersectionObserver fade-in animation (single trigger)
  - Vanilla JS carousel controls (scoped per section instance)
  ---------------------------------------------------------------------------
{% endcomment %}

<section
  class="vl-fp vl-fp--{{ section.id }}"
  aria-label="Recommended products"
  data-vl-fp-section
  data-section-id="{{ section.id }}"
>
  <style>
    /* Section-scoped theme variables */
    .vl-fp--{{ section.id }} {
      --vl-fp-bg-solid: {{ section.settings.background_color }};
      --vl-fp-bg-grad-start: {{ section.settings.background_gradient_start }};
      --vl-fp-bg-grad-end: {{ section.settings.background_gradient_end }};

      --vl-fp-heading-color: {{ section.settings.heading_color }};
      --vl-fp-subheading-color: {{ section.settings.subheading_color }};
      --vl-fp-reviews-color: {{ section.settings.reviews_color }};
      --vl-fp-name-color: {{ section.settings.name_color }};
      --vl-fp-price-color: {{ section.settings.price_color }};
      --vl-fp-desc-color: {{ section.settings.description_color }};

      --vl-fp-pill-bg: {{ section.settings.pill_bg_color }};
      --vl-fp-pill-text: {{ section.settings.pill_text_color }};
      --vl-fp-discount-bg: {{ section.settings.discount_bg_color }};
      --vl-fp-discount-text: {{ section.settings.discount_text_color }};

      --vl-fp-controls-icon: {{ section.settings.controls_icon_color }};
      --vl-fp-controls-progress-bg: {{ section.settings.controls_progress_bg_color }};
      --vl-fp-controls-progress-fill: {{ section.settings.controls_progress_fill_color }};

      --vl-fp-pad-top-m: {{ section.settings.padding_top_mobile }}px;
      --vl-fp-pad-bot-m: {{ section.settings.padding_bottom_mobile }}px;
      --vl-fp-pad-top-d: {{ section.settings.padding_top_desktop }}px;
      --vl-fp-pad-bot-d: {{ section.settings.padding_bottom_desktop }}px;

      --vl-fp-title-size-m: {{ section.settings.title_font_size_mobile }}px;
      --vl-fp-title-size-d: {{ section.settings.title_font_size_desktop }}px;
      --vl-fp-sub-size-m: {{ section.settings.sub_font_size_mobile }}px;
      --vl-fp-sub-size-d: {{ section.settings.sub_font_size_desktop }}px;
      --vl-fp-reviews-size-m: {{ section.settings.reviews_font_size_mobile }}px;
      --vl-fp-reviews-size-d: {{ section.settings.reviews_font_size_desktop }}px;
      --vl-fp-name-size-m: {{ section.settings.name_font_size_mobile }}px;
      --vl-fp-name-size-d: {{ section.settings.name_font_size_desktop }}px;
      --vl-fp-price-size-m: {{ section.settings.price_font_size_mobile }}px;
      --vl-fp-price-size-d: {{ section.settings.price_font_size_desktop }}px;
      --vl-fp-desc-size-m: {{ section.settings.desc_font_size_mobile }}px;
      --vl-fp-desc-size-d: {{ section.settings.desc_font_size_desktop }}px;
      --vl-fp-pill-size-m: {{ section.settings.pill_font_size_mobile }}px;
      --vl-fp-pill-size-d: {{ section.settings.pill_font_size_desktop }}px;
      --vl-fp-disc-pct-size-m: {{ section.settings.discount_pct_font_size_mobile }}px;
      --vl-fp-disc-pct-size-d: {{ section.settings.discount_pct_font_size_desktop }}px;
      --vl-fp-disc-text-size-m: {{ section.settings.discount_text_font_size_mobile }}px;
      --vl-fp-disc-text-size-d: {{ section.settings.discount_text_font_size_desktop }}px;
    }

    .vl-fp--{{ section.id }} {
      width: 100%;
      background: linear-gradient(180deg, var(--vl-fp-bg-grad-start), var(--vl-fp-bg-grad-end));
      overflow: hidden;
      color: #000000;
      font-family: Montserrat, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
    }

    .vl-fp--{{ section.id }} .vl-fp__inner {
      width: 100%;
      max-width: 1440px;
      margin: 0 auto;
      padding: var(--vl-fp-pad-top-m) 28px var(--vl-fp-pad-bot-m);
      display: flex;
      flex-direction: column;
      gap: 56px;
    }

    .vl-fp--{{ section.id }} .vl-fp__titleWrap {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 24px;
      text-align: center;
    }

    .vl-fp--{{ section.id }} .vl-fp__carousel {
      width: 100%;
      display: flex;
      flex-direction: column;
      gap: 18px;
    }

    .vl-fp--{{ section.id }} .vl-fp__title {
        font-family: "Playfair Display";
      font-weight: 600;
      font-size: var(--vl-fp-title-size-m);
      line-height: 1.2;
      color: var(--vl-fp-heading-color);
      margin: 0;
      font-style: italic;
    }

    .vl-fp--{{ section.id }} .vl-fp__sub {
      font-family: Satoshi, Montserrat, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      font-weight: 400;
      font-size: var(--vl-fp-sub-size-m);
      line-height: 1.5;
      color: var(--vl-fp-subheading-color);
      max-width: 720px;
      margin: 0;
    }

    .vl-fp--{{ section.id }} .vl-fp__sub--desktop {
      display: none;
    }

    .vl-fp--{{ section.id }} .vl-fp__products {
      width: 100%;
      gap: 16px;
      padding: 0;
      margin: 0;
      list-style: none;
      display: flex;
      overflow-x: auto;
      overflow-y: hidden;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scroll-padding-left: 0px;
      justify-content: flex-start;
      align-items: stretch;
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none; /* IE/Edge legacy */
    }

    .vl-fp--{{ section.id }} .vl-fp__products::-webkit-scrollbar {
      height: 0px;
    }

    /* Mobile: scroll-snap carousel */
    @media screen and (max-width: 899px) {
      .vl-fp--{{ section.id }} .vl-fp__products {
        padding-bottom: 8px;
      }
    }

    .vl-fp--{{ section.id }} .vl-fp__product {
      min-width: 0;
      flex: 0 0 auto;
      scroll-snap-align: start;
      scroll-snap-stop: always;
      width: min(320px, calc(100% - 56px));
    }

    .vl-fp--{{ section.id }} .vl-fp-card {
      width: 100%;
      min-width: 0;
      border: 1px solid #E5E5E5;
      border-radius: 12px;
      background: #FFFFFF;
      overflow: hidden;
      position: relative;
      display: flex;
      flex-direction: column;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__link {
      display: flex;
      flex-direction: column;
      min-width: 0;
      color: inherit;
      text-decoration: none;
      height: 100%;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__media {
      position: relative;
      width: 100%;
      padding: 52px 0 24px 0;
      display: flex;
      justify-content: center;
      align-items: center;
      min-height: 0;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__mediaInner {
      width: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
      padding: 0 18px;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__overlay {
      width: min(200px, 78%);
      height: auto;
      display: block;
      user-select: none;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__info {
      width: 100%;
      padding: 18px;
      border-top: 1px dashed #E5E5E5;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__ratingRow {
      display: flex;
      align-items: center;
      gap: 8px;
      min-width: 0;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__stars {
      /* width: 108px; */
      height: 20px;
      display: flex;
      align-items: center;
      gap: 0px;
      flex: 0 0 auto;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__stars svg {
      width: 18px;
      height: 18px;
      display: block;
      flex: 0 0 auto;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__reviews {
      font-weight: 400;
      font-size: var(--vl-fp-reviews-size-m);
      line-height: 1.48;
      color: var(--vl-fp-reviews-color);
      white-space: nowrap;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__nameRow {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      min-width: 0;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__name {
      font-weight: 500;
      font-size: var(--vl-fp-name-size-m);
      line-height: 1.2;
      color: var(--vl-fp-name-color);
      min-width: 0;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__price {
      font-weight: 500;
      font-size: var(--vl-fp-price-size-m);
      line-height: 1.2;
      color: var(--vl-fp-price-color);
      white-space: nowrap;
      flex: 0 0 auto;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__desc {
      font-weight: 400;
      font-size: var(--vl-fp-desc-size-m);
      line-height: 1.48;
      color: var(--vl-fp-desc-color);
      min-width: 0;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__pill {
      position: absolute;
      top: 18px;
      left: 18px;
      padding: 5px 12px;
      border-radius: 999px;
      background: var(--vl-fp-pill-bg);
      color: var(--vl-fp-pill-text);
      font-family: "PP Neue Montreal", Montserrat, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      font-weight: 500;
      font-size: var(--vl-fp-pill-size-m);
      line-height: 1.1;
      letter-spacing: 0px;
      z-index: 3;
      white-space: nowrap;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__discount {
      position: absolute;
      right: 18px;
      bottom: 130px;
      width: 80px;
      height: 80px;
      border-radius: 999px;
      background: var(--vl-fp-discount-bg);
      color: var(--vl-fp-discount-text);
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      z-index: 3;
      padding: 14px;
      transform: rotate(-16deg);
      transform-origin: center;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__discountInner {
      width: 100%;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: 6px;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__discountPct {
      font-family: "PP Neue Montreal", Montserrat, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      font-weight: 500;
      font-size: var(--vl-fp-disc-pct-size-m);
      line-height: 1;
    }

    .vl-fp--{{ section.id }} .vl-fp-card__discountText {
      font-family: "PP Neue Montreal", Montserrat, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
      font-weight: 500;
      font-size: var(--vl-fp-disc-text-size-m);
      line-height: 1.08;
      max-width: 120px;
    }

    .vl-fp--{{ section.id }} .vl-fp__controls {
      width: 100%;
      display: flex;
      justify-content: center;
      align-items: center;
    }

    .vl-fp--{{ section.id }} .vl-fp__dots {
      width: 100%;
      max-width: 1248px;
      height: 18px;
      display: none;
    }

    .vl-fp--{{ section.id }} .vl-fp-controls {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 24px;
    }

    .vl-fp--{{ section.id }} .vl-fp-controls__btn {
      width: 48px;
      height: 48px;
      border-radius: 999px;
      border: 1px solid rgba(0, 0, 0, 0.15);
      background: transparent;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      flex: 0 0 auto;
    }

    .vl-fp--{{ section.id }} .vl-fp-controls__btn[disabled] {
      opacity: 0.45;
      cursor: default;
    }

    .vl-fp--{{ section.id }} .vl-fp-controls__icon {
      width: 16px;
      height: 16px;
      display: block;
      fill: var(--vl-fp-controls-icon);
      opacity: 0.5;
    }

    .vl-fp--{{ section.id }} .vl-fp-controls__progress {
      width: 100%;
      max-width: 912px;
      height: 6px;
      border-radius: 3px;
      background: var(--vl-fp-controls-progress-bg);
      overflow: hidden;
    }

    .vl-fp--{{ section.id }} .vl-fp-controls__progressFill {
      height: 100%;
      width: 0%;
      background: var(--vl-fp-controls-progress-fill);
      border-radius: 3px;
      transition: width 220ms ease;
    }

    /* Fade-in on scroll (single trigger) - animate whole section as one unit */
    .vl-fp--{{ section.id }} .vl-fp__inner {
      opacity: 0;
      transform: translateY(20px);
      transition: opacity 0.8s ease-out, transform 0.8s ease-out;
      will-change: opacity, transform;
    }

    .vl-fp--{{ section.id }} .vl-fp__inner.is-visible {
      opacity: 1;
      transform: translateY(0);
    }

    /* Desktop */
    @media screen and (min-width: 900px) {
      .vl-fp--{{ section.id }} .vl-fp__inner {
        padding: var(--vl-fp-pad-top-d) 96px var(--vl-fp-pad-bot-d);
        gap: 80px;
      }

      .vl-fp--{{ section.id }} .vl-fp__title {
        font-size: var(--vl-fp-title-size-d);
        line-height: 0.9;
        margin: 0;
      }

      .vl-fp--{{ section.id }} .vl-fp__sub {
        font-size: var(--vl-fp-sub-size-d);
        margin: 0;
      }

      .vl-fp--{{ section.id }} .vl-fp__sub--mobile {
        display: none;
      }

      .vl-fp--{{ section.id }} .vl-fp__sub--desktop {
        display: block;
      }

      .vl-fp--{{ section.id }} .vl-fp__products {
        padding-bottom: 0px;
      }

      .vl-fp--{{ section.id }} .vl-fp__carousel {
        gap: 40px;
      }

      .vl-fp--{{ section.id }} .vl-fp__product {
        width: auto;
        flex: 0 0 calc((100% - 32px) / 3);
      }

      .vl-fp--{{ section.id }} .vl-fp-card__media {
        padding: 68px 0 32px 0;
      }

      .vl-fp--{{ section.id }} .vl-fp-card__info {
        padding: 24px 18px;
        gap: 10px;
      }

      .vl-fp--{{ section.id }} .vl-fp-card__reviews {
        font-size: var(--vl-fp-reviews-size-d);
      }

      .vl-fp--{{ section.id }} .vl-fp-card__name {
        font-size: var(--vl-fp-name-size-d);
      }

      .vl-fp--{{ section.id }} .vl-fp-card__price {
        font-size: var(--vl-fp-price-size-d);
      }

      .vl-fp--{{ section.id }} .vl-fp-card__desc {
        font-size: var(--vl-fp-desc-size-d);
      }

      .vl-fp--{{ section.id }} .vl-fp-card__overlay {
        width: min(254px, 78%);
      }

      .vl-fp--{{ section.id }} .vl-fp-card__pill {
        top: 20px;
        left: 20px;
        padding: 6px 16px;
        font-size: var(--vl-fp-pill-size-d);
      }

      .vl-fp--{{ section.id }} .vl-fp-card__discount {
        right: 18px;
        top: 210px;
        width: 100px;
        height: 100px;
      }

      .vl-fp--{{ section.id }} .vl-fp-card__discountPct {
        font-size: var(--vl-fp-disc-pct-size-d);
      }

      .vl-fp--{{ section.id }} .vl-fp-card__discountText {
        font-size: var(--vl-fp-disc-text-size-d);
      }

      .vl-fp--{{ section.id }} .vl-fp-controls {
        display: flex;
      }

      .vl-fp--{{ section.id }} .vl-fp__dots {
        display: none;
      }
    }
  </style>

  <div class="vl-fp__inner" data-vl-fp-animate>
    <header class="vl-fp__titleWrap">
      <h2 class="vl-fp__title">
        {{ section.settings.title | default: 'Recommended Products' | escape }}
      </h2>
      <p class="vl-fp__sub vl-fp__sub--desktop">
        {{ section.settings.description_desktop | default: 'Handpicked formulas your skin will love.' | escape }}
      </p>
      <p class="vl-fp__sub vl-fp__sub--mobile">
        {{ section.settings.description_mobile | default: 'Lorem ipsum dolor sit amet, consectetur adipiscing elit.' | escape }}
      </p>
    </header>

    <div class="vl-fp__carousel">
      <ul class="vl-fp__products" aria-label="Product list" data-vl-fp-track id="vl-fp-track-{{ section.id }}">
      {% comment %}
        Cards are managed as blocks. If no blocks exist, we fall back to the selected collection.
      {% endcomment %}
      {% assign card_blocks = section.blocks | where: 'type', 'card' %}

      {% if card_blocks.size > 0 %}
        {% for block in card_blocks %}
          {% assign product = block.settings.product %}
          {% if product != blank %}
            {% assign first_variant = product.selected_or_first_available_variant %}
          {% endif %}

          <li class="vl-fp__product">
            <article class="vl-fp-card" {{ block.shopify_attributes }}>
              {% if block.settings.show_pill and block.settings.pill_text != blank %}
                <div class="vl-fp-card__pill">{{ block.settings.pill_text }}</div>
              {% endif %}

              {% if block.settings.show_discount %}
                <div class="vl-fp-card__discount" aria-label="{{ block.settings.discount_text | escape }} {{ block.settings.discount_pct | escape }}">
                  <div class="vl-fp-card__discountInner">
                    <div class="vl-fp-card__discountPct">{{ block.settings.discount_pct }}</div>
                    <div class="vl-fp-card__discountText">{{ block.settings.discount_text }}</div>
                  </div>
                </div>
              {% endif %}

              {% if product != blank %}
                <a class="vl-fp-card__link" href="{{ product.url }}" aria-label="{{ product.title }} - {{ first_variant.price | money }}">
                  <div class="vl-fp-card__media">
                    <div class="vl-fp-card__mediaInner">
                      {% if product.featured_image != blank %}
                        {{
                          product.featured_image
                          | image_url: width: 520
                          | image_tag:
                            class: 'vl-fp-card__overlay',
                            loading: 'lazy',
                            alt: product.featured_image.alt | default: product.title
                        }}
                      {% else %}
                        <svg class="vl-fp-card__overlay" viewBox="0 0 254 254" role="img" aria-label="{{ product.title }}" focusable="false">
                          <rect width="254" height="254" rx="16" fill="#F3F3F3"></rect>
                        </svg>
                      {% endif %}
                    </div>
                  </div>

                  <div class="vl-fp-card__info">
                    <div class="vl-fp-card__ratingRow" aria-label="Product rating">
                      <div class="vl-fp-card__stars" aria-hidden="true">
