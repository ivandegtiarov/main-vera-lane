            <path d="M5.8 13.8L11.6 8 5.8 2.2 4.7 3.3 9.4 8l-4.7 4.7 1.1 1.1z"></path>
          </svg>
        </button>
      </div>

      {% comment %} Mobile-only dots indicator (inline SVG to avoid missing asset dependency) {% endcomment %}
      <svg class="vl-fp__dots" viewBox="0 0 1248 18" aria-hidden="true" focusable="false">
        <rect x="0" y="0" width="1248" height="18" rx="9" fill="rgba(0,0,0,0.06)"></rect>
        <circle cx="624" cy="9" r="4" fill="rgba(0,0,0,0.22)"></circle>
        <circle cx="588" cy="9" r="3" fill="rgba(0,0,0,0.12)"></circle>
        <circle cx="660" cy="9" r="3" fill="rgba(0,0,0,0.12)"></circle>
      </svg>
      </div>
    </div>
  </div>

  <script>
    (() => {
      const sectionEl = document.querySelector('.vl-fp--{{ section.id }}[data-vl-fp-section]');
      if (!sectionEl) return;

      /* Fade-in animation on scroll (single trigger) */
      const animateEl = sectionEl.querySelector('[data-vl-fp-animate]');
      if ('IntersectionObserver' in window) {
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (!entry.isIntersecting) return;
              entry.target.classList.add('is-visible');
              io.unobserve(entry.target);
            });
          },
          { root: null, rootMargin: '0px 0px -10% 0px', threshold: 0.15 }
        );
        if (animateEl) io.observe(animateEl);
      } else {
        if (animateEl) animateEl.classList.add('is-visible');
      }

      /* Carousel controls */
      const track = sectionEl.querySelector('[data-vl-fp-track]');
      if (!track) return;

      const fill = sectionEl.querySelector('[data-vl-fp-progress-fill]');
      const prevBtn = sectionEl.querySelector('.vl-fp-controls__btn[data-dir="prev"]');
      const nextBtn = sectionEl.querySelector('.vl-fp-controls__btn[data-dir="next"]');

      const isDesktop = () => window.matchMedia('(min-width: 900px)').matches;

      const getStep = () => {
        const first = track.querySelector('.vl-fp__product');
        if (!first) return 0;
        const rect = first.getBoundingClientRect();
        return rect.width + 16;
      };

      const getMaxIndex = () => {
        const cards = track.querySelectorAll('.vl-fp__product').length;
        if (!isDesktop()) return Math.max(0, cards - 1);
        return Math.max(0, cards - 3);
      };

      const clamp = (v, min, max) => Math.max(min, Math.min(max, v));

      const getIndexFromScroll = () => {
        const step = getStep();
        if (!step) return 0;
        return clamp(Math.round(track.scrollLeft / step), 0, getMaxIndex());
      };

      const setControls = () => {
        const maxIndex = getMaxIndex();
        const index = getIndexFromScroll();
        const pages = maxIndex + 1;

        if (prevBtn) prevBtn.disabled = index <= 0;
        if (nextBtn) nextBtn.disabled = index >= maxIndex;

        if (fill) {
          fill.style.width = pages <= 1 ? '33.333%' : `${((index + 1) / pages) * 100}%`;
        }
      };

      const scrollToIndex = (index, behavior) => {
        const step = getStep();
        const maxIndex = getMaxIndex();
        const target = clamp(index, 0, maxIndex);
        track.scrollTo({ left: target * step, behavior: behavior || 'smooth' });
      };

      const resetToFirstSlide = () => {
        /* Force left-aligned first slide on mobile (some browsers restore scroll position) */
        if (!isDesktop()) {
          track.scrollTo({ left: 0, behavior: 'auto' });
          requestAnimationFrame(() => track.scrollTo({ left: 0, behavior: 'auto' }));
        }
        setControls();
      };

      const onClick = (dir) => {
        const index = getIndexFromScroll();
        scrollToIndex(dir === 'next' ? index + 1 : index - 1, 'smooth');
        setControls();
      };

      if (prevBtn) prevBtn.addEventListener('click', () => onClick('prev'));
      if (nextBtn) nextBtn.addEventListener('click', () => onClick('next'));

      let raf = 0;
      track.addEventListener('scroll', () => {
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(setControls);
      });

      window.addEventListener('resize', resetToFirstSlide);
      window.addEventListener('load', resetToFirstSlide);
      window.addEventListener('pageshow', resetToFirstSlide);
    })();
  </script>
</section>

