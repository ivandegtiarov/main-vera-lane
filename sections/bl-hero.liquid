{%- comment -%} ── BL - HERO ── {%- endcomment -%}
{%- liquid
  if section.settings.bg_image != blank
    assign hero_bg_url = section.settings.bg_image | image_url: width: 1600
  elsif section.settings.bg_image_asset != blank
    assign hero_bg_url = section.settings.bg_image_asset | asset_url
  endif
-%}
<div class="bl-hero" {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %} style="{% if hero_bg_url %}--hero-bg-image: url('{{ hero_bg_url }}');{% endif %} --hero-bg-color: {{ section.settings.bg_color }}; --hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};">
  <div class="bl-hero__container">
    <div class="bl-hero__content">
      {%- if section.settings.category != blank -%}
        <span class="bl-hero__category">{{ section.settings.category }}</span>
      {%- endif -%}

      <h1 class="bl-hero__headline">{{ section.settings.headline }}</h1>

      {%- if section.settings.subheadline != blank -%}
        <p class="bl-hero__subheadline">{{ section.settings.subheadline }}</p>
      {%- endif -%}

      {%- if section.settings.show_rating -%}
        <div class="bl-hero__rating">
          <div class="bl-hero__stars">
            {%- for i in (1..5) -%}
              <svg class="bl-hero__star" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
            {%- endfor -%}
          </div>
          <span class="bl-hero__review-count">{{ section.settings.review_count }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.cta_text != blank -%}
        {%- liquid
          if section.settings.cta_type == 'anchor' and section.settings.cta_anchor != blank
            assign cta_href = '#' | append: section.settings.cta_anchor
          else
            assign cta_href = section.settings.cta_url
          endif
        -%}
        <a href="{{ cta_href }}" class="bl-hero__cta" style="--cta-text: {{ section.settings.cta_text_color }}; --cta-border: {{ section.settings.cta_border_color }};">
          {{ section.settings.cta_text }}
        </a>
      {%- endif -%}
    </div>
  </div>
</div>

{% stylesheet %}
html {
  scroll-behavior: smooth;
}

.bl-hero {
  position: relative;
  background-color: var(--hero-bg-color, #2D2D2D);
  background-image: var(--hero-bg-image);
  background-size: cover;
  background-position: center right;
  min-height: 480px;
  display: flex;
  align-items: center;
  padding: 4rem 2rem;
}

.bl-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(to right, rgba(0,0,0,var(--hero-overlay, 0.35)) 0%, rgba(0,0,0,0.15) 50%, transparent 100%);
  pointer-events: none;
}

.bl-hero__container {
  position: relative;
  z-index: 1;
  max-width: 1100px;
  margin: 0 auto;
  width: 100%;
}

.bl-hero__content {
  max-width: 520px;
}

.bl-hero__category {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #D4A574;
  margin-bottom: 1rem;
}

.bl-hero__headline {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: clamp(2rem, 5vw, 3rem);
  font-weight: 400;
  line-height: 1.15;
  letter-spacing: -0.01em;
  color: #fff;
  margin: 0 0 1.25rem;
}

.bl-hero__subheadline {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1.0625rem;
  font-weight: 400;
  line-height: 1.6;
  color: rgba(255, 255, 255, 0.85);
  margin: 0 0 1.5rem;
}

.bl-hero__rating {
  display: flex;
  align-items: center;
  gap: 0.625rem;
  margin-bottom: 2rem;
}

.bl-hero__stars {
  display: flex;
  gap: 0.125rem;
  color: #D4A574;
}

.bl-hero__star {
  width: 1.125rem;
  height: 1.125rem;
}

.bl-hero__review-count {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.8125rem;
  font-weight: 400;
  letter-spacing: 0.02em;
  color: rgba(255, 255, 255, 0.8);
}

.bl-hero__cta {
  display: inline-block;
  background: transparent;
  color: var(--cta-text, #fff);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 0.9375rem 2rem;
  border: 1px solid var(--cta-border, rgba(255, 255, 255, 0.6));
  transition: background 200ms ease, border-color 200ms ease, opacity 200ms ease;
}

.bl-hero__cta:hover {
  opacity: 0.8;
}

@media (max-width: 600px) {
  .bl-hero {
    min-height: 400px;
    background-position: center;
    padding: 3rem 1.5rem;
  }

  .bl-hero::before {
    background: linear-gradient(to bottom, rgba(0,0,0,var(--hero-overlay, 0.45)) 0%, rgba(0,0,0,0.25) 100%);
  }

  .bl-hero__content {
    text-align: center;
    max-width: 100%;
  }

  .bl-hero__rating {
    justify-content: center;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "BL - Hero",
  "tag": "section",
  "class": "bl-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "For anchor links (e.g., 'hero')"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "bg_image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "bg_image_asset",
      "label": "Background image (asset filename)",
      "info": "Use instead of image picker for theme asset images (e.g., 'my-image.jpg')"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color (fallback)",
      "default": "#2D2D2D"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay darkness",
      "min": 0,
      "max": 80,
      "step": 5,
      "default": 35,
      "unit": "%"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "category",
      "label": "Category label",
      "default": "BEAUTY"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "The Foundation That Works With Your Skin, Not Against It"
    },
    {
      "type": "textarea",
      "id": "subheadline",
      "label": "Subheadline",
      "info": "Optional supporting text"
    },
    {
      "type": "header",
      "content": "Rating"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count text",
      "default": "12,400+ Reviews"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "DISCOVER MORE"
    },
    {
      "type": "select",
      "id": "cta_type",
      "label": "Link type",
      "options": [
        { "value": "anchor", "label": "Scroll to section on page" },
        { "value": "url", "label": "Link to URL" }
      ],
      "default": "anchor"
    },
    {
      "type": "text",
      "id": "cta_anchor",
      "label": "Section ID to scroll to",
      "info": "Enter the Section ID from the target section (e.g., 'offer')",
      "default": "offer"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL",
      "info": "Used when link type is 'Link to URL'"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "cta_border_color",
      "label": "Button border color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "BL - Hero",
      "category": "t:categories.blissy_listicle"
    }
  ]
}
{% endschema %}
