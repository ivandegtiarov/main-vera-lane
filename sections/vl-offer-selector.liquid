          "default": false,
          "info": "Enable for subscription offers"
        },
        {
          "type": "text",
          "id": "frequency_options",
          "label": "Frequency options",
          "default": "Delivery every 1 month, Delivery every 2 months, Delivery every 3 months",
          "info": "Comma-separated list of options"
