<section class="dr-methodology">
  <div class="dr-methodology__container">
    <h2 class="dr-methodology__heading">{{ section.settings.heading }}</h2>
    <ul class="dr-methodology__list">
      {% for block in section.blocks %}
        <li class="dr-methodology__item" {{ block.shopify_attributes }}>
          <strong class="dr-methodology__title">{{ block.settings.title }}:</strong> {{ block.settings.description }}
        </li>
      {% endfor %}
    </ul>
  </div>
</section>

{% stylesheet %}
.dr-methodology {
  background: #ffffff;
  padding: 24px;
}

.dr-methodology__container {
  max-width: 700px;
  margin: 0 auto;
  text-align: left;
}

.dr-methodology__heading {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 22px;
  font-weight: 700;
  color: #222;
  margin: 0 0 20px;
  text-align: left;
}

.dr-methodology__list {
  list-style-type: disc;
  padding-left: 24px;
  margin: 0;
}

.dr-methodology__item {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  font-size: 15px;
  line-height: 1.7;
  color: #444;
  margin-bottom: 12px;
}

.dr-methodology__title {
  font-weight: 700;
  color: #222;
}
{% endstylesheet %}

{% schema %}
{
  "name": "DR - Methodology",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How I Evaluated Each Foundation"
    }
  ],
  "blocks": [
    {
      "type": "criterion",
      "name": "Criterion",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Oxidation Resistance"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "How well the formula maintained its shade after 8 hours of wear."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DR - Methodology",
      "blocks": [
        {
          "type": "criterion",
          "settings": {
            "title": "Oxidation Resistance",
            "description": "How well the formula maintained its shade after 8 hours of wear."
          }
        },
        {
          "type": "criterion",
          "settings": {
            "title": "Shade Matching",
            "description": "Accuracy of color adaptation across different skin tones."
          }
        },
        {
          "type": "criterion",
          "settings": {
            "title": "Skin Feel & Texture",
            "description": "Comfort, breathability, and how natural it looks on mature skin."
          }
        },
        {
          "type": "criterion",
          "settings": {
            "title": "Longevity",
            "description": "Transfer resistance and wear time without touch-ups needed."
          }
        }
      ]
    }
  ]
}
{% endschema %}
