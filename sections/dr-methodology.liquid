<section class="dr-methodology">
  <div class="dr-methodology__container">
    <h2 class="dr-methodology__heading">{{ section.settings.heading }}</h2>
    <div class="dr-methodology__grid">
      {% for block in section.blocks %}
        <div class="dr-methodology__item" {{ block.shopify_attributes }}>
          <div class="dr-methodology__number">{{ forloop.index }}</div>
          <div class="dr-methodology__content">
            <h3 class="dr-methodology__title">{{ block.settings.title }}</h3>
            <p class="dr-methodology__description">{{ block.settings.description }}</p>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
.dr-methodology {
  background: #f9f8f6;
  padding: 48px 24px;
}

.dr-methodology__container {
  max-width: 800px;
  margin: 0 auto;
}

.dr-methodology__heading {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 28px;
  font-weight: 400;
  text-align: center;
  margin: 0 0 40px;
  color: #1a1a1a;
}

.dr-methodology__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24px;
}

@media (max-width: 749px) {
  .dr-methodology__grid {
    grid-template-columns: 1fr;
  }
}

.dr-methodology__item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
}

.dr-methodology__number {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  background: #2c2c2c;
  color: #fff;
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 16px;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.dr-methodology__content {
  flex: 1;
}

.dr-methodology__title {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 16px;
  font-weight: 700;
  margin: 0 0 6px;
  color: #1a1a1a;
}

.dr-methodology__description {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 14px;
  line-height: 1.5;
  margin: 0;
  color: #6b6b6b;
}
{% endstylesheet %}

{% schema %}
{
  "name": "DR - Methodology",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How I Evaluated Each Foundation"
    }
  ],
  "blocks": [
    {
      "type": "criterion",
      "name": "Criterion",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Oxidation Resistance"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "How well the formula maintained its shade after 8 hours of wear."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DR - Methodology",
      "blocks": [
        {
          "type": "criterion",
          "settings": {
            "title": "Oxidation Resistance",
            "description": "How well the formula maintained its shade after 8 hours of wear."
          }
        },
        {
          "type": "criterion",
          "settings": {
            "title": "Shade Matching",
            "description": "Accuracy of color adaptation across different skin tones."
          }
        },
        {
          "type": "criterion",
          "settings": {
            "title": "Skin Feel & Texture",
            "description": "Comfort, breathability, and how natural it looks on mature skin."
          }
        },
        {
          "type": "criterion",
          "settings": {
            "title": "Longevity",
            "description": "Transfer resistance and wear time without touch-ups needed."
          }
        }
      ]
    }
  ]
}
{% endschema %}
