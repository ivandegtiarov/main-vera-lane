{%- comment -%} ── PF - REVIEWS ── {%- endcomment -%}
<section class="pf-reviews" {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %} style="--pf-reviews-bg: {{ section.settings.bg_color }};">
  <div class="pf-reviews__container">
    {%- if section.settings.headline != blank -%}
      <h2 class="pf-reviews__headline">{{ section.settings.headline }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="pf-reviews__grid">
        {%- for block in section.blocks -%}
          <article class="pf-reviews__card" {{ block.shopify_attributes }}>
            {%- if block.settings.rating > 0 -%}
              <div class="pf-reviews__stars">
                {%- for i in (1..5) -%}
                  <span class="pf-reviews__star {% if i <= block.settings.rating %}pf-reviews__star--filled{% endif %}">★</span>
                {%- endfor -%}
              </div>
            {%- endif -%}

            {%- if block.settings.title != blank -%}
              <h3 class="pf-reviews__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            <blockquote class="pf-reviews__quote">"{{ block.settings.quote }}"</blockquote>

            <footer class="pf-reviews__footer">
              <cite class="pf-reviews__author">{{ block.settings.author }}</cite>
              {%- if block.settings.verified -%}
                <span class="pf-reviews__verified">Verified Purchase</span>
              {%- endif -%}
            </footer>
          </article>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.more_text != blank -%}
      <p class="pf-reviews__more">{{ section.settings.more_text }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.pf-reviews {
  background: var(--pf-reviews-bg, #FAF9F6);
  padding: 4rem 1.5rem;
}

.pf-reviews__container {
  max-width: 900px;
  margin: 0 auto;
}

.pf-reviews__headline {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: clamp(1.375rem, 3vw, 1.75rem);
  font-weight: 400;
  line-height: 1.3;
  color: #1A1A1A;
  text-align: center;
  margin: 0 0 2.5rem;
}

.pf-reviews__grid {
  display: grid;
  gap: 1.5rem;
}

@media (min-width: 700px) {
  .pf-reviews__grid {
    grid-template-columns: repeat(3, 1fr);
  }
}

.pf-reviews__card {
  background: #fff;
  padding: 1.5rem;
  border: 1px solid #E8E6E3;
}

.pf-reviews__stars {
  display: flex;
  gap: 0.125rem;
  margin-bottom: 1rem;
}

.pf-reviews__star {
  font-size: 0.875rem;
  color: #E8E6E3;
}

.pf-reviews__star--filled {
  color: #C9A67A;
}

.pf-reviews__title {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.8125rem;
  font-weight: 600;
  color: #1A1A1A;
  margin: 0 0 0.75rem;
}

.pf-reviews__quote {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 0.9375rem;
  font-style: italic;
  line-height: 1.65;
  color: #444;
  margin: 0 0 1.25rem;
}

.pf-reviews__footer {
  display: flex;
  flex-direction: column;
  gap: 0.25rem;
}

.pf-reviews__author {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.75rem;
  font-style: normal;
  font-weight: 600;
  color: #1A1A1A;
}

.pf-reviews__verified {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.625rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: #7BA05B;
}

.pf-reviews__more {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 0.875rem;
  font-style: italic;
  color: #666;
  text-align: center;
  margin: 2rem 0 0;
}
{% endstylesheet %}

{% schema %}
{
  "name": "PF - Reviews",
  "tag": "section",
  "class": "pf-section",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FAF9F6"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "Life Changing Reviews"
    },
    {
      "type": "text",
      "id": "more_text",
      "label": "Footer text"
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "label": "Star rating",
          "min": 0,
          "max": 5,
          "step": 1,
          "default": 5
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "Finally found a solution that actually works for my dog's allergies."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Author",
          "default": "Sarah M."
        },
        {
          "type": "checkbox",
          "id": "verified",
          "label": "Show verified badge",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PF - Reviews",
      "category": "t:categories.pawfy_editorial",
      "blocks": [
        { "type": "review", "settings": { "title": "Finally, relief!", "quote": "Finally found a solution that actually works. My dog stopped scratching within two weeks.", "author": "Sarah M." } },
        { "type": "review", "settings": { "title": "Game changer", "quote": "This was the first thing I've tried that's actually worked for my dog's itchy skin.", "author": "Emma L." } },
        { "type": "review", "settings": { "title": "Worth every penny", "quote": "I was skeptical but this is the only thing that has given her relief from allergies.", "author": "Michael K." } }
      ]
    }
  ]
}
{% endschema %}
