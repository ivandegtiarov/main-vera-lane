{%- comment -%} ── PF - HERO ARTICLE ── {%- endcomment -%}
<article class="pf-hero-article" {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}>
  <div class="pf-hero-article__container">
    <header class="pf-hero-article__header">
      <h1 class="pf-hero-article__headline">{{ section.settings.headline }}</h1>

      {%- if section.settings.subheadline != blank -%}
        <p class="pf-hero-article__subheadline">{{ section.settings.subheadline }}</p>
      {%- endif -%}

      <div class="pf-hero-article__meta">
        {%- if section.settings.author_image != blank -%}
          <img
            src="{{ section.settings.author_image | image_url: width: 80 }}"
            alt="{{ section.settings.author | escape }}"
            class="pf-hero-article__author-image"
            loading="lazy"
          >
        {%- endif -%}
        <div class="pf-hero-article__meta-text">
          {%- if section.settings.author != blank -%}
            <span class="pf-hero-article__author">{{ section.settings.author }}</span>
          {%- endif -%}
          {%- if section.settings.date != blank -%}
            <span class="pf-hero-article__date">{{ section.settings.date }}</span>
          {%- endif -%}
        </div>
      </div>
    </header>

    {%- liquid
      assign content_blocks = section.blocks | where: 'type', 'paragraph' | concat: section.blocks | where: 'type', 'subheading' | concat: section.blocks | where: 'type', 'callout' | concat: section.blocks | where: 'type', 'image' | concat: section.blocks | where: 'type', 'bullet_list'
      assign sidebar_blocks = section.blocks | where: 'type', 'feature'
    -%}

    <div class="pf-hero-article__layout">
      <div class="pf-hero-article__content">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'paragraph' -%}
              <div class="pf-hero-article__paragraph" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>

            {%- when 'subheading' -%}
              <h2 class="pf-hero-article__subheading" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </h2>

            {%- when 'callout' -%}
              <blockquote class="pf-hero-article__callout" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </blockquote>

            {%- when 'image' -%}
              {%- if block.settings.image != blank -%}
                <figure class="pf-hero-article__inline-figure" {{ block.shopify_attributes }}>
                  <img
                    src="{{ block.settings.image | image_url: width: 800 }}"
                    alt="{{ block.settings.image.alt | escape }}"
                    class="pf-hero-article__inline-image"
                    loading="lazy"
                  >
                  {%- if block.settings.caption != blank -%}
                    <figcaption class="pf-hero-article__inline-caption">{{ block.settings.caption }}</figcaption>
                  {%- endif -%}
                </figure>
              {%- endif -%}

            {%- when 'bullet_list' -%}
              <div class="pf-hero-article__bullets" {{ block.shopify_attributes }}>
                {{ block.settings.text }}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>

      {%- if section.settings.sidebar_image != blank or sidebar_blocks.size > 0 or section.settings.sidebar_cta_text != blank -%}
        <aside class="pf-hero-article__sidebar">
          {%- if section.settings.sidebar_image != blank -%}
            <figure class="pf-hero-article__sidebar-figure">
              <img
                src="{{ section.settings.sidebar_image | image_url: width: 500 }}"
                alt="{{ section.settings.sidebar_image.alt | escape }}"
                class="pf-hero-article__sidebar-image"
                loading="lazy"
              >
              {%- if section.settings.sidebar_caption != blank -%}
                <figcaption class="pf-hero-article__sidebar-caption">{{ section.settings.sidebar_caption }}</figcaption>
              {%- endif -%}
            </figure>
          {%- endif -%}

          {%- if section.settings.sidebar_cta_text != blank -%}
            {%- liquid
              if section.settings.sidebar_cta_link_type == 'anchor' and section.settings.sidebar_cta_anchor != blank
                assign cta_href = '#' | append: section.settings.sidebar_cta_anchor
              else
                assign cta_href = section.settings.sidebar_cta_url
              endif
            -%}
            <a href="{{ cta_href }}" class="pf-hero-article__sidebar-cta">{{ section.settings.sidebar_cta_text }}</a>
          {%- endif -%}

          {%- if sidebar_blocks.size > 0 -%}
            <ul class="pf-hero-article__sidebar-features">
              {%- for block in sidebar_blocks -%}
                <li class="pf-hero-article__sidebar-feature" {{ block.shopify_attributes }}>
                  {{ block.settings.text }}
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </aside>
      {%- endif -%}
    </div>
  </div>
</article>

{% stylesheet %}
.pf-hero-article {
  background: #fff;
  padding: 3rem 1.5rem;
}

.pf-hero-article__container {
  max-width: 1000px;
  margin: 0 auto;
}

.pf-hero-article__header {
  max-width: 720px;
  margin-bottom: 2.5rem;
}

.pf-hero-article__headline {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  font-weight: 400;
  line-height: 1.2;
  color: #1A1A1A;
  margin: 0 0 1rem;
}

.pf-hero-article__subheadline {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1.125rem;
  font-style: italic;
  line-height: 1.5;
  color: #666;
  margin: 0 0 1.5rem;
}

.pf-hero-article__meta {
  display: flex;
  align-items: center;
  gap: 0.875rem;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.75rem;
  color: #888;
  letter-spacing: 0.02em;
}

.pf-hero-article__author-image {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  object-fit: cover;
}

.pf-hero-article__meta-text {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.pf-hero-article__author {
  font-weight: 500;
  color: #666;
}

.pf-hero-article__layout {
  display: grid;
  gap: 3rem;
}

@media (min-width: 768px) {
  .pf-hero-article__layout {
    grid-template-columns: 1fr 320px;
    gap: 4rem;
    align-items: start;
  }
}

/* Content blocks */
.pf-hero-article__content > *:not(:last-child) {
  margin-bottom: 1.5rem;
}

.pf-hero-article__paragraph {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1rem;
  line-height: 1.85;
  color: #444;
}

.pf-hero-article__paragraph p {
  margin-bottom: 1.5rem;
}

.pf-hero-article__paragraph p:last-child {
  margin-bottom: 0;
}

.pf-hero-article__paragraph strong {
  font-weight: 600;
  color: #1A1A1A;
}

.pf-hero-article__subheading {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1.375rem;
  font-weight: 400;
  line-height: 1.3;
  color: #1A1A1A;
  margin: 2rem 0 1rem;
}

.pf-hero-article__callout {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1rem;
  font-style: italic;
  line-height: 1.7;
  color: #1A1A1A;
  margin: 0;
  padding: 1.5rem 2rem;
  background: #FAF9F6;
  border-left: 3px solid #C9A67A;
}

.pf-hero-article__inline-figure {
  margin: 2rem 0;
}

.pf-hero-article__inline-image {
  width: 100%;
  height: auto;
}

.pf-hero-article__inline-caption {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.75rem;
  font-style: italic;
  color: #888;
  margin-top: 0.75rem;
  text-align: center;
}

.pf-hero-article__bullets {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1rem;
  line-height: 1.8;
  color: #444;
}

.pf-hero-article__bullets ul {
  list-style: none;
  margin: 0;
  padding: 0;
}

.pf-hero-article__bullets li {
  position: relative;
  padding-left: 1.5rem;
  margin-bottom: 0.75rem;
}

.pf-hero-article__bullets li::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0.6em;
  width: 6px;
  height: 6px;
  background: #C9A67A;
  border-radius: 50%;
}

/* Sidebar */
.pf-hero-article__sidebar {
  background: #FAF9F6;
  padding: 1.5rem;
  border: 1px solid #E8E6E3;
  position: sticky;
  top: 2rem;
}

.pf-hero-article__sidebar-figure {
  margin: 0 0 1.5rem;
}

.pf-hero-article__sidebar-image {
  width: 100%;
  height: auto;
}

.pf-hero-article__sidebar-caption {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.6875rem;
  font-style: italic;
  color: #888;
  margin-top: 0.75rem;
  text-align: center;
}

.pf-hero-article__sidebar-cta {
  display: block;
  background: #2A2A2A;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  text-decoration: none;
  text-align: center;
  padding: 1rem;
  margin-bottom: 1.5rem;
  transition: background 200ms ease;
}

.pf-hero-article__sidebar-cta:hover {
  background: #1A1A1A;
}

.pf-hero-article__sidebar-features {
  list-style: none;
  margin: 0;
  padding: 0;
}

.pf-hero-article__sidebar-feature {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.75rem;
  color: #555;
  padding: 0.625rem 0;
  border-bottom: 1px solid #E8E6E3;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.pf-hero-article__sidebar-feature::before {
  content: '';
  width: 4px;
  height: 4px;
  background: #C9A67A;
  border-radius: 50%;
  flex-shrink: 0;
}

.pf-hero-article__sidebar-feature:last-child {
  border-bottom: none;
}
{% endstylesheet %}

{% schema %}
{
  "name": "PF - Hero Article",
  "tag": "section",
  "class": "pf-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "For anchor links"
    },
    {
      "type": "header",
      "content": "Headline"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "Your Dogs Allergies are Making Their Life Miserable. This Allergy Chew Offers Fast Relief"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "A veterinarian-developed formula that actually works"
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "Author image"
    },
    {
      "type": "text",
      "id": "author",
      "label": "Author",
      "default": "Dr. Emily Ray, DVM"
    },
    {
      "type": "text",
      "id": "date",
      "label": "Date",
      "default": "Updated March 2026"
    },
    {
      "type": "header",
      "content": "Sidebar"
    },
    {
      "type": "image_picker",
      "id": "sidebar_image",
      "label": "Sidebar image"
    },
    {
      "type": "text",
      "id": "sidebar_caption",
      "label": "Image caption"
    },
    {
      "type": "text",
      "id": "sidebar_cta_text",
      "label": "Button text",
      "default": "Check Availability"
    },
    {
      "type": "select",
      "id": "sidebar_cta_link_type",
      "label": "Link type",
      "options": [
        { "value": "anchor", "label": "Scroll to section on page" },
        { "value": "url", "label": "Link to URL" }
      ],
      "default": "anchor"
    },
    {
      "type": "text",
      "id": "sidebar_cta_anchor",
      "label": "Section ID to scroll to",
      "default": "offer"
    },
    {
      "type": "url",
      "id": "sidebar_cta_url",
      "label": "Button URL"
    }
  ],
  "blocks": [
    {
      "type": "paragraph",
      "name": "Paragraph",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "Text",
          "default": "<p>Add your article content here. You can use <strong>bold</strong> and <em>italic</em> text.</p>"
        }
      ]
    },
    {
      "type": "subheading",
      "name": "Subheading",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Subheading text",
          "default": "Section Subheading"
        }
      ]
    },
    {
      "type": "callout",
      "name": "Callout",
      "settings": [
        {
          "type": "textarea",
          "id": "text",
          "label": "Callout text",
          "default": "This is a highlighted callout to draw attention to important information."
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "caption",
          "label": "Caption"
        }
      ]
    },
    {
      "type": "bullet_list",
      "name": "Bullet List",
      "settings": [
        {
          "type": "richtext",
          "id": "text",
          "label": "List items",
          "default": "<ul><li>First item</li><li>Second item</li><li>Third item</li></ul>"
        }
      ]
    },
    {
      "type": "feature",
      "name": "Sidebar Feature",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Feature text",
          "default": "60-day money back guarantee"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PF - Hero Article",
      "category": "t:categories.pawfy_editorial",
      "blocks": [
        { "type": "paragraph", "settings": { "text": "<p>Is your dog constantly scratching, biting at their paws, or dealing with red, irritated skin? These are signs their immune system is out of balance.</p>" } },
        { "type": "callout", "settings": { "text": "Most allergy solutions only mask symptoms. This formula addresses the root cause." } },
        { "type": "paragraph", "settings": { "text": "<p>After years of research, veterinarians developed a formula that combines probiotics, omega fatty acids, and natural anti-inflammatory ingredients to provide lasting relief.</p>" } },
        { "type": "feature", "settings": { "text": "60-day money back guarantee" } },
        { "type": "feature", "settings": { "text": "Billions of good bacteria" } },
        { "type": "feature", "settings": { "text": "Vet recommended formula" } }
      ]
    }
  ]
}
{% endschema %}
