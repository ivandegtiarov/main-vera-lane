      "type": "swatch",
      "name": "Color Swatch",
      "settings": [
        {
          "type": "image_picker",
          "id": "swatch_image",
          "label": "Swatch image"
        },
        {
          "type": "text",
          "id": "swatch_label",
          "label": "Color name",
          "default": "Natural"
