<!--
  Vera Lane – Grid Benefits Section
  Responsive benefits section with customizable blocks
-->

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&family=Montserrat:wght@400;600&display=swap" rel="stylesheet">

<section
  class="grid-benefits section-{{ section.id }}-padding{% if section.settings.enable_animation %} grid-benefits--animate{% endif %}"
  aria-label="{{ section.settings.section_label }}"
  role="region"
  data-animation-enabled="{{ section.settings.enable_animation }}"
  style="--padding-top-mobile: {{ section.settings.padding_top_mobile }}px; --padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px; --padding-top-desktop: {{ section.settings.padding_top_desktop }}px; --padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px; --title-font-size-mobile: {{ section.settings.title_font_size_mobile }}px; --title-font-size-desktop: {{ section.settings.title_font_size_desktop }}px; --item-title-font-size-mobile: {{ section.settings.item_title_font_size_mobile }}px; --item-title-font-size-desktop: {{ section.settings.item_title_font_size_desktop }}px; --item-text-font-size-mobile: {{ section.settings.item_text_font_size_mobile }}px; --item-text-font-size-desktop: {{ section.settings.item_text_font_size_desktop }}px;"
>
  <div class="grid-benefits__inner">
    <!-- Left/Top Section: Title & Image -->
    <div class="grid-benefits__hero">
      <h2 class="grid-benefits__title">{{ section.settings.main_title }}</h2>
      
      <div class="grid-benefits__image-wrapper">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              class: 'grid-benefits__image',
              widths: '294, 420, 640, 800, 1200',
              sizes: '(max-width: 767px) 100vw, (max-width: 1023px) 420px, 640px'
          }}
        {%- else -%}
          <div class="grid-benefits__image placeholder-svg">
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>
    </div>

    <!-- Right/Bottom Section: Benefits Grid -->
    <div class="grid-benefits__grid">
      {%- for block in section.blocks -%}
        <article class="grid-benefit__item" data-block-id="{{ block.id }}" {{ block.shopify_attributes }}>
          <h3 class="grid-benefit__item-title">{{ block.settings.title }}</h3>
          <p class="grid-benefit__item-description">{{ block.settings.description }}</p>
        </article>
      {%- endfor -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .grid-benefits {
    position: relative;
    width: 100%;
    background-color: #ffffff;
    padding-top: var(--padding-top-mobile);
    padding-bottom: var(--padding-bottom-mobile);
  }

  @media (min-width: 768px) {
    .grid-benefits {
      padding-top: var(--padding-top-desktop);
      padding-bottom: var(--padding-bottom-desktop);
    }
  }

  .grid-benefits__inner {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 20px;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  @media (min-width: 768px) {
    .grid-benefits__inner {
      padding: 0 40px;
      gap: 60px;
    }
  }

  @media (min-width: 1024px) {
    .grid-benefits__inner {
      padding: 0 96px;
      flex-direction: row;
      gap: 100px;
    }
  }

  @media (min-width: 1440px) {
    .grid-benefits__inner {
      max-width: 1440px;
    }
  }

  .grid-benefits__hero {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (min-width: 1024px) {
    .grid-benefits__hero {
      flex-shrink: 0;
      width: 307px;
      gap: 56px;
    }
  }

  .grid-benefits__title {
    margin: 0;
    font-family: 'Playfair Display', serif;
    font-weight: 700;
    font-size: var(--title-font-size-mobile);
    line-height: 1.3333333333em;
    color: #000000;
    width: 100%;
    font-style: italic;
  }

  @media (min-width: 768px) {
    .grid-benefits__title {
      font-size: calc(var(--title-font-size-mobile) + (var(--title-font-size-desktop) - var(--title-font-size-mobile)) * 0.5);
    }
  }

  @media (min-width: 1024px) {
    .grid-benefits__title {
      font-size: var(--title-font-size-desktop);
      line-height: 1.4em;
    }
  }

  .grid-benefits__image-wrapper {
    position: relative;
    width: 100%;
  }

  .grid-benefits__image {
    display: block;
    width: 100%;
    height: 320px;
    border-radius: 12px;
    object-fit: cover;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .grid-benefits__image:hover {
    transform: scale(1.02) translateY(-2px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
  }

  .grid-benefits__grid {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  @media (min-width: 768px) {
    .grid-benefits__grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 32px;
    }
  }

  @media (min-width: 1024px) {
    .grid-benefits__grid {
      flex: 1;
      gap: 48px;
    }
  }

  .grid-benefit__item {
    display: flex;
    flex-direction: column;
    gap: 4px;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
    cursor: pointer;
    padding: 16px;
    margin: -16px;
    border-radius: 12px;
  }

  .grid-benefit__item:hover {
    transform: scale(1.05);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  .grid-benefit__item-title {
    margin: 0;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: var(--item-title-font-size-mobile);
    line-height: 1.5em;
    color: #000000;
    width: 100%;
  }

  @media (min-width: 768px) {
    .grid-benefit__item-title {
      font-size: calc(var(--item-title-font-size-mobile) + (var(--item-title-font-size-desktop) - var(--item-title-font-size-mobile)) * 0.5);
    }
  }

  @media (min-width: 1024px) {
    .grid-benefit__item-title {
      font-size: var(--item-title-font-size-desktop);
      line-height: 1.5555555556em;
    }
  }

  .grid-benefit__item-description {
    margin: 0;
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: var(--item-text-font-size-mobile);
    line-height: 1.5714285714em;
    color: #000000;
    width: 100%;
  }

  @media (min-width: 768px) {
    .grid-benefit__item-description {
      font-size: calc(var(--item-text-font-size-mobile) + (var(--item-text-font-size-desktop) - var(--item-text-font-size-mobile)) * 0.5);
    }
  }

  @media (min-width: 1024px) {
    .grid-benefit__item-description {
      font-size: var(--item-text-font-size-desktop);
    }
  }

  /* Fade-in animation */
  .grid-benefits--animate .grid-benefit__item,
  .grid-benefits--animate .grid-benefits__image-wrapper,
  .grid-benefits--animate .grid-benefits__title {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  .grid-benefits--animate .grid-benefit__item.is-visible,
  .grid-benefits--animate .grid-benefits__image-wrapper.is-visible,
  .grid-benefits--animate .grid-benefits__title.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .grid-benefits--animate .grid-benefit__item:hover.is-visible {
    transform: translateY(0) scale(1.05);
  }

  /* Staggered animation delays */
  .grid-benefits--animate .grid-benefits__title {
    transition-delay: 0.1s;
  }

  .grid-benefits--animate .grid-benefits__image-wrapper {
    transition-delay: 0.2s;
  }

  .grid-benefits--animate .grid-benefit__item:nth-child(1) {
    transition-delay: 0.3s;
  }

  .grid-benefits--animate .grid-benefit__item:nth-child(2) {
    transition-delay: 0.4s;
  }

  .grid-benefits--animate .grid-benefit__item:nth-child(3) {
    transition-delay: 0.5s;
  }

  .grid-benefits--animate .grid-benefit__item:nth-child(4) {
    transition-delay: 0.6s;
  }

  .grid-benefits--animate .grid-benefit__item:nth-child(5) {
    transition-delay: 0.7s;
  }

  .grid-benefits--animate .grid-benefit__item:nth-child(6) {
    transition-delay: 0.8s;
  }

  .grid-benefits__image.placeholder-svg,
  .grid-benefits__image .placeholder-svg {
    width: 100%;
    height: 320px;
    background-color: #f3f3f3;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
  }
{% endstylesheet %}

{% javascript %}
  // Add fade-in animation on scroll
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.grid-benefits');
    if (!section) return;

    const animationEnabled = section.getAttribute('data-animation-enabled') === 'true';
    
    if (animationEnabled && 'IntersectionObserver' in window) {
      const animatedElements = section.querySelectorAll('.grid-benefit__item, .grid-benefits__image-wrapper, .grid-benefits__title');
      
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -100px 0px',
        threshold: 0.1
      };
      
      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);
      
      animatedElements.forEach(element => {
        observer.observe(element);
      });
    } else if (animationEnabled) {
      // Fallback for browsers without IntersectionObserver
      const animatedElements = section.querySelectorAll('.grid-benefit__item, .grid-benefits__image-wrapper, .grid-benefits__title');
      animatedElements.forEach(element => {
        element.classList.add('is-visible');
      });
    }
  });
{% endjavascript %}

