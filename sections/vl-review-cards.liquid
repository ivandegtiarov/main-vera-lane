{%- comment -%} ── VL - REVIEW CARDS ── {%- endcomment -%}
<section class="vl-review-cards" {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %} style="--rc-bg: {{ section.settings.bg_color }}; --rc-card-bg: {{ section.settings.card_bg_color }}; --rc-star-color: {{ section.settings.star_color }}; --rc-text-color: {{ section.settings.text_color }}; --rc-name-color: {{ section.settings.name_color }};">
  <div class="vl-review-cards__container">
    {%- if section.settings.headline != blank -%}
      <div class="vl-review-cards__header">
        <h2 class="vl-review-cards__headline">{{ section.settings.headline }}</h2>
        {%- if section.settings.show_rating_summary -%}
          <div class="vl-review-cards__summary">
            <span class="vl-review-cards__summary-stars">
              {%- for i in (1..5) -%}
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
              {%- endfor -%}
            </span>
            <span class="vl-review-cards__summary-text">{{ section.settings.rating_summary_text }}</span>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      {%- assign initial_count = section.settings.initial_count -%}
      {%- assign hidden_count = section.blocks.size | minus: initial_count -%}
      <div class="vl-review-cards__grid" data-initial-count="{{ initial_count }}">
        {%- for block in section.blocks -%}
          {%- assign has_review_image = false -%}
          {%- assign review_img_src = '' -%}
          {%- if block.settings.review_image != blank -%}
            {%- assign has_review_image = true -%}
            {%- assign review_img_src = block.settings.review_image | image_url: width: 600 -%}
          {%- elsif block.settings.review_image_asset != blank -%}
            {%- assign has_review_image = true -%}
            {%- assign review_img_src = block.settings.review_image_asset | asset_url -%}
          {%- endif -%}
          <article class="vl-review-cards__card {% if has_review_image %}vl-review-cards__card--has-image{% endif %}{% if forloop.index > initial_count %} vl-review-cards__card--hidden{% endif %}" data-index="{{ forloop.index }}" {{ block.shopify_attributes }}>
            {%- if has_review_image -%}
              <div class="vl-review-cards__review-image">
                <img
                  src="{{ review_img_src }}"
                  alt="Customer photo"
                  loading="lazy"
                  class="vl-review-cards__review-img"
                >
              </div>
            {%- endif -%}
            <div class="vl-review-cards__card-top">
              <div class="vl-review-cards__rating-row">
                <div class="vl-review-cards__stars">
                  {%- for i in (1..5) -%}
                    <span class="vl-review-cards__star {% if i <= block.settings.rating %}vl-review-cards__star--filled{% endif %}">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                      </svg>
                    </span>
                  {%- endfor -%}
                </div>
                {%- if block.settings.date != blank -%}
                  <span class="vl-review-cards__date">{{ block.settings.date }}</span>
                {%- endif -%}
              </div>

              {%- if block.settings.title != blank -%}
                <h3 class="vl-review-cards__title">{{ block.settings.title }}</h3>
              {%- endif -%}

              <p class="vl-review-cards__quote">{{ block.settings.quote }}</p>
            </div>

            <footer class="vl-review-cards__footer">
              <div class="vl-review-cards__author-row">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 80 }}"
                    alt="{{ block.settings.name | escape }}"
                    class="vl-review-cards__avatar"
                    loading="lazy"
                    width="32"
                    height="32"
                  >
                {%- else -%}
                  <span class="vl-review-cards__avatar-placeholder">{{ block.settings.name | slice: 0 }}</span>
                {%- endif -%}
                <span class="vl-review-cards__name">{{ block.settings.name }}</span>
              </div>
              {%- if block.settings.verified -%}
                <span class="vl-review-cards__verified">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/></svg>
                  Verified Buyer
                </span>
              {%- endif -%}
            </footer>
          </article>
        {%- endfor -%}
      </div>

      {%- if section.blocks.size > initial_count or section.settings.see_all_url != blank -%}
        <div class="vl-review-cards__actions">
          {%- if hidden_count > 0 -%}
            <button type="button" class="vl-review-cards__load-more" data-load-more data-hidden-count="{{ hidden_count }}">
              {{ section.settings.load_more_text }}
            </button>
          {%- endif -%}
          <a href="{{ section.settings.see_all_url }}" class="vl-review-cards__see-all {% if hidden_count > 0 %}vl-review-cards__see-all--hidden{% endif %}">
            {{ section.settings.see_all_text }}
          </a>
        </div>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.vl-review-cards {
  background: var(--rc-bg, #ffffff);
  padding: 3rem 1rem;
}

@media (min-width: 750px) {
  .vl-review-cards {
    padding: 4rem 1.5rem;
  }
}

.vl-review-cards__container {
  max-width: 1200px;
  margin: 0 auto;
}

.vl-review-cards__header {
  margin-bottom: 1.5rem;
}

@media (min-width: 750px) {
  .vl-review-cards__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
}

.vl-review-cards__headline {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 1.25rem;
  font-weight: 600;
  color: #1a1a1a;
  margin: 0 0 0.75rem;
}

@media (min-width: 750px) {
  .vl-review-cards__headline {
    font-size: 1.5rem;
    margin: 0;
  }
}

.vl-review-cards__summary {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.vl-review-cards__summary-stars {
  display: flex;
  gap: 1px;
  color: #fbbf24;
}

.vl-review-cards__summary-text {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.8125rem;
  color: #6b7280;
}

.vl-review-cards__grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 1rem;
}

@media (min-width: 550px) {
  .vl-review-cards__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 900px) {
  .vl-review-cards__grid {
    grid-template-columns: repeat(4, 1fr);
  }
}

.vl-review-cards__card {
  background: var(--rc-card-bg, #ffffff);
  border: 1px solid #e5e7eb;
  border-radius: 4px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-height: 200px;
  overflow: hidden;
}

.vl-review-cards__card:not(.vl-review-cards__card--has-image) {
  padding: 1.25rem;
}

.vl-review-cards__card--has-image .vl-review-cards__card-top,
.vl-review-cards__card--has-image .vl-review-cards__footer {
  padding: 0 1.25rem;
}

.vl-review-cards__card--has-image .vl-review-cards__card-top {
  padding-top: 1rem;
}

.vl-review-cards__card--has-image .vl-review-cards__footer {
  padding-bottom: 1.5rem;
}

.vl-review-cards__card:nth-child(odd) {
  background: #fefefe;
}

.vl-review-cards__review-image {
  width: 100%;
  aspect-ratio: 4/3;
  overflow: hidden;
  background: #f3f4f6;
}

.vl-review-cards__review-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

.vl-review-cards__card-top {
  flex: 1;
}

.vl-review-cards__rating-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 0.625rem;
}

.vl-review-cards__stars {
  display: flex;
  gap: 1px;
}

.vl-review-cards__star {
  color: #d1d5db;
  display: flex;
  align-items: center;
}

.vl-review-cards__star--filled {
  color: #fbbf24;
}

.vl-review-cards__date {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.6875rem;
  color: #9ca3af;
  text-transform: uppercase;
  letter-spacing: 0.02em;
}

.vl-review-cards__title {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.875rem;
  font-weight: 600;
  color: #1f2937;
  margin: 0 0 0.5rem;
  line-height: 1.3;
}

.vl-review-cards__quote {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.875rem;
  line-height: 1.5;
  color: #4b5563;
  margin: 0;
}

.vl-review-cards__footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 1rem;
  padding-top: 0.875rem;
  border-top: 1px solid #f3f4f6;
}

.vl-review-cards__author-row {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.vl-review-cards__avatar {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  object-fit: cover;
}

.vl-review-cards__avatar-placeholder {
  width: 28px;
  height: 28px;
  border-radius: 50%;
  background: #e5e7eb;
  color: #6b7280;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.75rem;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  text-transform: uppercase;
}

.vl-review-cards__name {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.8125rem;
  font-weight: 500;
  color: #374151;
}

.vl-review-cards__verified {
  display: inline-flex;
  align-items: center;
  gap: 0.25rem;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.6875rem;
  font-weight: 500;
  color: #059669;
  background: #ecfdf5;
  padding: 0.25rem 0.5rem;
  border-radius: 2px;
}

.vl-review-cards__verified svg {
  flex-shrink: 0;
}

.vl-review-cards__card--hidden {
  display: none;
}

.vl-review-cards__actions {
  display: flex;
  justify-content: center;
  margin-top: 2rem;
}

.vl-review-cards__load-more {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.875rem;
  font-weight: 500;
  color: #374151;
  background: #ffffff;
  border: 1px solid #d1d5db;
  border-radius: 4px;
  padding: 0.75rem 1.5rem;
  cursor: pointer;
  transition: all 0.15s ease;
}

.vl-review-cards__load-more:hover {
  background: #f9fafb;
  border-color: #9ca3af;
}

.vl-review-cards__see-all {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.875rem;
  font-weight: 500;
  color: #374151;
  background: #ffffff;
  border: 1px solid #d1d5db;
  border-radius: 4px;
  padding: 0.75rem 1.5rem;
  text-decoration: none;
  transition: all 0.15s ease;
}

.vl-review-cards__see-all:hover {
  background: #f9fafb;
  border-color: #9ca3af;
}

.vl-review-cards__see-all--hidden {
  display: none;
}
{% endstylesheet %}

{% javascript %}
(function() {
  const loadMoreBtns = document.querySelectorAll('[data-load-more]');

  loadMoreBtns.forEach(function(btn) {
    btn.addEventListener('click', function() {
      const section = btn.closest('.vl-review-cards');
      const hiddenCards = section.querySelectorAll('.vl-review-cards__card--hidden');
      const seeAllLink = section.querySelector('.vl-review-cards__see-all');

      // Show all hidden cards
      hiddenCards.forEach(function(card) {
        card.classList.remove('vl-review-cards__card--hidden');
      });

      // Hide the Load More button
      btn.style.display = 'none';

      // Show the See All link
      if (seeAllLink) {
        seeAllLink.classList.remove('vl-review-cards__see-all--hidden');
      }
    });
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "VL - Review Cards",
  "tag": "section",
  "class": "vl-section",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "For anchor links (e.g., 'reviews')"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Customer Reviews"
    },
    {
      "type": "checkbox",
      "id": "show_rating_summary",
      "label": "Show rating summary",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_summary_text",
      "label": "Rating summary text",
      "default": "Based on 1,247 reviews"
    },
    {
      "type": "header",
      "content": "Load More"
    },
    {
      "type": "range",
      "id": "initial_count",
      "label": "Reviews to show initially",
      "min": 4,
      "max": 16,
      "step": 4,
      "default": 8
    },
    {
      "type": "text",
