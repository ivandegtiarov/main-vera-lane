<div class="ss-astrologers">
  <div class="ss-astrologers__container">
    <div class="ss-astrologers__text">
      <h2 class="ss-astrologers__heading">Designed by Expert Astrologers</h2>
      <p class="ss-astrologers__description">Every Star Story book is crafted under the guidance of certified astrologers who bring decades of experience in natal chart interpretation. Our team ensures that each page of your personalized book reflects accurate, meaningful insights drawn from the positions of celestial bodies at the exact moment of your birth.</p>
      <h3 class="ss-astrologers__subheading">Meet Our Astrologers</h3>
    </div>
    <div class="ss-astrologers__cards">
      <div class="ss-astrologers__card ss-astrologers__card--first">
        <img
          class="ss-astrologers__card-image"
          src="{{ 'ss-astrologer-1.png' | asset_url }}"
          alt="Sophia Hartley"
          loading="lazy"
          width="200"
          height="200"
        >
        <p class="ss-astrologers__card-name">Sophia Hartley</p>
        <p class="ss-astrologers__card-title">Professional Astrologer</p>
      </div>
      <div class="ss-astrologers__card ss-astrologers__card--second">
        <img
          class="ss-astrologers__card-image"
          src="{{ 'ss-astrologer-2.png' | asset_url }}"
          alt="Maya Fitzgerald"
          loading="lazy"
          width="200"
          height="200"
        >
        <p class="ss-astrologers__card-name">Maya Fitzgerald</p>
        <p class="ss-astrologers__card-title">Astrological Consultant and Author</p>
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
.ss-astrologers {
  background-color: #f0ebe1;
  padding: 100px 20px;
}

.ss-astrologers__container {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 60px;
}

.ss-astrologers__text {
  flex: 1;
}

.ss-astrologers__heading {
  font-family: "Noto Serif", serif;
  color: #1a3050;
  font-size: 32px;
  line-height: 1.3;
  margin: 0 0 20px;
}

.ss-astrologers__description {
  font-family: "DM Sans", sans-serif;
  color: #292929;
  font-size: 16px;
  line-height: 1.7;
  margin: 0 0 28px;
}

.ss-astrologers__subheading {
  font-family: "Noto Serif", serif;
  color: #1a3050;
  font-size: 22px;
  margin: 0;
}

.ss-astrologers__cards {
  flex: 1;
  display: flex;
  justify-content: center;
  position: relative;
}

.ss-astrologers__card {
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  padding: 16px;
  text-align: center;
  width: 230px;
}

.ss-astrologers__card--first {
  position: relative;
  bottom: 49px;
  z-index: 2;
}

.ss-astrologers__card--second {
  position: relative;
  top: 49px;
  margin-left: -30px;
  z-index: 1;
}

.ss-astrologers__card-image {
  width: 200px;
  height: auto;
  border-radius: 12px;
  display: block;
  margin: 0 auto 12px;
}

.ss-astrologers__card-name {
  font-family: "DM Sans", sans-serif;
  color: #1a3050;
  font-size: 16px;
  font-weight: 700;
  margin: 0 0 4px;
}

.ss-astrologers__card-title {
  font-family: "DM Sans", sans-serif;
  color: #292929;
  font-size: 14px;
  margin: 0;
}

@media screen and (max-width: 768px) {
  .ss-astrologers {
    padding: 45px 20px;
  }

  .ss-astrologers__container {
    flex-direction: column;
    gap: 40px;
  }

  .ss-astrologers__heading {
    font-size: 26px;
  }

  .ss-astrologers__cards {
    flex-direction: row;
    gap: 16px;
  }

  .ss-astrologers__card--first {
    bottom: 0;
  }

  .ss-astrologers__card--second {
    top: 0;
    margin-left: 0;
  }

  .ss-astrologers__card {
    width: 48%;
  }

  .ss-astrologers__card-image {
    width: 100%;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "SS - Astrologers",
  "settings": []
}
{% endschema %}
