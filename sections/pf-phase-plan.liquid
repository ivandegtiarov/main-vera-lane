{%- comment -%} ── PF - PHASE PLAN ── {%- endcomment -%}
<section class="pf-phase-plan" {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}>
  <div class="pf-phase-plan__container">
    <header class="pf-phase-plan__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="pf-phase-plan__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      <h2 class="pf-phase-plan__headline">{{ section.settings.headline }}</h2>
      {%- if section.settings.subheadline != blank -%}
        <p class="pf-phase-plan__subheadline">{{ section.settings.subheadline }}</p>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="pf-phase-plan__phases">
        {%- for block in section.blocks -%}
          <div class="pf-phase-plan__phase" {{ block.shopify_attributes }}>
            <span class="pf-phase-plan__phase-number">{{ block.settings.number }}</span>
            <div class="pf-phase-plan__phase-content">
              <h3 class="pf-phase-plan__phase-title">{{ block.settings.title }}</h3>
              <p class="pf-phase-plan__phase-desc">{{ block.settings.description }}</p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.footer_text != blank -%}
      <p class="pf-phase-plan__footer">{{ section.settings.footer_text }}</p>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.pf-phase-plan {
  background: #fff;
  padding: 4rem 1.5rem;
  border-top: 1px solid #E8E6E3;
  border-bottom: 1px solid #E8E6E3;
}

.pf-phase-plan__container {
  max-width: 720px;
  margin: 0 auto;
}

.pf-phase-plan__header {
  text-align: center;
  margin-bottom: 3rem;
}

.pf-phase-plan__eyebrow {
  display: block;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.6875rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  color: #C9A67A;
  margin-bottom: 0.75rem;
}

.pf-phase-plan__headline {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: clamp(1.375rem, 3vw, 1.75rem);
  font-weight: 400;
  line-height: 1.3;
  color: #1A1A1A;
  margin: 0 0 0.75rem;
}

.pf-phase-plan__subheadline {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1rem;
  font-style: italic;
  color: #666;
  margin: 0;
}

.pf-phase-plan__phases {
  display: flex;
  flex-direction: column;
  gap: 0;
}

.pf-phase-plan__phase {
  display: grid;
  grid-template-columns: 3rem 1fr;
  gap: 1.5rem;
  padding: 2rem 0;
  border-bottom: 1px solid #E8E6E3;
}

.pf-phase-plan__phase:last-child {
  border-bottom: none;
}

.pf-phase-plan__phase-number {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 2rem;
  font-weight: 400;
  color: #C9A67A;
  line-height: 1;
}

.pf-phase-plan__phase-title {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.875rem;
  font-weight: 600;
  letter-spacing: 0.02em;
  color: #1A1A1A;
  margin: 0 0 0.5rem;
}

.pf-phase-plan__phase-desc {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 0.9375rem;
  line-height: 1.7;
  color: #555;
  margin: 0;
}

.pf-phase-plan__footer {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 0.9375rem;
  font-style: italic;
  line-height: 1.7;
  color: #666;
  text-align: center;
  margin: 2.5rem 0 0;
  padding-top: 2rem;
  border-top: 1px solid #E8E6E3;
}
{% endstylesheet %}

{% schema %}
{
  "name": "PF - Phase Plan",
  "tag": "section",
  "class": "pf-section",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "The Process"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "The four phase plan to relieve your dog's allergies"
    },
    {
      "type": "text",
      "id": "subheadline",
      "label": "Subheadline",
      "default": "Or your money back."
    },
    {
      "type": "textarea",
      "id": "footer_text",
      "label": "Footer text"
    }
  ],
  "blocks": [
    {
      "type": "phase",
      "name": "Phase",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "01"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Phase One: Foundation"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "During the initial phase, the chews work to calm inflammation and ease overall discomfort, providing relief from itching and scratching."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PF - Phase Plan",
      "category": "t:categories.pawfy_editorial",
      "blocks": [
        { "type": "phase", "settings": { "number": "01", "title": "Phase One: Foundation", "description": "During the initial phase, the chews work to calm inflammation and ease overall discomfort." } },
        { "type": "phase", "settings": { "number": "02", "title": "Phase Two: Gut Balance", "description": "Good bacteria populate the gut microbiome, supporting your dog's immune defenses." } },
        { "type": "phase", "settings": { "number": "03", "title": "Phase Three: Restoration", "description": "In the final phase, your dog's system has had time to revert to normal function." } },
        { "type": "phase", "settings": { "number": "04", "title": "Phase Four: Maintenance", "description": "Continued use keeps your dog's allergy symptoms at bay for good." } }
      ]
    }
  ]
}
{% endschema %}
