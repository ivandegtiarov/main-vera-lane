<div class="vl-product-hero" style="
  --hero-bg: {{ section.settings.image_bg_color }};
  --content-bg: {{ section.settings.content_bg_color }};
  --title-color: {{ section.settings.title_color }};
  --price-color: {{ section.settings.price_color }};
  --original-price-color: {{ section.settings.original_price_color }};
  --benefit-color: {{ section.settings.benefit_color }};
  --checkmark-color: {{ section.settings.checkmark_color }};
  --cta-bg: {{ section.settings.cta_bg_color }};
  --cta-text: {{ section.settings.cta_text_color }};
  --cta-icon-bg: {{ section.settings.cta_icon_bg_color }};
">
  <div class="vl-product-hero__inner">
    <!-- Image Carousel -->
    <div class="vl-product-hero__carousel">
      <div class="vl-product-hero__slides" data-slides>
        {% assign images = section.blocks | where: "type", "image" %}
        {% for block in images %}
          <div class="vl-product-hero__slide {% if forloop.first %}is-active{% endif %}" data-slide="{{ forloop.index0 }}">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.image_alt | default: section.settings.product_title }}"
                class="vl-product-hero__image"
                width="402"
                height="auto"
                loading="eager"
              >
            {% else %}
              <div class="vl-product-hero__placeholder">
                {{ 'product-1' | placeholder_svg_tag: 'vl-product-hero__placeholder-svg' }}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </div>

      {% if images.size > 1 %}
        <button class="vl-product-hero__arrow vl-product-hero__arrow--prev" data-arrow="prev" aria-label="Previous image">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="15 18 9 12 15 6"></polyline>
          </svg>
        </button>
        <button class="vl-product-hero__arrow vl-product-hero__arrow--next" data-arrow="next" aria-label="Next image">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="9 18 15 12 9 6"></polyline>
          </svg>
        </button>
      {% endif %}
    </div>

    <!-- Product Info -->
    <div class="vl-product-hero__content">
      <!-- Rating -->
      {% if section.settings.show_rating %}
        <div class="vl-product-hero__rating">
          <div class="vl-product-hero__stars">
            {% for i in (1..5) %}
              {% if i <= section.settings.rating_stars %}
                <svg class="vl-product-hero__star vl-product-hero__star--filled" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% else %}
                <svg class="vl-product-hero__star" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% endif %}
            {% endfor %}
          </div>
          <span class="vl-product-hero__rating-text">{{ section.settings.rating_text }}</span>
        </div>
      {% endif %}

      <!-- Title -->
      <h1 class="vl-product-hero__title">{{ section.settings.product_title }}</h1>

      <!-- Price -->
      <div class="vl-product-hero__price">
        {% if section.settings.original_price != blank %}
          <span class="vl-product-hero__price-original">{{ section.settings.original_price }}</span>
        {% endif %}
        <span class="vl-product-hero__price-current">{{ section.settings.current_price }}</span>
        {% if section.settings.discount_badge != blank %}
          <span class="vl-product-hero__discount-badge">{{ section.settings.discount_badge }}</span>
        {% endif %}
      </div>

      <!-- Benefits -->
      <ul class="vl-product-hero__benefits">
        {% assign benefits = section.blocks | where: "type", "benefit" %}
        {% for block in benefits %}
          <li class="vl-product-hero__benefit">
            <svg class="vl-product-hero__check" width="20" height="20" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" fill="currentColor"/>
              <path d="M8 12l2.5 2.5L16 9" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{{ block.settings.text }}</span>
          </li>
        {% endfor %}
      </ul>

      <!-- CTA Button -->
      <a href="{{ section.settings.cta_url }}" class="vl-product-hero__cta" target="_blank" rel="noopener">
        {% if section.settings.cta_icon != blank %}
          <span class="vl-product-hero__cta-icon">
            <img src="{{ section.settings.cta_icon | image_url: width: 80 }}" alt="" width="40" height="40">
          </span>
        {% elsif section.settings.show_amazon_icon %}
          <span class="vl-product-hero__cta-icon vl-product-hero__cta-icon--amazon">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M13.958 10.09c0 1.232.029 2.256-.591 3.351-.502.891-1.301 1.438-2.186 1.438-1.214 0-1.922-.924-1.922-2.292 0-2.692 2.415-3.182 4.7-3.182v.685zm3.186 7.705c-.209.189-.512.201-.745.074-1.052-.872-1.238-1.276-1.814-2.106-1.734 1.767-2.962 2.297-5.209 2.297-2.66 0-4.731-1.641-4.731-4.925 0-2.565 1.391-4.309 3.37-5.164 1.715-.754 4.11-.891 5.942-1.095v-.41c0-.753.06-1.642-.383-2.294-.385-.579-1.124-.82-1.775-.82-1.205 0-2.277.618-2.54 1.897-.054.285-.261.567-.549.582l-3.061-.333c-.259-.056-.548-.266-.472-.66.704-3.716 4.06-4.838 7.066-4.838 1.537 0 3.547.41 4.758 1.574 1.538 1.436 1.392 3.352 1.392 5.438v4.923c0 1.481.616 2.13 1.192 2.929.204.287.249.63-.01.839-.647.541-1.794 1.537-2.423 2.099l-.008-.007z"/>
            </svg>
          </span>
        {% endif %}
        <span class="vl-product-hero__cta-text">{{ section.settings.cta_text }}</span>
      </a>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const hero = document.querySelector('.vl-product-hero');
    if (!hero) return;

    const carousel = hero.querySelector('.vl-product-hero__carousel');
    const slides = hero.querySelectorAll('[data-slide]');
    const prevBtn = hero.querySelector('[data-arrow="prev"]');
    const nextBtn = hero.querySelector('[data-arrow="next"]');

    if (slides.length <= 1) return;

    let currentSlide = 0;
    let touchStartX = 0;
    let touchEndX = 0;

    function goToSlide(index) {
      // Loop around
      if (index < 0) index = slides.length - 1;
      if (index >= slides.length) index = 0;

      slides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === index);
      });
      currentSlide = index;
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', (e) => {
        e.preventDefault();
        goToSlide(currentSlide - 1);
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', (e) => {
        e.preventDefault();
        goToSlide(currentSlide + 1);
      });
    }

    // Touch swipe support
    carousel.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    carousel.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      handleSwipe();
    }, { passive: true });

    function handleSwipe() {
      const swipeThreshold = 50;
      const diff = touchStartX - touchEndX;

      if (Math.abs(diff) > swipeThreshold) {
        if (diff > 0) {
          goToSlide(currentSlide + 1);
        } else {
          goToSlide(currentSlide - 1);
        }
      }
    }
  });
</script>

{% stylesheet %}
  .vl-product-hero {
    background-color: var(--content-bg, #ffffff);
  }

  .vl-product-hero__inner {
    max-width: 402px;
    margin: 0 auto;
  }

  /* Carousel */
  .vl-product-hero__carousel {
    position: relative;
    background-color: var(--hero-bg, #D4C4B5);
  }

  .vl-product-hero__slides {
    position: relative;
    overflow: hidden;
  }

  .vl-product-hero__slide {
    display: none;
  }

  .vl-product-hero__slide.is-active {
    display: block;
  }

  .vl-product-hero__image {
    width: 100%;
    height: auto;
    display: block;
  }

  .vl-product-hero__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: var(--hero-bg, #D4C4B5);
  }

  .vl-product-hero__placeholder-svg {
    width: 60%;
    height: auto;
    opacity: 0.5;
  }

  .vl-product-hero__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.9);
    border: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
    transition: all 0.2s ease;
    z-index: 10;
    color: #333;
  }

  .vl-product-hero__arrow:hover {
    background-color: #ffffff;
  }

  .vl-product-hero__arrow--prev {
    left: 12px;
  }

  .vl-product-hero__arrow--next {
    right: 12px;
  }

  /* Content */
  .vl-product-hero__content {
    padding: 20px 16px 32px;
  }

  /* Rating */
  .vl-product-hero__rating {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 12px;
  }

  .vl-product-hero__stars {
    display: flex;
    gap: 2px;
  }

  .vl-product-hero__star {
    color: #CCCCCC;
  }

  .vl-product-hero__star--filled {
    color: #000000;
  }

  .vl-product-hero__rating-text {
    font-size: 12px;
    color: #666666;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  /* Title */
  .vl-product-hero__title {
    font-family: var(--font-heading--family, serif);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.2;
    color: var(--title-color, #000000);
    margin: 0 0 12px;
    text-transform: uppercase;
  }

  /* Price */
  .vl-product-hero__price {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }

  .vl-product-hero__price-original {
    font-size: 18px;
    color: var(--original-price-color, #999999);
    text-decoration: line-through;
  }

  .vl-product-hero__price-current {
    font-size: 22px;
    font-weight: 600;
    color: var(--price-color, #2A7D4F);
  }

  .vl-product-hero__discount-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background-color: #E53935;
    color: #ffffff;
    font-size: 12px;
    font-weight: 700;
    padding: 4px 10px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }

  /* Benefits */
  .vl-product-hero__benefits {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .vl-product-hero__benefit {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 15px;
    line-height: 1.4;
    color: var(--benefit-color, #333333);
  }

  .vl-product-hero__check {
    flex-shrink: 0;
    color: var(--checkmark-color, #2A7D4F);
    margin-top: 1px;
  }

  /* CTA Button */
  .vl-product-hero__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 14px 24px;
    background-color: var(--cta-bg, #F7A81B);
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s ease;
    gap: 0;
  }

  .vl-product-hero__cta:hover {
    opacity: 0.9;
  }

  .vl-product-hero__cta-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: var(--cta-icon-bg, #ffffff);
    border-radius: 6px;
    margin-right: 0;
    position: absolute;
    left: 16px;
  }

  .vl-product-hero__cta-icon img {
    width: 28px;
    height: 28px;
    object-fit: contain;
  }

  .vl-product-hero__cta-icon--amazon {
    background-color: #232F3E;
    color: #ffffff;
  }

  .vl-product-hero__cta {
    position: relative;
  }

  .vl-product-hero__cta-text {
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--cta-text, #000000);
  }
{% endstylesheet %}

