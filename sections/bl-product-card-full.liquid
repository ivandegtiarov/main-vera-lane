{%- comment -%} ── BL - PRODUCT CARD FULL ── {%- endcomment -%}
<div class="bl-card-full" {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %} style="--full-bg: {{ section.settings.bg_color }}; --image-width-mobile: {{ section.settings.image_width_mobile }}%; --image-width-desktop: {{ section.settings.image_width_desktop }}%;">
  <div class="bl-card-full__container">
    {%- if section.settings.badge_text != blank -%}
      <span class="bl-card-full__badge" style="--badge-bg: {{ section.settings.badge_bg }};">{{ section.settings.badge_text }}</span>
    {%- endif -%}

    <h2 class="bl-card-full__title">{{ section.settings.product_name }}</h2>

    {%- if section.settings.subtitle != blank -%}
      <p class="bl-card-full__subtitle">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- if section.settings.image != blank -%}
      <figure class="bl-card-full__media">
        <img
          src="{{ section.settings.image | image_url: width: 800 }}"
          alt="{{ section.settings.image.alt | default: section.settings.product_name | escape }}"
          class="bl-card-full__image"
          loading="lazy"
        >
      </figure>
    {%- endif -%}

    {%- if section.settings.description != blank -%}
      <div class="bl-card-full__desc">{{ section.settings.description }}</div>
    {%- endif -%}

    {%- if section.settings.show_price -%}
      <div class="bl-card-full__pricing">
        {%- if section.settings.compare_price != blank -%}
          <span class="bl-card-full__compare-price">{{ section.settings.compare_price }}</span>
        {%- endif -%}
        <span class="bl-card-full__price">{{ section.settings.price }}</span>
        {%- if section.settings.savings_text != blank -%}
          <span class="bl-card-full__savings">{{ section.settings.savings_text }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- assign trust_blocks = section.blocks | where: 'type', 'trust_badge' -%}
    {%- if trust_blocks.size > 0 -%}
      <div class="bl-card-full__trust">
        {%- for block in trust_blocks -%}
          <div class="bl-card-full__trust-item" {{ block.shopify_attributes }}>
            {%- if block.settings.icon != blank -%}
              <img src="{{ block.settings.icon | image_url: width: 32 }}" alt="" class="bl-card-full__trust-icon" loading="lazy">
            {%- endif -%}
            <span class="bl-card-full__trust-label">{{ block.settings.label }}</span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.cta_text != blank -%}
      <a href="{{ section.settings.cta_url }}" class="bl-card-full__cta" style="--cta-bg: {{ section.settings.cta_bg }}; --cta-text: {{ section.settings.cta_text_color }};">
        {{ section.settings.cta_text }}
      </a>
    {%- endif -%}

    {%- if section.settings.urgency_text != blank -%}
      <p class="bl-card-full__urgency">{{ section.settings.urgency_text }}</p>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
.bl-card-full {
  background: var(--full-bg, #2D2D2D);
  padding: 4rem 2rem;
  text-align: center;
}

.bl-card-full__container {
  max-width: 600px;
  margin: 0 auto;
}

.bl-card-full__badge {
  display: inline-block;
  background: var(--badge-bg, #8B3A3A);
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.625rem;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  padding: 0.375rem 0.875rem;
  margin-bottom: 1.5rem;
}

.bl-card-full__title {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: clamp(1.75rem, 4vw, 2.25rem);
  font-weight: 400;
  line-height: 1.2;
  color: #fff;
  margin: 0 0 0.75rem;
}

.bl-card-full__subtitle {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1rem;
  font-style: italic;
  color: rgba(255, 255, 255, 0.7);
  margin: 0 0 2rem;
}

.bl-card-full__media {
  margin: 0 0 2rem;
}

.bl-card-full__image {
  display: block;
  max-width: var(--image-width-mobile, 100%);
  height: auto;
  border-radius: 2px;
  margin: 0 auto;
}

@media (min-width: 601px) {
  .bl-card-full__image {
    max-width: var(--image-width-desktop, 100%);
  }
}

.bl-card-full__desc {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 0.9375rem;
  line-height: 1.7;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 2rem;
}

.bl-card-full__pricing {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 0.75rem;
  margin-bottom: 1.5rem;
  flex-wrap: wrap;
}

.bl-card-full__compare-price {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 1rem;
  color: rgba(255, 255, 255, 0.5);
  text-decoration: line-through;
}

.bl-card-full__price {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 2rem;
  font-weight: 400;
  color: #fff;
}

.bl-card-full__savings {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.75rem;
  font-weight: 500;
  color: #D4A574;
  letter-spacing: 0.02em;
}

.bl-card-full__trust {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 1.5rem;
  margin-bottom: 2rem;
}

.bl-card-full__trust-item {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.bl-card-full__trust-icon {
  width: 1rem;
  height: 1rem;
  opacity: 0.8;
}

.bl-card-full__trust-label {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: rgba(255, 255, 255, 0.7);
}

.bl-card-full__cta {
  display: block;
  background: var(--cta-bg, #fff);
  color: var(--cta-text, #2D2D2D);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.8125rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 1.125rem 2rem;
  transition: opacity 200ms ease;
}

.bl-card-full__cta:hover {
  opacity: 0.9;
}

.bl-card-full__urgency {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.75rem;
  color: rgba(255, 255, 255, 0.6);
  margin: 1rem 0 0;
}

@media (max-width: 600px) {
  .bl-card-full {
    padding: 3rem 1.5rem;
  }

  .bl-card-full__trust {
    flex-direction: column;
    gap: 0.75rem;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "BL - Product Card Full",
  "tag": "section",
  "class": "bl-section",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "Used for anchor links from other sections",
      "default": "offer"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#2D2D2D"
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "LIMITED TIME OFFER"
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge background",
      "default": "#8B3A3A"
    },
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "text",
      "id": "product_name",
      "label": "Product name",
      "default": "Mature Skin Foundation"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtitle",
      "default": "The foundation that works with your skin"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Product image"
    },
    {
      "type": "range",
      "id": "image_width_mobile",
      "label": "Image width (mobile)",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "image_width_desktop",
      "label": "Image width (desktop)",
      "min": 30,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "header",
      "content": "Pricing"
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show pricing",
      "default": true
    },
    {
      "type": "text",
      "id": "compare_price",
      "label": "Compare at price",
      "default": "$89.00"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Sale price",
      "default": "$49.00"
    },
    {
      "type": "text",
      "id": "savings_text",
      "label": "Savings text",
      "default": "Save 45%"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "Button text",
      "default": "Claim Your Discount"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button URL"
    },
    {
      "type": "color",
      "id": "cta_bg",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Button text color",
      "default": "#2D2D2D"
    },
    {
      "type": "text",
      "id": "urgency_text",
      "label": "Urgency text",
      "info": "Shows below button",
      "default": "Only 47 left at this price"
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust Badge",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon",
          "info": "Small icon (32x32 recommended)"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Free Shipping"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BL - Product Card Full",
      "category": "t:categories.blissy_listicle",
      "blocks": [
        { "type": "trust_badge", "settings": { "label": "Free Shipping" } },
        { "type": "trust_badge", "settings": { "label": "30-Day Returns" } },
        { "type": "trust_badge", "settings": { "label": "Secure Checkout" } }
      ]
    }
  ]
}
{% endschema %}
