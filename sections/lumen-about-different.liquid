  "max_blocks": 3,
  "presets": [
    {
      "name": "Lumen – About different",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Identity Restored",
            "copy": "Vera Lane exists for the woman who has stopped wearing foundation because it started to feel like a betrayal. We believe your makeup should be infrastructure that stays out of the way, not a mask that hides who you are. We design for that moment of self-recognition—formulating products that disappear into your skin so that people notice your glow, not your makeup."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Texture-First Integrity",
            "copy": "We reject the \"anti-aging\" shame of the beauty industry. Instead, we prioritize the physical reality of skin that has changed—skin that is more sensitive and where products often settle into lines. Our \"second skin\" formulas are engineered to float over texture rather than emphasizing it, giving you the invisible confidence of a healthy, \"lit-from-within\" radiance."
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Certainty over Complexity",
            "copy": "We believe your morning routine should give you mental bandwidth back, not take it away. By removing the \"shade guessing game\" and the anxiety of the wrong match, we provide a reliable standard for women who value presence over performance. We create simple, dependable tools that let you get ready in minutes and move through the world with self-respect."
          }
        }
      ]
    }
  ]
}
{% endschema %}