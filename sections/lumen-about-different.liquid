      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "label": "Padding bottom – desktop",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "label": "Padding bottom – mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Typography controls"
    },
    {
      "type": "range",
      "id": "heading_size_desktop",
      "label": "Heading font size – desktop",
      "min": 12,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_size_mobile",
      "label": "Heading font size – mobile",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "card_title_size_desktop",
      "label": "Card title font size – desktop",
      "min": 12,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "card_title_size_mobile",
      "label": "Card title font size – mobile",
      "min": 12,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_copy_size_desktop",
      "label": "Card body text font size – desktop",
      "min": 12,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "card_copy_size_mobile",
