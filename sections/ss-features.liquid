<section class="ss-features" data-section-id="{{ section.id }}">
  <div class="ss-features__container">
    <h2 class="ss-features__title">What Makes Star Story Special</h2>

    <div class="ss-features__grid">
      <!-- Left column -->
      <div class="ss-features__column ss-features__column--left">
        <div class="ss-features__item">
          <div class="ss-features__icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M20 4C15 4 11 8 11 13V17H10C8.9 17 8 17.9 8 19V34C8 35.1 8.9 36 10 36H30C31.1 36 32 35.1 32 34V19C32 17.9 31.1 17 30 17H29V13C29 8 25 4 20 4ZM20 7C23.3 7 26 9.7 26 13V17H14V13C14 9.7 16.7 7 20 7Z" fill="white"/>
              <circle cx="20" cy="26" r="3" fill="#1A3050"/>
            </svg>
          </div>
          <h3 class="ss-features__item-title">Unlock Your Potential</h3>
          <p class="ss-features__item-desc">Access deeper aspects of your personality that you may not be aware of, unlocking untapped potential.</p>
        </div>

        <div class="ss-features__item">
          <div class="ss-features__icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="14" stroke="white" stroke-width="2.5" fill="none"/>
              <path d="M20 8V20L27 27" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="20" cy="20" r="2" fill="white"/>
              <path d="M20 4L18 8H22L20 4Z" fill="white"/>
              <path d="M36 20L32 18V22L36 20Z" fill="white"/>
              <path d="M20 36L22 32H18L20 36Z" fill="white"/>
              <path d="M4 20L8 22V18L4 20Z" fill="white"/>
            </svg>
          </div>
          <h3 class="ss-features__item-title">Guide Your Decisions</h3>
          <p class="ss-features__item-desc">Use insights from your horoscope to enlighten your decision-making in both personal and professional areas.</p>
        </div>
      </div>

      <!-- Center image -->
      <div class="ss-features__center">
        <img
          src="{{ 'ss-features-center.webp' | asset_url }}"
          alt="Star Story product"
          class="ss-features__image"
          loading="lazy"
          width="400"
          height="500"
        >
      </div>

      <!-- Right column -->
      <div class="ss-features__column ss-features__column--right">
        <div class="ss-features__item">
          <div class="ss-features__icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="18" cy="18" r="11" stroke="white" stroke-width="2.5" fill="none"/>
              <line x1="26" y1="26" x2="36" y2="36" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="ss-features__item-title">Discover Yourself</h3>
          <p class="ss-features__item-desc">Dive deep into your character, strengths, and life's path through your astrological birth chart.</p>
        </div>

        <div class="ss-features__item">
          <div class="ss-features__icon">
            <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
              <circle cx="20" cy="20" r="8" fill="white"/>
              <line x1="20" y1="2" x2="20" y2="8" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="20" y1="32" x2="20" y2="38" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="2" y1="20" x2="8" y2="20" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="32" y1="20" x2="38" y2="20" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="7.3" y1="7.3" x2="11.5" y2="11.5" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="28.5" y1="28.5" x2="32.7" y2="32.7" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="7.3" y1="32.7" x2="11.5" y2="28.5" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
              <line x1="28.5" y1="11.5" x2="32.7" y2="7.3" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
            </svg>
          </div>
          <h3 class="ss-features__item-title">Enhance Emotional Wellness</h3>
          <p class="ss-features__item-desc">Gain a better understanding of your emotional triggers and learn strategies for emotional balance.</p>
        </div>
      </div>
    </div>

    <div class="ss-features__cta">
      <a href="#" class="ss-features__button">Add To Cart</a>
    </div>
  </div>
</section>

{% stylesheet %}
.ss-features {
  background-color: #1A3050;
  padding: 80px 20px;
}

.ss-features__container {
  max-width: 1200px;
  margin: 0 auto;
}

.ss-features__title {
  font-family: 'Noto Serif', serif;
  color: #ffffff;
  text-align: center;
  font-size: 36px;
  font-weight: 700;
  margin: 0 0 60px;
}

.ss-features__grid {
  display: flex;
  align-items: center;
  gap: 40px;
}

.ss-features__column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 48px;
}

.ss-features__column--left .ss-features__item {
  text-align: right;
  align-items: flex-end;
}

.ss-features__column--right .ss-features__item {
  text-align: left;
  align-items: flex-start;
}

.ss-features__item {
  display: flex;
  flex-direction: column;
}

.ss-features__center {
  flex: 2;
  display: flex;
  justify-content: center;
  align-items: center;
}

.ss-features__image {
  max-width: 100%;
  height: auto;
  display: block;
}

.ss-features__icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.ss-features__icon svg {
  width: 28px;
  height: 28px;
}

.ss-features__item-title {
  font-family: 'Noto Serif', serif;
  font-size: 18px;
  font-weight: 700;
  color: #ffffff;
  margin: 12px 0 8px;
}

.ss-features__item-desc {
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.6;
  margin: 0;
}

.ss-features__cta {
  text-align: center;
  margin-top: 60px;
}

.ss-features__button {
  display: inline-block;
  background-color: #ffffff;
  color: #1A3050;
  font-family: 'DM Sans', sans-serif;
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  text-decoration: none;
  padding: 14px 40px;
  border-radius: 50px;
  letter-spacing: 1px;
  transition: opacity 0.2s ease;
}

.ss-features__button:hover {
  opacity: 0.9;
}

@media (max-width: 768px) {
  .ss-features {
    padding: 60px 20px;
  }

  .ss-features__title {
    font-size: 28px;
    margin-bottom: 40px;
  }

  .ss-features__grid {
    flex-direction: column;
    gap: 32px;
  }

  .ss-features__center {
    order: -1;
  }

  .ss-features__column--left .ss-features__item,
  .ss-features__column--right .ss-features__item {
    text-align: center;
  }

  .ss-features__column--left .ss-features__icon,
  .ss-features__column--right .ss-features__icon {
    justify-content: center;
  }

  .ss-features__column {
    gap: 32px;
  }

  .ss-features__cta {
    margin-top: 40px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "SS - Features",
  "settings": []
}
{% endschema %}
