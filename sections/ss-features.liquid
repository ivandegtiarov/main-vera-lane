<!-- SS Features — rebuilt from star-story-theme/sections/ws-special.liquid -->
<!-- Settings hardcoded from product.json ws_special_trLnfJ -->
<!-- Note: gen_back_image was shopify://shop_images/Rectangle_2435.png — using a dark gradient fallback -->
<!-- gen_middle_image mapped to ss-features-center.webp -->
<!-- Icon images: Group_230.svg -> ss-icon-discover.svg, Sun_3.svg -> ss-icon-sun.svg, Jar_2.svg -> no exact match (using ss-icon-gift.svg), Group_229.svg -> ss-icon-compass.svg -->

<div class="ws-special-text-shopify-section">
    <h1 style="text-align: center; padding: 20px 20px 0px 20px; color: #fff; margin: 0;">What Makes Star Story Special</h1>
    <div class="ws-special-text-container">
        <div class="ws-special-text-inner">
            <!-- Blocks 3 and 4 (forloop.index >= 3 in original) -->
            <div class="ws-special-text-container-item">
                <img class="ws-special-text-header" src="{{ 'ss-icon-gift.svg' | asset_url }}">
                <div class="ws-special-text-header">Unlock Your Potential</div>
                <div class="ws-special-text-content"><p>Use this book as a key to unlocking the deeper aspects of yourself, discovering untapped potential along the way</p></div>
            </div>
            <div class="ws-special-text-container-item">
                <img class="ws-special-text-header" src="{{ 'ss-icon-compass.svg' | asset_url }}">
                <div class="ws-special-text-header">Guide Your Decisions</div>
                <div class="ws-special-text-content"><p>Let the insights from your horoscope reading enlighten your decision-making, illuminating paths in personal and professional realms.</p></div>
            </div>
        </div>
        <div class="ws-special-text-container-middle-image">
            <img src="{{ 'ss-features-center.webp' | asset_url }}">
        </div>
        <div class="ws-special-text-inner">
            <!-- Blocks 1 and 2 (forloop.index <= 2 in original) -->
            <div class="ws-special-text-container-item">
                <img class="ws-special-text-header" src="{{ 'ss-icon-discover.svg' | asset_url }}">
                <div class="ws-special-text-header">Discover Yourself</div>
                <div class="ws-special-text-content"><p>Dive deep into your character, strengths, and life's path with a book that's uniquely yours, based on your astrological birth chart.</p></div>
            </div>
            <div class="ws-special-text-container-item">
                <img class="ws-special-text-header" src="{{ 'ss-icon-sun.svg' | asset_url }}">
                <div class="ws-special-text-header">Enhance Emotional Wellness</div>
                <div class="ws-special-text-content"><p>Gaining clarity about yourself can significantly improve your emotional well-being, offering peace and answers to inner questions.</p></div>
            </div>
        </div>
    </div>

    <a class="ws-special-btn" href="#product-id">Add To Cart for A$119</a>
</div>

<style>
.ws-special-text-shopify-section {
    background: linear-gradient(135deg, #1a3050 0%, #00354b 50%, #1a3050 100%);
    padding-top: 80px;
    padding-bottom: 80px;
}
.ws-special-text-container {
    display: flex;
    justify-content: center;
    max-width: 1240px;
    margin: 0 auto;
}
.ws-special-text-header {
    color: #fff;
    text-align: center;
    font-feature-settings: 'clig' off, 'liga' off;
    font-family: "DM Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 700;
    line-height: 27px;
    margin-top: 25px;
}
img.ws-special-text-header {
    margin-top: 0;
}
.ws-special-text-content {
    color: #fff;
    font-feature-settings: 'clig' off, 'liga' off;
    font-family: "DM Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px;
    display: flex;
    justify-content: center;
    text-align: center;
    max-width: 270px;
}
.ws-special-text-content p {
    margin-top: 0;
}
.ws-special-text-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
}
.ws-special-text-container-item {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    gap: 10px;
}
.ws-special-text-container-middle-image {
    flex: 2;
    padding: 20px;
    text-align: center;
}
.ws-special-text-container-middle-image img {
    display: block;
    width: 100%;
}
.ws-special-btn {
    border-radius: 50px;
    background: #FFF;
    padding: 12px 20px;
    display: flex;
    width: fit-content;
    color: #0E1311;
    text-align: center;
    font-feature-settings: 'clig' off, 'liga' off;
    font-family: "DM Sans";
    font-size: 14px;
    font-style: normal;
    font-weight: 500;
    line-height: 2;
    letter-spacing: 0.5px;
    text-decoration: unset;
    text-transform: uppercase;
    margin: 50px auto auto;
}
@media screen and (max-width: 990px) {
    .ws-special-text-shopify-section {
        padding-top: 70px;
    }
    .ws-special-text-container {
        flex-direction: column;
    }
    .ws-special-text-container-middle-image {
        order: -1;
    }
}
</style>

