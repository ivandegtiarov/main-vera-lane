{% stylesheet %}
.ss-footer {
  background-color: #1A3050;
  padding: 60px 20px 40px;
}

.ss-footer__inner {
  max-width: 1200px;
  margin: 0 auto;
}

.ss-footer__nav {
  display: flex;
  justify-content: center;
  flex-wrap: wrap;
  gap: 24px 32px;
  margin-bottom: 32px;
}

.ss-footer__nav-link {
  font-family: "DM Sans", sans-serif;
  font-size: 14px;
  color: #fff;
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 1px;
  transition: opacity 0.2s ease;
}

.ss-footer__nav-link:hover {
  opacity: 0.7;
}

.ss-footer__divider {
  width: 100%;
  height: 1px;
  background: rgba(255, 255, 255, 0.2);
  margin: 0 0 32px;
}

.ss-footer__social {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 16px;
  margin-bottom: 32px;
}

.ss-footer__social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  transition: opacity 0.2s ease;
}

.ss-footer__social-link:hover {
  opacity: 0.7;
}

.ss-footer__bottom {
  text-align: center;
}

.ss-footer__copyright {
  font-family: "DM Sans", sans-serif;
  font-size: 12px;
  color: rgba(255, 255, 255, 0.6);
  margin: 0 0 20px;
}

.ss-footer__payments {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8px;
}

.ss-footer__payment-icon {
  display: inline-flex;
}

@media (max-width: 600px) {
  .ss-footer__nav {
    gap: 16px 24px;
    justify-content: center;
  }
}
{% endstylesheet %}

