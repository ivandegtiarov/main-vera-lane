<div class="vl-rich-text" style="
  --section-bg: {{ section.settings.bg_color }};
  --heading-color: {{ section.settings.heading_color }};
  --text-color: {{ section.settings.text_color }};
  --link-color: {{ section.settings.link_color }};
">
  <div class="vl-rich-text__inner">
    {% if section.settings.subheading != blank %}
      <h2 class="vl-rich-text__subheading">{{ section.settings.subheading }}</h2>
    {% endif %}

    <div class="vl-rich-text__content">
      {{ section.settings.content }}
    </div>
  </div>
</div>

{% stylesheet %}
  .vl-rich-text {
    background-color: var(--section-bg, #ffffff);
    padding: 24px 16px;
  }

  .vl-rich-text__inner {
    max-width: 402px;
    margin: 0 auto;
  }

  .vl-rich-text__subheading {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 20px;
    font-weight: 700;
    color: var(--heading-color, #000000);
    margin: 0 0 16px;
    line-height: 1.3;
  }

  .vl-rich-text__content {
    font-size: 15px;
    line-height: 1.7;
    color: var(--text-color, #333333);
  }

  .vl-rich-text__content p {
    margin: 0 0 16px;
  }

  .vl-rich-text__content p:last-child {
    margin-bottom: 0;
  }

  .vl-rich-text__content h3 {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 18px;
    font-weight: 700;
    color: var(--heading-color, #000000);
    margin: 24px 0 12px;
    line-height: 1.3;
  }

  .vl-rich-text__content h4 {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 16px;
    font-weight: 700;
    color: var(--heading-color, #000000);
    margin: 20px 0 10px;
    line-height: 1.3;
  }

  .vl-rich-text__content strong {
    font-weight: 700;
    color: var(--heading-color, #000000);
  }

  .vl-rich-text__content em {
    font-style: italic;
  }

  .vl-rich-text__content a {
    color: var(--link-color, #5C1A33);
    text-decoration: underline;
  }

  .vl-rich-text__content ul,
  .vl-rich-text__content ol {
    margin: 0 0 16px;
    padding-left: 20px;
  }

  .vl-rich-text__content li {
    margin-bottom: 8px;
  }

  .vl-rich-text__content blockquote {
    margin: 20px 0;
    padding-left: 16px;
    border-left: 3px solid var(--link-color, #5C1A33);
    font-style: italic;
    color: var(--text-color, #333333);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "VL Rich Text",
  "tag": "section",
  "class": "vl-rich-text-section",
  "settings": [
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "info": "Optional section heading"
    },
    {
      "type": "richtext",
      "id": "content",
      "label": "Content",
      "default": "<p>Add your editorial content here. This section supports rich text formatting including <strong>bold</strong>, <em>italic</em>, lists, and links.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#5C1A33"
    }
  ],
  "presets": [
    {
      "name": "VL Rich Text"
    }
  ]
}
{% endschema %}
