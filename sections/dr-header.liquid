<div class="dr-header">
  <div class="dr-header__inner">
    <a href="#" class="dr-header__logo">expertbeautyreviews</a>
    <nav class="dr-header__nav">
      <a href="#" class="dr-header__nav-link">Home</a>
      <a href="#" class="dr-header__nav-link">About</a>
    </nav>
  </div>
</div>

{% stylesheet %}
.dr-header {
  position: sticky;
  top: 0;
  z-index: 1000;
  background: #fff;
  border-bottom: 1px solid #e5e5e5;
}

.dr-header__inner {
  max-width: 1000px;
  margin: 0 auto;
  padding: 16px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dr-header__logo {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  font-size: 18px;
  font-weight: 700;
  color: #1a1a1a;
  text-decoration: none;
}

.dr-header__nav {
  display: flex;
  gap: 24px;
}

.dr-header__nav-link {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  font-size: 14px;
  color: #555;
  text-decoration: none;
}

.dr-header__nav-link:hover {
  color: #1a1a1a;
}
{% endstylesheet %}

