<div class="dr-header">
  <div class="dr-header__banner">
    <span class="dr-header__banner-text">This is a review supported site. We may earn commissions. Affiliate Disclosure</span>
  </div>
  <div class="dr-header__bar">
    <div class="dr-header__inner">
      <a href="#" class="dr-header__logo">ExpertBeautyReviews</a>
      <nav class="dr-header__nav">
        <a href="#" class="dr-header__nav-link">Home</a>
        <a href="#" class="dr-header__nav-link">About</a>
      </nav>
    </div>
  </div>
</div>

{% stylesheet %}
.dr-header {
  position: static;
}

.dr-header__banner {
  background: #4CAF50;
  padding: 6px 24px;
  text-align: right;
}

.dr-header__banner-text {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  font-size: 12px;
  color: #fff;
}

.dr-header__bar {
  background: #fff;
  border-bottom: 1px solid #eee;
}

.dr-header__inner {
  max-width: 700px;
  margin: 0 auto;
  padding: 14px 24px;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.dr-header__logo {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  font-size: 18px;
  font-weight: 700;
  color: #333;
  text-decoration: none;
}

.dr-header__nav {
  display: flex;
  gap: 24px;
}

.dr-header__nav-link {
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  font-size: 14px;
  color: #666;
  text-decoration: none;
}
{% endstylesheet %}

{% schema %}
{
  "name": "DR - Header",
  "settings": []
}
{% endschema %}
