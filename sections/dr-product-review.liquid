{% if section.settings.section_id != blank %}
  <div id="{{ section.settings.section_id }}"></div>
{% endif %}

<div class="dr-review">
  {% if section.settings.badge_text != blank %}
    <div class="dr-review__badge {% if section.settings.badge_text contains 'Winner' %}dr-review__badge--gold{% else %}dr-review__badge--blue{% endif %}">
      {{ section.settings.badge_text }}
    </div>
  {% endif %}

  {% if section.settings.product_name != blank %}
    <h2 class="dr-review__product-name">{{ section.settings.product_name }}</h2>
  {% endif %}

  {% if section.settings.brand != blank %}
    <div class="dr-review__brand">{{ section.settings.brand }}</div>
  {% endif %}

  {% if section.settings.rating != blank %}
    <div class="dr-review__rating">
      {% assign rating_float = section.settings.rating | plus: 0.0 %}
      {% assign full_stars = rating_float | floor %}
      {% assign decimal = rating_float | minus: full_stars %}
      {% assign next_star = full_stars | plus: 1 %}
      <span class="dr-review__stars">
        {% for i in (1..5) %}
          {% if i <= full_stars %}&#9733;{% elsif i == next_star and decimal >= 0.5 %}&#9733;{% else %}&#9734;{% endif %}
        {% endfor %}
      </span>
      <span class="dr-review__rating-number">{{ section.settings.rating }}/5</span>
    </div>
  {% endif %}

  {% if section.settings.hero_image != blank %}
    <div class="dr-review__image">
      {{ section.settings.hero_image | image_url: width: 600 | image_tag: loading: 'lazy', class: 'dr-review__img' }}
    </div>
  {% endif %}

  {% if section.settings.sale_text != blank %}
    <div class="dr-review__sale">{{ section.settings.sale_text }}</div>
  {% endif %}

  {% if section.settings.cta_text != blank %}
    <div class="dr-review__cta-wrap">
      <a href="{{ section.settings.cta_url }}" class="dr-review__cta">{{ section.settings.cta_text }}</a>
    </div>
  {% endif %}

  <hr class="dr-review__divider">

  {% assign pros = section.blocks | where: "type", "pro" %}
  {% assign cons = section.blocks | where: "type", "con" %}

  {% if pros.size > 0 %}
    <h3 class="dr-review__heading">What I Love</h3>
    <div class="dr-review__items">
      {% for block in pros %}
        <div class="dr-review__item" {{ block.shopify_attributes }}>
          <span class="dr-review__icon dr-review__icon--pro">&#10003;</span>
          <p class="dr-review__item-text"><strong>{{ block.settings.title }}</strong> {{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {% if cons.size > 0 %}
    <h3 class="dr-review__heading">What could be better</h3>
    <div class="dr-review__items">
      {% for block in cons %}
        <div class="dr-review__item" {{ block.shopify_attributes }}>
          <span class="dr-review__icon dr-review__icon--con">&#10005;</span>
          <p class="dr-review__item-text"><strong>{{ block.settings.title }}</strong> {{ block.settings.description }}</p>
        </div>
      {% endfor %}
    </div>
  {% endif %}

  {% if section.settings.verdict != blank %}
    <h3 class="dr-review__heading">My overall rating</h3>
    <p class="dr-review__verdict">{{ section.settings.verdict }}</p>
  {% endif %}
</div>

{% stylesheet %}
.dr-review {
  background: #fff;
  border: 1px solid #e0e0e0;
  border-radius: 8px;
  max-width: 700px;
  margin: 0 auto 32px;
  padding: 32px;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

.dr-review__badge {
  text-align: center;
  font-size: 16px;
  font-weight: 700;
  margin-bottom: 16px;
}

.dr-review__badge--gold {
  color: #d4a853;
}

.dr-review__badge--blue {
  color: #4A90D9;
}

.dr-review__product-name {
  text-align: center;
  font-size: 20px;
  font-weight: 700;
  color: #222;
  margin: 0 0 4px;
}

.dr-review__brand {
  text-align: center;
  font-size: 14px;
  color: #888;
  margin-bottom: 12px;
}

.dr-review__rating {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  margin-bottom: 16px;
}

.dr-review__stars {
  font-size: 18px;
  color: #d4a853;
  line-height: 1;
}

.dr-review__rating-number {
  font-size: 14px;
  color: #666;
}

.dr-review__image {
  text-align: center;
  margin-bottom: 16px;
}

.dr-review__img {
  max-width: 300px;
  max-height: 250px;
  object-fit: contain;
  width: 100%;
  height: auto;
}

.dr-review__sale {
  text-align: center;
  font-size: 13px;
  color: #666;
  font-style: italic;
  margin-bottom: 16px;
}

.dr-review__cta-wrap {
  margin-bottom: 24px;
}

.dr-review__cta {
  display: block;
  width: 100%;
  background: #4A90D9;
  color: #fff;
  text-align: center;
  font-size: 16px;
  font-weight: 700;
  padding: 14px;
  border-radius: 6px;
  text-decoration: none;
  box-sizing: border-box;
}

.dr-review__cta:hover {
  background: #3a7bc8;
  color: #fff;
}

.dr-review__divider {
  border: none;
  border-top: 1px solid #eee;
  margin: 0 0 24px;
}

.dr-review__heading {
  font-size: 18px;
  font-weight: 700;
  color: #222;
  margin: 0 0 16px;
  text-align: left;
}

.dr-review__items {
  margin-bottom: 24px;
}

.dr-review__item {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  margin-bottom: 16px;
}

.dr-review__item:last-child {
  margin-bottom: 0;
}

.dr-review__icon {
  width: 20px;
  height: 20px;
  min-width: 20px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-size: 12px;
  font-weight: 700;
  line-height: 1;
  margin-top: 3px;
}

.dr-review__icon--pro {
  background: #4CAF50;
}

.dr-review__icon--con {
  background: #f44336;
}

.dr-review__item-text {
  font-size: 15px;
  color: #444;
  line-height: 1.6;
  margin: 0;
}

.dr-review__verdict {
  font-size: 15px;
  color: #444;
  line-height: 1.6;
  text-align: left;
  margin: 0;
}

@media (max-width: 600px) {
  .dr-review {
    padding: 20px 16px;
    margin-bottom: 24px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "DR - Product Review",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section Anchor ID",
      "info": "Used for linking from rankings bar (e.g. product-1)"
    },
    {
      "type": "text",
      "id": "rank_label",
      "label": "Rank",
      "info": "e.g. #1, #2, #3"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge Text",
      "info": "e.g. ★ Winner ★, Runner Up"
    },
    {
      "type": "text",
      "id": "brand",
      "label": "Brand Name"
    },
    {
      "type": "text",
      "id": "product_name",
      "label": "Product Name"
    },
    {
      "type": "text",
      "id": "rating",
      "label": "Rating",
      "info": "Numeric rating out of 5 (e.g. 4.8)"
    },
    {
      "type": "text",
      "id": "price",
      "label": "Price",
      "info": "e.g. $39.99"
    },
    {
      "type": "text",
      "id": "sale_text",
      "label": "Sale Text",
      "info": "e.g. Sale: Get up to 50% off your first kit (expires soon)"
    },
    {
      "type": "textarea",
      "id": "verdict",
      "label": "Verdict",
      "info": "Overall rating paragraph"
    },
    {
      "type": "text",
      "id": "cta_text",
      "label": "CTA Button Text",
      "info": "Leave blank to hide button"
    },
    {
      "type": "url",
