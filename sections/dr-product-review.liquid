      "label": "CTA Button URL"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Product Image"
    }
  ],
  "blocks": [
    {
      "type": "pro",
      "name": "Pro",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    },
    {
      "type": "con",
      "name": "Con",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DR - Product Review"
    }
  ]
}
{% endschema %}
