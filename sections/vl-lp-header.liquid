{%- liquid
  assign logo_width = section.settings.logo_width
  assign logo_width_2x = logo_width | times: 2
  assign logo_width_3x = logo_width | times: 3
-%}
<div class="vl-lp-header" style="
  --header-padding-top: {{ section.settings.padding_top }}px;
  --header-padding-bottom: {{ section.settings.padding_bottom }}px;
  --header-bg-color: {{ section.settings.bg_color }};
">
  <div class="vl-lp-header__inner">
    {% if section.settings.logo != blank %}
      <img
        src="{{ section.settings.logo | image_url: width: logo_width }}"
        srcset="{{ section.settings.logo | image_url: width: logo_width }} 1x, {{ section.settings.logo | image_url: width: logo_width_2x }} 2x, {{ section.settings.logo | image_url: width: logo_width_3x }} 3x"
        alt="{{ shop.name }}"
        class="vl-lp-header__logo"
        width="{{ logo_width }}"
        height="auto"
        loading="eager"
      >
    {% elsif settings.logo != blank %}
      <img
        src="{{ settings.logo | image_url: width: logo_width }}"
        srcset="{{ settings.logo | image_url: width: logo_width }} 1x, {{ settings.logo | image_url: width: logo_width_2x }} 2x, {{ settings.logo | image_url: width: logo_width_3x }} 3x"
        alt="{{ shop.name }}"
        class="vl-lp-header__logo"
        width="{{ logo_width }}"
        height="auto"
        loading="eager"
      >
    {% else %}
      <span class="vl-lp-header__logo-text">{{ shop.name }}</span>
    {% endif %}
  </div>
</div>

{% stylesheet %}
  .vl-lp-header {
    background-color: var(--header-bg-color, #ffffff);
    padding-top: var(--header-padding-top, 16px);
    padding-bottom: var(--header-padding-bottom, 16px);
  }

  .vl-lp-header__inner {
    max-width: 402px;
    margin: 0 auto;
    display: flex;
    justify-content: center;
    align-items: center;
    padding: 0 16px;
  }

  .vl-lp-header__logo {
    display: block;
    height: auto;
  }

  .vl-lp-header__logo-text {
    font-family: var(--font-heading--family, serif);
    font-size: 24px;
    font-weight: 400;
    letter-spacing: 0.2em;
    text-transform: uppercase;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "VL LP Header",
  "tag": "section",
  "class": "vl-lp-header-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo",
      "info": "Leave blank to use theme logo"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width",
      "min": 80,
      "max": 300,
      "step": 10,
      "default": 140,
      "unit": "px"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 16,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "default": 16,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "VL LP Header"
    }
  ]
}
{% endschema %}
