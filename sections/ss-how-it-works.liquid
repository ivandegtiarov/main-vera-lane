<div class="ws-how-works-shopify-section">
    <h1 style="text-align: center; padding: 20px 20px 0px 20px;">How it works</h1>
    <div class="ws-how-works-container">

        <div class="ws-how-works-container-item">
            <div class="ws-how-works-number">1</div>
            <div class="ws-how-works-content"><p><strong>Place your order </strong> <br/>Provide birth details and begin your cosmic journey.</p></div>
        </div>

        <div class="ws-how-works-image text-desktop"><img class="ws-how-works-image-img" src="https://cdn.shopify.com/s/files/1/0883/5606/1457/files/1_13_2.png?v=1721180928"></div>
        <div class="ws-how-works-image text-mobile">
            <svg width="19" height="109" viewBox="0 0 19 109" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="19" height="109" rx="2" fill="#f0ebe1"/>
            </svg>
        </div>

        <div class="ws-how-works-container-item">
            <div class="ws-how-works-number">2</div>
            <div class="ws-how-works-content"><p><strong>Personalized Just for You<br/></strong>Unique, high-quality book crafted for you.</p></div>
        </div>

        <div class="ws-how-works-image text-desktop"><img class="ws-how-works-image-img" src="https://cdn.shopify.com/s/files/1/0883/5606/1457/files/1_13_2.png?v=1721180928"></div>
        <div class="ws-how-works-image text-mobile">
            <svg width="19" height="109" viewBox="0 0 19 109" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="19" height="109" rx="2" fill="#f0ebe1"/>
            </svg>
        </div>

        <div class="ws-how-works-container-item">
            <div class="ws-how-works-number">3</div>
            <div class="ws-how-works-content"><p><strong>Receive your book</strong>  <br/>Book arrives within 7-10 days.</p></div>
        </div>

    </div>
</div>

<style>
.ws-img-text-container-text.text-mobile { display: none; }
.ws-how-works-shopify-section {
    background: #f0ebe1;
    padding-bottom: 40px;
    padding-top: 13px;
}
.ws-how-works-container {
    display: flex;
    justify-content: center;
    max-width: 1240px;
    margin: 0 auto;
}
.ws-how-works-number {
    color: #000;
    font-feature-settings: 'clig' off, 'liga' off;
    font-family: "DM Serif";
    font-size: 50px;
    font-style: normal;
    font-weight: 600;
    display: flex;
    line-height: 40px;
    letter-spacing: 0.5px;
    justify-content: center;
}
.ws-how-works-content {
    color: var(--Black, #000);
    font-feature-settings: 'clig' off, 'liga' off;
    font-family: "DM Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 400;
    line-height: 20px;
    display: flex;
    justify-content: center;
    text-align: center;
    padding-top: 15px;
}
.ws-how-works-container-item {
    width: 100%;
}
.text-mobile {
    display: none;
}
.text-desktop {
    display: block;
}
@media screen and (max-width: 990px) {
    .ws-img-text-container-text.text-mobile { display: block; }
    .text-mobile { display: block; }
    .text-desktop { display: none; }
    .ws-how-works-container {
        flex-direction: column;
    }
    .ws-how-works-image {
        margin: 23px auto;
        max-width: 50%;
        justify-content: center;
        display: flex;
    }
    img.ws-how-works-image-img {
        display: block;
        width: 100%;
    }
    .ws-how-works-container-item {
        width: 100%;
        max-width: 230px;
        margin: 0 auto;
    }
    .ws-how-works-shopify-section h1 {
        padding-bottom: 30px !important;
    }
    .ws-how-works-content p {
        margin-bottom: 0;
        margin-top: 0;
    }
}
</style>

