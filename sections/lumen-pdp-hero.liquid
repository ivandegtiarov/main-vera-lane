                            {% if block.settings.faq_enable_popup and block.settings.faq_popup_content != blank %}
                              <button
                                type="button"
                                class="lumen-pdp-hero__faq-popup-trigger"
                                data-lumen-faq-popup-trigger
                                data-lumen-faq-section-id="{{ section.id }}"
                                data-lumen-faq-block-id="{{ block.id }}"
                                data-lumen-faq-popup-title="{{ block.settings.faq_popup_title | default: block.settings.title | escape }}"
                                aria-haspopup="dialog"
                              >
                                {{ block.settings.faq_popup_trigger_text | default: 'View full list' }}
                              </button>
                            {% endif %}

                            {% if block.settings.faq_show_image and block.settings.faq_image != blank %}
                              <div class="lumen-pdp-hero__faq-image">
                                {{
                                  block.settings.faq_image
                                  | image_url: width: 1200
                                  | image_tag:
                                    loading: 'lazy',
                                    widths: '320, 480, 640, 800, 1000, 1200',
                                    class: 'lumen-pdp-hero__faq-image-img'
