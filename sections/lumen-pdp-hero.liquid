                            </div>
                          </div>
                        </div>
                      </div>
                      {% comment %} Bundle Products List - Show when add_bundle_property or add_vera2_bundle_property is enabled {% endcomment %}
                          {% if block.type == 'bundle' and has_bundle_property and has_bundle_products %}
