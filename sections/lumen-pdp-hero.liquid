                          </svg>
                    </div>
                    <span class="lumen-pdp-hero__rating-text">
                      {{ section.settings.rating_text }}
                    </span>
                </a>
                <h1 class="lumen-pdp-hero__title" x-text="currentTitle">
                  {% if section.settings.custom_title != blank %}
                    {{ section.settings.custom_title }}
                  {% elsif section_product %}
                    {{ section_product.title }}
                  {% else %}
                    {{ 'products.product.title' | t }}
                  {% endif %}
                </h1>
                <div class="lumen-pdp-hero__price-row">
                  <span class="lumen-pdp-hero__price" x-text="formatMoney(currentPrice)">
                    {% if section_product and selected_variant %}
                      {{ selected_variant.price | money }}
                    {% endif %}
                  </span>
                  {% if section.settings.size_text != blank %}
                    <span class="lumen-pdp-hero__size">
                      {{ section.settings.size_text }}
                    </span>
                  {% endif %}
                </div>
            </div>
            
            <!-- Description -->
            {% assign description_blocks = section.blocks | where: 'type', 'description_item' %}
            {% if description_blocks.size > 0 %}
              <div class="lumen-pdp-hero__description">
                  <div class="lumen-pdp-hero__description-accordion">
                    {% for block in description_blocks %}
                      <div class="lumen-pdp-hero__description-item" x-data="{ open: false }" {{ block.shopify_attributes }}>
                          <div class="lumen-pdp-hero__description-header" @click="open = !open">
                              <h3 class="lumen-pdp-hero__description-title">
                                {{ block.settings.title }}
                              </h3>
                              <div class="lumen-pdp-hero__description-icon">
                                  <svg x-show="!open" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                      <path d="M9 1.75V16.25M1.75 9H16.25" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                  </svg>
                                  <svg x-show="open" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                      <path d="M2.25 8.44H15.75" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                                  </svg>
                              </div>
                          </div>
                          <div x-collapse x-show="open" class="lumen-pdp-hero__description-content">
                              <div class="lumen-pdp-hero__description-content-inner">
                                  {{ block.settings.content }}
                              </div>
                          </div>
                      </div>
                    {% endfor %}
                  </div>
              </div>
            {% endif %}
            
            <!-- Bundle/Variant Selection -->
            {% assign bundle_option_blocks = section.blocks | where: 'type', 'bundle_option' %}
            {% assign bundle_blocks = section.blocks | where: 'type', 'bundle' %}
            {% assign all_bundle_blocks = bundle_option_blocks | concat: bundle_blocks %}
            
            {% if all_bundle_blocks.size > 0 and section_product and selected_variant %}
              <div class="lumen-pdp-hero__variants">
                {% for block in section.blocks %}
                  {% if block.type == 'bundle_option' or block.type == 'bundle' %}
                    
                    {% if block.type == 'bundle_option' %}
                      {% comment %} Original bundle_option logic - single product with quantity {% endcomment %}
                      {% assign bundle_quantity = block.settings.quantity | default: 1 %}
                      
                      {% assign unit_price = selected_variant.price %}
                      {% assign compare_price = unit_price | times: bundle_quantity %}
                      
                      {% if block.settings.use_percentage %}
                        {% assign discount_percentage = block.settings.discount_percentage | default: 0 %}
                        {% assign discount_multiplier = 100 | minus: discount_percentage %}
                        {% assign regular_price = compare_price | times: discount_multiplier | divided_by: 100 %}
                      {% else %}
                        {% assign regular_price = compare_price %}
                      {% endif %}
                      
                      {% assign display_image = block.settings.bundle_image %}
                      {% if display_image == blank %}
                        {% assign variant_media = selected_variant.featured_media | default: section_product.featured_media %}
                        {% assign display_image = variant_media %}
                      {% endif %}
                      
                      {% assign display_title = block.settings.bundle_title %}
                      {% if display_title == blank %}
                        {% assign display_title = section_product.title %}
                        {% if bundle_quantity > 1 %}
                          {% assign display_title = display_title | append: ' (' | append: bundle_quantity | append: 'x)' %}
                        {% endif %}
                      {% endif %}
                      
                    {% elsif block.type == 'bundle' %}
                      {% comment %} New bundle logic - uses bundle product for display, adds separate products to cart {% endcomment %}
                      {% assign bundle_product = block.settings.bundle_product %}
                      {% assign product_1 = block.settings.product_1 %}
                      {% assign product_2 = block.settings.product_2 %}
                      {% assign product_3 = block.settings.product_3 %}
                      {% assign product_1_quantity = block.settings.product_1_quantity | default: 1 %}
                      {% assign product_2_quantity = block.settings.product_2_quantity | default: 1 %}
                      {% assign product_3_quantity = block.settings.product_3_quantity | default: 1 %}
                      {% assign add_bundle_property = block.settings.add_bundle_property | default: false %}
                      {% assign add_vera2_bundle_property = block.settings.add_vera2_bundle_property | default: false %}
                      {% assign has_bundle_property = false %}
                      {% if add_bundle_property or add_vera2_bundle_property %}
                        {% assign has_bundle_property = true %}
                      {% endif %}

                      {%- comment -%}
                        Theme editor "product" settings can sometimes surface as a handle string.
                        Resolve handles to product objects so we don't render empty rows.
                      {%- endcomment -%}
                      {% if product_1 != blank and product_1.title == blank %}
                        {% assign product_1_handle = product_1.handle | default: product_1 | handleize %}
                        {% assign product_1 = all_products[product_1_handle] %}
                      {% endif %}
                      {% if product_2 != blank and product_2.title == blank %}
                        {% assign product_2_handle = product_2.handle | default: product_2 | handleize %}
                        {% assign product_2 = all_products[product_2_handle] %}
                      {% endif %}
                      {% if product_3 != blank and product_3.title == blank %}
                        {% assign product_3_handle = product_3.handle | default: product_3 | handleize %}
                        {% assign product_3 = all_products[product_3_handle] %}
                      {% endif %}

                      {% assign has_bundle_products = false %}
                      {% if product_1 != blank and product_1.title != blank %}
                        {% assign has_bundle_products = true %}
                      {% endif %}
                      {% if product_2 != blank and product_2.title != blank %}
                        {% assign has_bundle_products = true %}
                      {% endif %}
                      {% if product_3 != blank and product_3.title != blank %}
                        {% assign has_bundle_products = true %}
                      {% endif %}
                      
                      {% if bundle_product %}
                        {% assign bundle_variant = bundle_product.selected_or_first_available_variant %}
                        {% assign regular_price = bundle_variant.price %}
                        {% assign compare_price = bundle_variant.compare_at_price %}
                        
                        {% assign display_image = block.settings.bundle_image %}
                        {% if display_image == blank and bundle_product.featured_media %}
                          {% assign display_image = bundle_product.featured_media %}
                        {% endif %}
                        
                        {% assign display_title = block.settings.bundle_title %}
                        {% if display_title == blank %}
                          {% assign display_title = bundle_product.title %}
                        {% endif %}
                      {% endif %}
                    {% endif %}
                    
                    {%- comment -%} Liquid doesn't support parentheses in boolean expressions reliably; compute flag explicitly. {%- endcomment -%}
                    {% assign has_pill_badge = false %}
                    {% if block.type == 'bundle' and has_bundle_property and block.settings.show_corner_badge %}
                      {% assign has_pill_badge = true %}
                    {% elsif block.settings.show_badge and block.settings.badge_text != blank %}
                      {% assign has_pill_badge = true %}
                    {% endif %}

                    <div
                      class="lumen-pdp-hero__variant{% if block.type == 'bundle' and has_bundle_property %} lumen-pdp-hero__variant--has-bundle-products{% endif %}{% if block.type == 'bundle' and block.settings.show_amazon_offer %} lumen-pdp-hero__variant--amazon-offer{% endif %}{% if block.type == 'bundle' and block.settings.is_subscription %} lumen-pdp-hero__variant--subscription{% endif %}"
                      :class="{'lumen-pdp-hero__variant--selected': isSelected('{{ block.id }}')}"
                      {% if block.type == 'bundle_option' %}
                        @click="selectBundle('{{ block.id }}', {{ selected_variant.id }}, {{ bundle_quantity }}, 'bundle_option')"
                      {% elsif block.type == 'bundle' %}
                        @click="selectMultiProductBundle('{{ block.id }}', {{ product_1.variants.first.id | default: 0 }}, {{ product_1_quantity }}, {{ product_2.variants.first.id | default: 0 }}, {{ product_2_quantity }}, {{ product_3.variants.first.id | default: 0 }}, {{ product_3_quantity }}, {{ add_bundle_property }}, {{ add_vera2_bundle_property }}, {{ block.settings.is_subscription | default: false }})"
                      {% endif %}
                      {{ block.shopify_attributes }}
                    >
                      <div class="lumen-pdp-hero__variant-content">
                        <div class="lumen-pdp-hero__variant-image">
                          {% if display_image %}
                            {{ display_image | image_url: width: 200 | image_tag: loading: 'lazy', alt: display_title | escape }}
                          {% endif %}
                        </div>
                        <div class="lumen-pdp-hero__variant-info">
                          <div class="lumen-pdp-hero__variant-details">
                            <div class="lumen-pdp-hero__variant-header">
                              <div class="lumen-pdp-hero__variant-header-left">
                                <div class="lumen-pdp-hero__variant-name">
                                  {{ display_title }}
                                  {% if block.type == 'bundle' and block.settings.is_subscription and block.settings.subscription_discount_label != blank %}
                                    <span class="lumen-pdp-hero__subscription-label">({{ block.settings.subscription_discount_label }})</span>
                                  {% endif %}
                                </div>
                              </div>
                              {% if block.type == 'bundle' and block.settings.show_amazon_offer and block.settings.amazon_url != blank %}
                                <div class="lumen-pdp-hero__variant-header-right">
                                  <a href="{{ block.settings.amazon_url }}"
                                     class="lumen-pdp-hero__amazon-button"
                                     target="_blank"
                                     rel="noopener noreferrer"
                                     aria-label="Buy on Amazon">
                                    {% if block.settings.amazon_icon != blank %}
                                      <img src="{{ block.settings.amazon_icon | image_url: width: 40 }}" alt="Amazon" width="24" height="24" loading="lazy">
                                    {% else %}
                                      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" fill="none">
                                        <path d="M20 0C8.954 0 0 8.954 0 20s8.954 20 20 20 20-8.954 20-20S31.046 0 20 0z" fill="#FF9900"/>
                                        <path d="M12 20.5c0-.45.366-.816.816-.816h14.368c.45 0 .816.366.816.816s-.366.816-.816.816H12.816c-.45 0-.816-.366-.816-.816zm7.5-8c0-.45.366-.816.816-.816h1.368c.45 0 .816.366.816.816v8.5h1.5c.45 0 .816.366.816.816s-.366.816-.816.816h-2.684c-.45 0-.816-.366-.816-.816v-8.5h-1.5c-.45 0-.816-.366-.816-.816zm8 11c0-.45.366-.816.816-.816h1.368c.45 0 .816.366.816.816s-.366.816-.816.816H28.316c-.45 0-.816-.366-.816-.816z" fill="#fff"/>
                                      </svg>
                                    {% endif %}
                                    <span>BUY</span>
                                  </a>
                                </div>
                              {% elsif has_pill_badge %}
                                <div class="lumen-pdp-hero__variant-header-right">
                                  {%- comment -%} Badge pill (right side, like screenshot). Corner badge takes priority. {%- endcomment -%}
                                  {% if block.type == 'bundle' and has_bundle_property and block.settings.show_corner_badge %}
                                    <div class="badge-container" style="--badge-bg: {% if block.settings.corner_badge_bg_color != blank %}{{ block.settings.corner_badge_bg_color }}{% else %}#000000{% endif %}; --badge-fg: {% if block.settings.corner_badge_text_color != blank %}{{ block.settings.corner_badge_text_color }}{% else %}#FFFFFF{% endif %};">
                                      <div class="lumen-pdp-hero__variant-pill">
                                        {{ block.settings.corner_badge_text | default: 'MOST POPULAR' }}
                                      </div>
                                    </div>
                                  {% else %}
                                    <div class="badge-container" style="--badge-bg: {% if block.settings.badge_bg_color != blank %}{{ block.settings.badge_bg_color }}{% else %}#000000{% endif %}; --badge-fg: {% if block.settings.badge_text_color != blank %}{{ block.settings.badge_text_color }}{% else %}#FFFFFF{% endif %};">
                                      <div class="lumen-pdp-hero__variant-pill">
                                        {{ block.settings.badge_text }}
                                      </div>
                                    </div>
                                  {% endif %}
                                </div>
                              {% endif %}
                            </div>
                            <div class="lumen-pdp-hero__variant-price-row">
                              <span class="lumen-pdp-hero__variant-price">
                                {{ regular_price | money }}
                              </span>
                              {% if compare_price and compare_price > regular_price %}
                                <span class="lumen-pdp-hero__variant-price-old">
                                  {{ compare_price | money }}
                                </span>
                              {% endif %}
                              {% if block.settings.show_free_delivery_badge and section.settings.free_delivery_text != blank %}
                                <div class="lumen-pdp-hero__variant-badge">
                                  <svg class="lumen-pdp-hero__variant-badge-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 14 14" fill="none">
                                    <path d="M12.25 7C12.25 7.11603 12.2039 7.22731 12.1219 7.30936C12.0398 7.39141 11.9285 7.4375 11.8125 7.4375H7.4375V11.8125C7.4375 11.9285 7.39141 12.0398 7.30936 12.1219C7.22731 12.2039 7.11603 12.25 7 12.25C6.88397 12.25 6.77269 12.2039 6.69064 12.1219C6.60859 12.0398 6.5625 11.9285 6.5625 11.8125V7.4375H2.1875C2.07147 7.4375 1.96019 7.39141 1.87814 7.30936C1.79609 7.22731 1.75 7.11603 1.75 7C1.75 6.88397 1.79609 6.77269 1.87814 6.69064C1.96019 6.60859 2.07147 6.5625 2.1875 6.5625H6.5625V2.1875C6.5625 2.07147 6.60859 1.96019 6.69064 1.87814C6.77269 1.79609 6.88397 1.75 7 1.75C7.11603 1.75 7.22731 1.79609 7.30936 1.87814C7.39141 1.96019 7.4375 2.07147 7.4375 2.1875V6.5625H11.8125C11.9285 6.5625 12.0398 6.60859 12.1219 6.69064C12.2039 6.77269 12.25 6.88397 12.25 7Z" fill="#7A0036"/>
                                  </svg>
                                  <span class="lumen-pdp-hero__variant-badge-text">
                                    {{ section.settings.free_delivery_text }}
