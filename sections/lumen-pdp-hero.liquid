                                    {{ block.settings.button_label | default: section.settings.upsell_button_label | default: 'ADD TO BAG' }}
                                  </span>
                                </button>
                              </add-to-cart-component>
                            {%- endform -%}
                          </product-form-component>
                        </div>
                      </div>
                    {% endif %}
                  {% endfor %}
                </div>
              </div>
            {% endif %}

            {% assign ugc_blocks = section.blocks | where: 'type', 'ugc_video' %}
            {% render 'lumen-ugc-video', mode: 'slider', section: section, ugc_blocks: ugc_blocks %}

            <!-- Accordion Section -->
            <div class="lumen-pdp-hero__accordion">
              {% for block in section.blocks %}
                {% if block.type == 'faq_item' %}
                {%- assign faq_title = block.settings.title | replace: '[threshold]', free_shipping_threshold -%}
                {%- assign faq_content = block.settings.content | replace: '[threshold]', free_shipping_threshold -%}
                <div class="lumen-pdp-hero__accordion-item" x-data="{ open: {{ forloop.first | json }} }" {{ block.shopify_attributes }}>
                    <div class="lumen-pdp-hero__accordion-header" @click="open = !open">
                        <h3 class="lumen-pdp-hero__accordion-title">
                          {{ faq_title }}
                        </h3>
                        <div class="lumen-pdp-hero__accordion-icon">
                            <svg x-show="!open" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M9 1.75V16.25M1.75 9H16.25" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                            <svg x-show="open" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
                                <path d="M2.25 8.44H15.75" stroke="#000000" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
