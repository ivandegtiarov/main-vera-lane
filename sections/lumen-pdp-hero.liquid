                              <div class="lumen-pdp-hero__bundle-products-label">
                                Included in bundle
                              </div>
                              <div class="lumen-pdp-hero__bundle-products-list">
                                {% if product_1 != blank and product_1.title != blank %}
                                  <div class="lumen-pdp-hero__bundle-product-item">
                                    <div class="lumen-pdp-hero__bundle-product-image">
                                      {% if product_1.featured_media %}
                                        {{ product_1.featured_media | image_url: width: 80 | image_tag: loading: 'lazy', alt: product_1.title | escape }}
                                      {% endif %}
                                    </div>
                                    <div class="lumen-pdp-hero__bundle-product-info">
                                      <div class="lumen-pdp-hero__bundle-product-name">{{ product_1.title }}</div>
                                      <div class="lumen-pdp-hero__bundle-product-quantity">X{{ product_1_quantity }}</div>
                                    </div>
                                  </div>
                                {% endif %}
                                {% if product_2 != blank and product_2.title != blank %}
                                  <div class="lumen-pdp-hero__bundle-product-item">
                                    <div class="lumen-pdp-hero__bundle-product-image">
                                      {% if product_2.featured_media %}
                                        {{ product_2.featured_media | image_url: width: 80 | image_tag: loading: 'lazy', alt: product_2.title | escape }}
                                      {% endif %}
                                    </div>
                                    <div class="lumen-pdp-hero__bundle-product-info">
                                      <div class="lumen-pdp-hero__bundle-product-name">{{ product_2.title }}</div>
                                      <div class="lumen-pdp-hero__bundle-product-quantity">X{{ product_2_quantity }}</div>
                                    </div>
                                  </div>
                                {% endif %}
                                {% if product_3 != blank and product_3.title != blank %}
                                  <div class="lumen-pdp-hero__bundle-product-item">
                                    <div class="lumen-pdp-hero__bundle-product-image">
                                      {% if product_3.featured_media %}
                                        {{ product_3.featured_media | image_url: width: 80 | image_tag: loading: 'lazy', alt: product_3.title | escape }}
                                      {% endif %}
                                    </div>
                                    <div class="lumen-pdp-hero__bundle-product-info">
                                      <div class="lumen-pdp-hero__bundle-product-name">{{ product_3.title }}</div>
                                      <div class="lumen-pdp-hero__bundle-product-quantity">X{{ product_3_quantity }}</div>
                                    </div>
                                  </div>
                                {% endif %}
                              </div>
                            </div>
                          {% endif %}
                      {% if block.type == 'bundle' and block.settings.show_amazon_offer and block.settings.amazon_promo_text != blank %}
                        <div class="lumen-pdp-hero__amazon-banner"
                             style="background-color: {{ block.settings.amazon_banner_bg_color | default: '#7A0036' }}; color: {{ block.settings.amazon_banner_text_color | default: '#FFFFFF' }};">
                          {{ block.settings.amazon_promo_text }}
                        </div>
                      {% endif %}
                      {% comment %} Subscription Frequency Selector {% endcomment %}
                      {% if block.type == 'bundle' and block.settings.is_subscription and has_selling_plans and block.settings.show_frequency_selector %}
                        <div class="lumen-pdp-hero__frequency" x-show="isSelected('{{ block.id }}')">
                          <select
                            class="lumen-pdp-hero__frequency-select"
                            x-model="selectedSellingPlanId"
                            @change="updateSellingPlan($event.target.value)"
                          >
                            {% for plan in selling_plans %}
                              <option value="{{ plan.id }}" {% if forloop.first %}selected{% endif %}>
                                {{ plan.name }}
                              </option>
                            {% endfor %}
                          </select>
                          <svg class="lumen-pdp-hero__frequency-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <polyline points="6 9 12 15 18 9"></polyline>
