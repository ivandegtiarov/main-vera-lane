</style>

<div class="lumen-pdp-hero-wrapper"{% if section.settings.section_id != blank %} id="{{ section.settings.section_id }}"{% endif %}>
  <section
    class="lumen-pdp-hero{% if section.settings.enable_animation %} lumen-pdp-hero--animate{% endif %}"
    x-data="lumenPdpHero()"
    data-section-id="{{ section.id }}"
    data-animation-enabled="{{ section.settings.enable_animation }}"
  >
    <!-- Left Part: Media Gallery + Magazine Logos -->
    <div class="lumen-pdp-hero__left">
    {% if section_product %}
      <!-- Image Gallery with Swiper -->
      <div class="lumen-pdp-hero__gallery">
        <!-- Thumbnails Swiper -->
        <div class="swiper lumen-pdp-hero__gallery-thumbs-swiper">
          <div class="swiper-wrapper">
            <template x-for="(image, index) in currentImages" :key="index">
              <div class="swiper-slide">
                <img
                  :src="image.thumb"
                  :alt="image.alt"
                  loading="lazy"
                  width="320"
                  height="320"
                  class="fit--cover"
                >
              </div>
            </template>
          </div>
        </div>

        <!-- Main Swiper -->
        <div class="swiper lumen-pdp-hero__gallery-main-swiper">
          <div class="swiper-wrapper">
            <template x-for="(image, index) in currentImages" :key="index">
              <div class="swiper-slide">
                <img
                  :src="image.url"
                  :alt="image.alt"
                  loading="lazy"
                  width="1200"
                  height="1200"
                  class="fit--cover"
                >
              </div>
            </template>
          </div>
          <!-- Navigation arrows -->
          <div class="swiper-button-next"></div>
          <div class="swiper-button-prev"></div>
        </div>
      </div>
    {% endif %}

    <!-- Magazine Logos -->
    <div class="lumen-pdp-hero__magazine-logos">
      {% for block in section.blocks %}
        {% if block.type == 'magazine_logo' %}
          <div
            class="lumen-pdp-hero__magazine-logo"
            {{ block.shopify_attributes }}
          >
            {% if block.settings.logo_image != blank %}
              <img src="{{ block.settings.logo_image | image_url: width: 200 }}" loading="lazy" alt="{{ block.settings.alt_text | default: 'Magazine logo' }}">
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>

  <!-- Product Content -->
  <div class="lumen-pdp-hero__content">
    <!-- Header: Rating, Title, Price -->
    <div class="lumen-pdp-hero__header">
                <a href="{{ section.settings.rating_link | default: '#reviews' }}" class="lumen-pdp-hero__rating">
                    <div class="lumen-pdp-hero__rating-stars">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 18 18" fill="none">
