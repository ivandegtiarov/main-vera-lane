      <div class="lumen-faq-modal__body" data-lumen-faq-body></div>

      {% for block in section.blocks %}
        {% if block.type == 'faq_item' and block.settings.faq_enable_popup and block.settings.faq_popup_content != blank %}
          <template data-lumen-faq-template="{{ block.id }}">
            {{ block.settings.faq_popup_content }}
