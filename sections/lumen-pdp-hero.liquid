                            data-section-id="{{ section.id }}"
                            data-product-id="{{ upsell_product.id }}"
                            data-product-url="{{ upsell_product.url }}"
                            on:submit="/handleSubmit"
                            data-quantity-default="1"
                          >
                            <div class="sr-only" aria-live="assertive" role="status" aria-atomic="true" ref="liveRegion"></div>
                            {%- form 'product', upsell_product, id: upsell_form_id, data-type: 'add-to-cart-form' -%}
                              <input type="hidden" name="id" ref="variantId" value="{{ upsell_variant.id }}">
                              <input type="hidden" name="quantity" value="1">
                              <add-to-cart-component ref="addToCartButtonContainer" data-add-to-cart-animation="false">
                                <button
                                  type="submit"
                                  name="add"
                                  ref="addToCartButton"
                                  class="lumen-pdp-hero__upsell-button"
                                  data-lumen-upsell-atc
                                  data-lumen-upsell-default-label="{{ block.settings.button_label | default: section.settings.upsell_button_label | default: 'ADD TO BAG' | escape }}"
                                  data-lumen-upsell-adding-label="{{ section.settings.adding_to_cart_label | default: 'ADDING...' | escape }}"
                                  {% unless upsell_variant.available %}disabled{% endunless %}
                                >
