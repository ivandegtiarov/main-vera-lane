            <!-- Add to Bag Button -->
            {% if section_product and selected_variant %}
              {% assign form_id = 'LumenPdpHeroProductForm-' | append: section.id %}
              <product-form-component
                data-section-id="{{ section.id }}"
                data-product-id="{{ section_product.id }}"
                data-product-url="{{ section_product.url }}"
                on:submit="/handleSubmit"
                data-quantity-default="1"
              >
                <div class="sr-only" aria-live="assertive" role="status" aria-atomic="true" ref="liveRegion"></div>
                {%- form 'product', section_product, id: form_id, data-type: 'add-to-cart-form' -%}
                  <input type="hidden" name="id" ref="variantId" x-model="selectedVariantId">
