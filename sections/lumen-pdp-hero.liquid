                {% endif %}
              {% endfor %}
            </div>
        </div>
    </div>
  </section>

  {%- comment -%}
    Render UGC modal OUTSIDE the animated content columns so it isn't constrained by
    transform (which would break position:fixed and cause the modal to appear on the side).
  {%- endcomment -%}
  {% assign ugc_blocks = section.blocks | where: 'type', 'ugc_video' %}
  {% render 'lumen-ugc-video', mode: 'modal', section: section, ugc_blocks: ugc_blocks %}

  {%- comment -%} FAQ popup modal (per FAQ block) {%- endcomment -%}
  <div class="lumen-faq-modal" data-lumen-faq-modal data-lumen-faq-section-id="{{ section.id }}" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="lumen-faq-modal__backdrop" data-lumen-faq-close></div>
    <div class="lumen-faq-modal__panel" role="document">
      <button type="button" class="lumen-faq-modal__close" data-lumen-faq-close aria-label="Close">&times;</button>
      <h3 class="lumen-faq-modal__title" data-lumen-faq-title></h3>
