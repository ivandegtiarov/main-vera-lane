          mask-image: url(data:image/svg+xml,%3Csvg%20width%3D%228%22%20height%3D%228%22%20viewBox%3D%220%200%208%208%22%20fill%3D%22none%22%20xmlns%3D%22http%3A//www.w3.org/2000/svg%22%3E%3Cpath%20d%3D%22M8%200H0V8L8%200Z%22%20fill%3D%22%23000%22/%3E%3C/svg%3E);
          -webkit-mask-repeat: no-repeat;
          /* mask-repeat: no-repeat; */
          -webkit-mask-size: 100% 100%;
          /* mask-size: 100% 100%; */
          /* transform: rotate(90deg); */
          /* filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.12)); */
          /* z-index: 0; */
          pointer-events: none;
