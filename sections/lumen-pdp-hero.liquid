<!-- Swiper CSS -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css">

<!-- Load product form script -->
<script src="{{ 'product-form.js' | asset_url }}" type="module"></script>

<!-- Alpine.js Component Registration -->
<script>
  // Utility function for money formatting
  const formatMoney = (cents) => (cents / 100).toLocaleString('{{ request.locale.iso_code }}', {
    style: 'currency',
    currency: '{{ cart.currency.iso_code }}'
  });

  function lumenPdpHero() {
    return {
      // Store the selected bundle block ID, variant ID, and quantity
      selectedBundleId: null,
      selectedVariantId: {{ selected_variant.id | default: section_product.variants.first.id }},
      selectedQuantity: 1,
      isLoading: false,
      bundleType: 'bundle_option', // 'bundle_option' or 'bundle'
      // For multi-product bundles
      product1VariantId: null,
      product1Quantity: 1,
      product2VariantId: null,
      product2Quantity: 1,
      product3VariantId: null,
      product3Quantity: 1,
      addBundleProperty: false, // Whether to add bundle property to cart items (vera_bundle)
      addVera2BundleProperty: false, // Whether to add vera2_bundle property to cart items
      // Subscription / Selling Plan
      isSubscription: false,
      selectedSellingPlanId: {% if selling_plans.first %}{{ selling_plans.first.id }}{% else %}null{% endif %},
      // Selling plan prices (for updating price when frequency changes)
      sellingPlanPrices: {
        {% if has_selling_plans %}
          {% for plan in selling_plans %}
            {{ plan.id }}: {
              price: {{ plan.price_adjustments.first.value | default: 0 }},
              adjustmentType: "{{ plan.price_adjustments.first.value_type | default: 'percentage' }}",
              name: "{{ plan.name | escape }}"
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        {% endif %}
      },
      baseProductPrice: {{ selected_variant.price | default: 0 }},
      // Current product images for gallery
      currentImages: [],
      // Bundle images data
      bundleImagesData: {},
      // Current product title and price
      currentTitle: {{ section.settings.custom_title | default: section_product.title | json }},
      currentPrice: {{ selected_variant.price | default: 0 }},
      // Button labels
      addToCartLabel: {{ section.settings.add_to_cart_label | json }},
      addingToCartLabel: {{ section.settings.adding_to_cart_label | json }},
      // Bundle product data
      bundleProductData: {},
      
      init() {
        // Initialize with default product images
        {% if section_product %}
          this.currentImages = [
            {% for media in section_product.media %}
              {% if media.media_type == 'image' %}
                {
                  url: "{{ media | image_url: width: 1200 }}",
                  thumb: "{{ media | image_url: width: 320 }}",
                  alt: "{{ media.alt | escape }}"
                }{% unless forloop.last %},{% endunless %}
              {% endif %}
            {% endfor %}
          ];
        {% endif %}
        
        // Store bundle images and product data
        {% for block in section.blocks %}
          {% if block.type == 'bundle' %}
            {% assign bundle_product = block.settings.bundle_product %}
            {% assign bundle_title = block.settings.bundle_title %}
            {% if bundle_product %}
              {% assign bundle_variant = bundle_product.selected_or_first_available_variant %}
              this.bundleImagesData['{{ block.id }}'] = [
                {% for media in bundle_product.media %}
                  {% if media.media_type == 'image' %}
                    {
                      url: "{{ media | image_url: width: 1200 }}",
                      thumb: "{{ media | image_url: width: 320 }}",
                      alt: "{{ media.alt | escape }}"
                    }{% unless forloop.last %},{% endunless %}
                  {% endif %}
                {% endfor %}
              ];
              this.bundleProductData['{{ block.id }}'] = {
                title: "{% if bundle_title != blank %}{{ bundle_title | escape }}{% else %}{{ bundle_product.title | escape }}{% endif %}",
                price: {{ bundle_variant.price }}
              };
            {% endif %}
          {% endif %}
        {% endfor %}
        
        // Check if user already made a selection (persisted on DOM to survive re-init)
        const persistedBundle = this.$el.getAttribute('data-selected-bundle');
        if (persistedBundle) {
          this.selectedBundleId = persistedBundle;
          if (this.bundleImagesData[persistedBundle]) {
            this.currentImages = this.bundleImagesData[persistedBundle];
          }
          if (this.bundleProductData[persistedBundle]) {
            this.currentTitle = this.bundleProductData[persistedBundle].title;
            this.currentPrice = this.bundleProductData[persistedBundle].price;
          }
          this.$nextTick(() => this.reinitializeGallery());
        } else {
          // Auto-select the first bundle option if available
          {% assign first_bundle_option = section.blocks | where: 'type', 'bundle_option' | first %}
          {% assign first_bundle = section.blocks | where: 'type', 'bundle' | first %}

          {% if first_bundle_option %}
            {% assign first_quantity = first_bundle_option.settings.quantity | default: 1 %}
            this.selectedBundleId = '{{ first_bundle_option.id }}';
            this.selectedVariantId = {{ selected_variant.id }};
            this.selectedQuantity = {{ first_quantity }};
            this.bundleType = 'bundle_option';
          {% elsif first_bundle %}
            {% assign product_1 = first_bundle.settings.product_1 %}
            {% assign product_2 = first_bundle.settings.product_2 %}
            {% assign product_3 = first_bundle.settings.product_3 %}
            {% assign product_1_quantity = first_bundle.settings.product_1_quantity | default: 1 %}
            {% assign product_2_quantity = first_bundle.settings.product_2_quantity | default: 1 %}
            {% assign product_3_quantity = first_bundle.settings.product_3_quantity | default: 1 %}
            {% assign first_bundle_property = first_bundle.settings.add_bundle_property | default: false %}
            {% assign first_vera2_bundle_property = first_bundle.settings.add_vera2_bundle_property | default: false %}
            this.selectedBundleId = '{{ first_bundle.id }}';
            this.bundleType = 'bundle';
            this.product1VariantId = {{ product_1.variants.first.id | default: 0 }};
            this.product1Quantity = {{ product_1_quantity }};
            this.product2VariantId = {{ product_2.variants.first.id | default: 0 }};
            this.product2Quantity = {{ product_2_quantity }};
            this.product3VariantId = {{ product_3.variants.first.id | default: 0 }};
            this.product3Quantity = {{ product_3_quantity }};
            this.addBundleProperty = {{ first_bundle_property }};
            this.addVera2BundleProperty = {{ first_vera2_bundle_property }};
            // Load bundle images, title, and price for first bundle
            if (this.bundleImagesData['{{ first_bundle.id }}']) {
              this.currentImages = this.bundleImagesData['{{ first_bundle.id }}'];
            }
            if (this.bundleProductData['{{ first_bundle.id }}']) {
              this.currentTitle = this.bundleProductData['{{ first_bundle.id }}'].title;
              this.currentPrice = this.bundleProductData['{{ first_bundle.id }}'].price;
            }
            this.$nextTick(() => this.reinitializeGallery());
          {% endif %}
        }
        
        // Listen for cart success/error to reset loading state
        document.addEventListener('cart:updated', () => {
          this.isLoading = false;
        });
        
        document.addEventListener('cart:error', () => {
          this.isLoading = false;
        });
        
        // Reset loading after 3 seconds as fallback
        this.$watch('isLoading', (value) => {
          if (value) {
            setTimeout(() => {
              this.isLoading = false;
            }, 3000);
          }
        });
      },
      
      selectBundle(bundleId, variantId, quantity, type) {
        this.selectedBundleId = bundleId;
        this.$el.setAttribute('data-selected-bundle', bundleId);
        this.selectedVariantId = variantId;
        this.selectedQuantity = quantity;
        this.bundleType = type || 'bundle_option';
        // Bundle option uses main product, so reset to default
        {% if section_product %}
          this.currentImages = [
            {% for media in section_product.media %}
              {% if media.media_type == 'image' %}
                {
                  url: "{{ media | image_url: width: 1200 }}",
                  thumb: "{{ media | image_url: width: 320 }}",
                  alt: "{{ media.alt | escape }}"
                }{% unless forloop.last %},{% endunless %}
              {% endif %}
            {% endfor %}
          ];
          this.currentTitle = {{ section.settings.custom_title | default: section_product.title | json }};
          this.currentPrice = {{ selected_variant.price | default: 0 }};
        {% endif %}
        this.$nextTick(() => this.reinitializeGallery());
      },
      
      selectMultiProductBundle(bundleId, product1VariantId, product1Quantity, product2VariantId, product2Quantity, product3VariantId, product3Quantity, addBundleProperty = false, addVera2BundleProperty = false, isSubscription = false) {
        this.selectedBundleId = bundleId;
        this.$el.setAttribute('data-selected-bundle', bundleId);
        this.bundleType = 'bundle';
        this.product1VariantId = product1VariantId;
        this.product1Quantity = product1Quantity;
        this.product2VariantId = product2VariantId;
        this.product2Quantity = product2Quantity;
        this.product3VariantId = product3VariantId;
        this.product3Quantity = product3Quantity;
        this.addBundleProperty = addBundleProperty;
        this.addVera2BundleProperty = addVera2BundleProperty;
        this.isSubscription = isSubscription;

        // Reset selling plan if not a subscription
        if (!isSubscription) {
          this.selectedSellingPlanId = null;
        } else {
          // Set default selling plan and update price
          this.selectedSellingPlanId = {% if selling_plans.first %}{{ selling_plans.first.id }}{% else %}null{% endif %};
          // Update price for the subscription plan
          if (this.selectedSellingPlanId && this.sellingPlanPrices[this.selectedSellingPlanId]) {
            const plan = this.sellingPlanPrices[this.selectedSellingPlanId];
            if (plan.adjustmentType === 'percentage') {
              const discount = plan.price / 100;
              this.currentPrice = Math.round(this.baseProductPrice * (1 - discount));
            } else if (plan.adjustmentType === 'fixed_amount') {
              this.currentPrice = this.baseProductPrice - plan.price;
            } else if (plan.adjustmentType === 'price') {
              this.currentPrice = plan.price;
            }
          }
        }

        // Update gallery images, title, and price for this bundle
        if (this.bundleImagesData[bundleId] && this.bundleImagesData[bundleId].length > 0) {
          this.currentImages = this.bundleImagesData[bundleId];
        }

        if (this.bundleProductData[bundleId]) {
          this.currentTitle = this.bundleProductData[bundleId].title;
          this.currentPrice = this.bundleProductData[bundleId].price;
        }

        this.$nextTick(() => this.reinitializeGallery());
      },

      updateSellingPlan(planId) {
        this.selectedSellingPlanId = parseInt(planId);

        // Update the displayed price based on the selling plan
        const plan = this.sellingPlanPrices[planId];
        if (plan) {
          if (plan.adjustmentType === 'percentage') {
            // Percentage discount
            const discount = plan.price / 100;
            this.currentPrice = Math.round(this.baseProductPrice * (1 - discount));
          } else if (plan.adjustmentType === 'fixed_amount') {
            // Fixed amount discount
            this.currentPrice = this.baseProductPrice - plan.price;
          } else if (plan.adjustmentType === 'price') {
            // Fixed price
            this.currentPrice = plan.price;
          } else {
            // Default to base price
            this.currentPrice = this.baseProductPrice;
          }
        }
      },
      
      reinitializeGallery() {
        // Dispatch event to reinitialize gallery
        document.dispatchEvent(new CustomEvent('lumen:gallery:reinitialize'));
        
        // Also directly reinitialize if Swiper instances exist
        setTimeout(() => {
          if (window.lumenGalleryMain) {
            window.lumenGalleryMain.update();
            window.lumenGalleryMain.slideTo(0);
          }
          if (window.lumenGalleryThumbs) {
            window.lumenGalleryThumbs.update();
            window.lumenGalleryThumbs.slideTo(0);
          }
        }, 100);
      },
      
      isSelected(bundleId) {
        return this.selectedBundleId === bundleId;
      },
      
      handleAddToCart(event) {
        // Only intercept for multi-product bundles
        if (this.bundleType === 'bundle') {
          event.preventDefault();
          this.isLoading = true;
          this.addMultipleProductsToCart();
        } else {
          // For bundle_option, let the normal form submission work
          this.isLoading = true;
        }
      },


      
      async addMultipleProductsToCart() {
        const items = [];
        
        // Determine which bundle property to use (vera2_bundle takes priority)
        const useBundleProperty = this.addVera2BundleProperty || this.addBundleProperty;
        const bundleId = this.addVera2BundleProperty ? "vera2_bundle" : "vera_bundle";
        
        // Generate unique bundle timestamp to keep bundle items separate
        const bundleTimestamp = useBundleProperty ? Date.now().toString() : null;
        
        if (this.product1VariantId && this.product1VariantId !== 0) {
          const item = {
            id: this.product1VariantId,
            quantity: this.product1Quantity
          };
          if (useBundleProperty) {
            item.properties = {
              bundle_id: bundleId,
              bundle_item_index: "1",
              _bundle_key: bundleTimestamp
            };
          }
          // Add selling plan for subscriptions
          if (this.isSubscription && this.selectedSellingPlanId) {
            item.selling_plan = this.selectedSellingPlanId;
          }
          items.push(item);
        }

        if (this.product2VariantId && this.product2VariantId !== 0) {
          const item = {
            id: this.product2VariantId,
            quantity: this.product2Quantity
          };
          if (useBundleProperty) {
            item.properties = {
              bundle_id: bundleId,
              bundle_item_index: "2",
              _bundle_key: bundleTimestamp
            };
          }
          // Add selling plan for subscriptions
          if (this.isSubscription && this.selectedSellingPlanId) {
            item.selling_plan = this.selectedSellingPlanId;
          }
          items.push(item);
        }

        if (this.product3VariantId && this.product3VariantId !== 0) {
          const item = {
            id: this.product3VariantId,
            quantity: this.product3Quantity
          };
          if (useBundleProperty) {
            item.properties = {
              bundle_id: bundleId,
              bundle_item_index: "3",
              _bundle_key: bundleTimestamp
            };
          }
          // Add selling plan for subscriptions
          if (this.isSubscription && this.selectedSellingPlanId) {
            item.selling_plan = this.selectedSellingPlanId;
          }
          items.push(item);
        }
        
        if (items.length === 0) {
          console.error('No valid products to add');
          this.isLoading = false;
          return;
        }
        
        const formData = { items };
        
        try {
          const response = await fetch('/cart/add.js', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json',
            },
            body: JSON.stringify(formData)
          });
          
          if (response.ok) {
            const data = await response.json();

            {% if section.settings.skip_cart_go_to_checkout %}
              // Check if an upsell modal is present on the page
              const upsellOverlay = document.getElementById('vl-upsell-overlay');
              if (upsellOverlay) {
                document.dispatchEvent(new CustomEvent('vl:upsell:show'));
              } else {
                window.location.href = '/checkout';
              }
              return;
            {% endif %}

            // Fetch updated cart state
            const cartResponse = await fetch('/cart.js');
            const cart = await cartResponse.json();

            // Dispatch the proper cart:update event that the cart drawer listens for
            const cartAddEvent = new CustomEvent('cart:update', {
              bubbles: true,
              detail: {
                resource: cart,
                sourceId: '{{ section.id }}',
                data: {
                  didError: false,
                  itemCount: cart.item_count,
                  source: 'bundle-add'
                }
              }
            });
            document.dispatchEvent(cartAddEvent);
            
          } else {
            const errorData = await response.json();
            throw new Error(errorData.description || 'Failed to add bundle to cart');
          }
        } catch (error) {
          console.error('Error adding bundle to cart:', error);
          
          // Dispatch cart error event
          const cartErrorEvent = new CustomEvent('cart:error', {
            bubbles: true,
            detail: {
              sourceId: '{{ section.id }}',
              data: {
                message: error.message || 'Failed to add items to cart',
                description: 'There was an error adding the bundle to your cart.',
                errors: error
              }
            }
          });
          document.dispatchEvent(cartErrorEvent);
          
          alert('Sorry, there was an error adding items to your cart. Please try again.');
        } finally {
          this.isLoading = false;
        }
      }
    };
  }
</script>

<!-- Alpine.js (with collapse plugin) -->
<script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<!-- Swiper JS -->
<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

<script>
  function initLumenGallery() {
    if (typeof Swiper === 'undefined') return;

    // Destroy existing instances if they exist
    if (window.lumenGalleryThumbs) {
      window.lumenGalleryThumbs.destroy(true, true);
    }
    if (window.lumenGalleryMain) {
      window.lumenGalleryMain.destroy(true, true);
    }

    // Initialize thumbnails swiper
    window.lumenGalleryThumbs = new Swiper('.lumen-pdp-hero__gallery-thumbs-swiper', {
      spaceBetween: 16,
      slidesPerView: 'auto',
      freeMode: true,
      watchSlidesProgress: true,
      direction: 'vertical',
      mousewheel: {
        forceToAxis: true,
        sensitivity: 1,
        releaseOnEdges: true,
      },
      breakpoints: {
        0: {
          direction: 'horizontal',
          spaceBetween: 8,
        },
        769: {
          direction: 'vertical',
          spaceBetween: 16,
        }
      }
    });
    
    // Initialize main swiper
    window.lumenGalleryMain = new Swiper('.lumen-pdp-hero__gallery-main-swiper', {
      spaceBetween: 0,
      thumbs: {
        swiper: window.lumenGalleryThumbs,
      },
      loop: false,
      navigation: {
        nextEl: '.lumen-pdp-hero__gallery-main-swiper .swiper-button-next',
        prevEl: '.lumen-pdp-hero__gallery-main-swiper .swiper-button-prev',
      },
      breakpoints: {
        0: {
          spaceBetween: 12,
        },
        769: {
          spaceBetween: 0,
        }
      }
    });
  }

  function initLumenUgc(root) {
    const scope = root || document;
    if (!scope || typeof scope.querySelectorAll !== 'function') return;
    if (typeof Swiper === 'undefined') return;

    const ugcRoots = scope.querySelectorAll('[data-lumen-ugc]');
    if (!ugcRoots || ugcRoots.length === 0) return;

    const closeAllUgcModals = () => {
      document.querySelectorAll('.lumen-ugc-modal.is-open').forEach((modalEl) => {
        modalEl.classList.remove('is-open');
        modalEl.setAttribute('aria-hidden', 'true');
        const videoWrap = modalEl.querySelector('[data-lumen-ugc-video]');
        if (videoWrap) videoWrap.innerHTML = '';
      });
    };

    if (!window.__lumenUgcEscapeBound) {
      window.__lumenUgcEscapeBound = true;
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeAllUgcModals();
      });
    }

    ugcRoots.forEach((ugcRoot) => {
      const swiperEl = ugcRoot.querySelector('[data-lumen-ugc-swiper]');
      const prevEl = ugcRoot.querySelector('[data-lumen-ugc-prev]');
      const nextEl = ugcRoot.querySelector('[data-lumen-ugc-next]');
      const sectionId = ugcRoot.getAttribute('data-lumen-ugc-section-id');
      const modalEl = sectionId ? document.querySelector(`[data-lumen-ugc-modal][data-lumen-ugc-section-id="${sectionId}"]`) : null;
      const modalVideoEl = modalEl ? modalEl.querySelector('[data-lumen-ugc-video]') : null;
      const soundBtn = modalEl ? modalEl.querySelector('[data-lumen-ugc-sound]') : null;
      const progressFillEl = modalEl ? modalEl.querySelector('[data-lumen-ugc-progress-fill]') : null;

      if (!swiperEl || !prevEl || !nextEl || !modalEl || !modalVideoEl || !soundBtn || !progressFillEl) return;

      // Swiper: destroy old instance (theme editor / reinit)
      if (ugcRoot.__lumenUgcSwiper) {
        try { ugcRoot.__lumenUgcSwiper.destroy(true, true); } catch (e) {}
      }

      ugcRoot.__lumenUgcSwiper = new Swiper(swiperEl, {
        slidesPerView: 3,
        spaceBetween: 10,
        navigation: {
          nextEl,
          prevEl,
          disabledClass: 'is-disabled'
        },
        breakpoints: {
          0: { slidesPerView: 3.5, spaceBetween: 10 },
          768: { slidesPerView: 3.5, spaceBetween: 14 },
          1024: { slidesPerView: 3.5, spaceBetween: 18 }
        }
      });

      const closeModal = () => {
        // Cleanup progress listeners
        if (typeof modalEl.__lumenUgcProgressCleanup === 'function') {
          try { modalEl.__lumenUgcProgressCleanup(); } catch (e) {}
          modalEl.__lumenUgcProgressCleanup = null;
        }
        // Stop playback
        const existingVideo = modalVideoEl.querySelector('video');
        if (existingVideo && typeof existingVideo.pause === 'function') {
          try { existingVideo.pause(); } catch (e) {}
        }
        modalEl.classList.remove('is-open');
        modalEl.classList.remove('is-paused');
        modalEl.setAttribute('aria-hidden', 'true');
        modalVideoEl.innerHTML = '';
        progressFillEl.style.width = '0%';
      };

      const openModalWithTemplate = (blockId) => {
        const template = modalEl.querySelector(`[data-lumen-ugc-template="${blockId}"]`);
        if (!template) return;
        modalVideoEl.innerHTML = template.innerHTML;
        const video = modalVideoEl.querySelector('video');
        if (video) {
          // Ensure no native controls
          video.controls = false;
          video.loop = true;
          video.muted = false;
          video.volume = 1;
          soundBtn.classList.remove('is-muted');
          modalEl.classList.remove('is-paused');

          // Reset progress
          progressFillEl.style.width = '0%';

          // Bind progress updates (cleanup previous first)
          if (typeof modalEl.__lumenUgcProgressCleanup === 'function') {
            try { modalEl.__lumenUgcProgressCleanup(); } catch (e) {}
          }
          const updateProgress = () => {
            const d = video.duration;
            const t = video.currentTime;
            if (!d || !isFinite(d) || d <= 0) {
              progressFillEl.style.width = '0%';
              return;
            }
            const pct = Math.max(0, Math.min(100, (t / d) * 100));
            progressFillEl.style.width = pct + '%';
          };
          const syncPausedState = () => {
            modalEl.classList.toggle('is-paused', video.paused);
          };
          const onEnded = () => {
            // With looping, ended may fire briefly; keep UI sane.
            updateProgress();
          };
          video.addEventListener('timeupdate', updateProgress);
          video.addEventListener('durationchange', updateProgress);
          video.addEventListener('loadedmetadata', updateProgress);
          video.addEventListener('ended', onEnded);
          video.addEventListener('pause', syncPausedState);
          video.addEventListener('play', syncPausedState);
          video.addEventListener('playing', syncPausedState);
          modalEl.__lumenUgcProgressCleanup = () => {
            video.removeEventListener('timeupdate', updateProgress);
            video.removeEventListener('durationchange', updateProgress);
            video.removeEventListener('loadedmetadata', updateProgress);
            video.removeEventListener('ended', onEnded);
            video.removeEventListener('pause', syncPausedState);
            video.removeEventListener('play', syncPausedState);
            video.removeEventListener('playing', syncPausedState);
          };

          const playPromise = video.play?.();
          if (playPromise && typeof playPromise.catch === 'function') {
            playPromise.catch(() => {
              // Autoplay-with-sound can be blocked; fallback to muted playback.
              video.muted = true;
              soundBtn.classList.add('is-muted');
              const retry = video.play?.();
              if (retry && typeof retry.catch === 'function') retry.catch(() => {});
            });
          }
        }
        modalEl.classList.add('is-open');
        modalEl.setAttribute('aria-hidden', 'false');
      };

      // Bind slider open handler once per UGC root
      if (!ugcRoot.__lumenUgcBound) {
        ugcRoot.__lumenUgcBound = true;

        ugcRoot.addEventListener('click', (e) => {
          const openBtn = e.target.closest?.('[data-lumen-ugc-open]');
          if (openBtn && ugcRoot.contains(openBtn)) {
            const blockId = openBtn.getAttribute('data-lumen-ugc-block-id');
            if (blockId) openModalWithTemplate(blockId);
            return;
          }
        });
      }

      // Bind modal handlers once per modal element (theme editor can replace DOM)
      if (!modalEl.__lumenUgcModalBound) {
        modalEl.__lumenUgcModalBound = true;

        modalEl.addEventListener('click', (e) => {
          const closeBtn = e.target.closest?.('[data-lumen-ugc-close]');
          if (closeBtn && modalEl.contains(closeBtn)) {
            e.preventDefault();
            closeModal();
            return;
          }

          const pauseOnClick = modalEl.getAttribute('data-lumen-ugc-pause-on-click') === 'true';
          if (pauseOnClick) {
            const videoEl = modalVideoEl.querySelector('video');
            if (videoEl && (e.target === videoEl || e.target.closest?.('[data-lumen-ugc-video]') === modalVideoEl)) {
              if (e.target.closest?.('.lumen-ugc-modal__controls')) return;
              e.preventDefault();
              if (videoEl.paused) {
                const p = videoEl.play?.();
                if (p && typeof p.catch === 'function') p.catch(() => {});
              } else {
                try { videoEl.pause(); } catch (err) {}
              }
              return;
            }
          }

          const closeOnOutside = modalEl.getAttribute('data-lumen-ugc-close-on-outside') === 'true';
          if (!closeOnOutside) return;

          const panelEl = modalEl.querySelector('.lumen-ugc-modal__panel');
          if (!panelEl) return;
          // Close when clicking anywhere outside the panel (backdrop / empty area)
          if (!panelEl.contains(e.target)) {
            e.preventDefault();
            closeModal();
            return;
          }
        });

        const modalSoundBtn = modalEl.querySelector('[data-lumen-ugc-sound]');
        if (modalSoundBtn) {
          modalSoundBtn.addEventListener('click', (e) => {
            e.preventDefault();
            const video = modalVideoEl.querySelector('video');
            if (!video) return;
            video.muted = !video.muted;
            if (!video.muted) video.volume = 1;
            modalSoundBtn.classList.toggle('is-muted', video.muted);
          });
        }
      }
    });
  }

  function initLumenFaqPopups() {
    const closeModal = (modalEl) => {
      if (!modalEl) return;
      modalEl.classList.remove('is-open');
      modalEl.setAttribute('aria-hidden', 'true');
      const bodyEl = modalEl.querySelector('[data-lumen-faq-body]');
      const titleEl = modalEl.querySelector('[data-lumen-faq-title]');
      if (bodyEl) bodyEl.innerHTML = '';
      if (titleEl) titleEl.textContent = '';
      document.documentElement.classList.remove('lumen-faq-modal-open');
      document.body.classList.remove('lumen-faq-modal-open');
    };

    const closeAll = () => {
      document.querySelectorAll('.lumen-faq-modal.is-open').forEach((modalEl) => closeModal(modalEl));
    };

    if (!window.__lumenFaqEscapeBound) {
      window.__lumenFaqEscapeBound = true;
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeAll();
      });
    }

    if (!window.__lumenFaqClickBound) {
      window.__lumenFaqClickBound = true;
      document.addEventListener('click', (e) => {
        const openBtn = e.target.closest?.('[data-lumen-faq-popup-trigger]');
        if (openBtn) {
          e.preventDefault();
          const sectionId = openBtn.getAttribute('data-lumen-faq-section-id');
          const blockId = openBtn.getAttribute('data-lumen-faq-block-id');
          const title = openBtn.getAttribute('data-lumen-faq-popup-title') || '';
          if (!sectionId || !blockId) return;

          const modalEl = document.querySelector(`[data-lumen-faq-modal][data-lumen-faq-section-id="${sectionId}"]`);
          if (!modalEl) return;

          const template = modalEl.querySelector(`[data-lumen-faq-template="${blockId}"]`);
          const bodyEl = modalEl.querySelector('[data-lumen-faq-body]');
          const titleEl = modalEl.querySelector('[data-lumen-faq-title]');
          if (!template || !bodyEl || !titleEl) return;

          titleEl.textContent = title;
          bodyEl.innerHTML = template.innerHTML;
          modalEl.classList.add('is-open');
          modalEl.setAttribute('aria-hidden', 'false');
          document.documentElement.classList.add('lumen-faq-modal-open');
          document.body.classList.add('lumen-faq-modal-open');
          return;
        }

        const closeBtn = e.target.closest?.('[data-lumen-faq-close]');
        if (closeBtn) {
          e.preventDefault();
          const modalEl = closeBtn.closest?.('[data-lumen-faq-modal]');
          closeModal(modalEl);
          return;
        }
      });
    }
  }
  
  document.addEventListener('DOMContentLoaded', function() {
    // Initial gallery setup
    initLumenGallery();
    
    // Listen for gallery reinitialize event
    document.addEventListener('lumen:gallery:reinitialize', function() {
      setTimeout(() => {
        initLumenGallery();
      }, 50);
    });

    // Init UGC within this section
    initLumenUgc(document);

    // Init FAQ popups (global delegated handlers)
    initLumenFaqPopups();

    // Upsell ATC: "ADDING..." state for upsell buttons
    if (!window.__lumenUpsellAtcBound) {
      window.__lumenUpsellAtcBound = true;

      const setUpsellLoading = (btn, isLoading) => {
        if (!btn) return;
        const labelEl = btn.querySelector('.lumen-pdp-hero__upsell-button-label');
        const defaultLabel = btn.getAttribute('data-lumen-upsell-default-label') || (labelEl ? labelEl.textContent : '');
        const addingLabel = btn.getAttribute('data-lumen-upsell-adding-label') || 'ADDING...';

        if (isLoading) {
          btn.setAttribute('data-lumen-upsell-loading', 'true');
          btn.setAttribute('aria-busy', 'true');
          btn.disabled = true;
          if (labelEl) labelEl.textContent = addingLabel;
          btn.setAttribute('data-lumen-upsell-default-label', defaultLabel);
        } else {
          btn.removeAttribute('data-lumen-upsell-loading');
          btn.removeAttribute('aria-busy');
          // Only re-enable if originally available (Shopify will keep disabled for sold out)
          btn.disabled = false;
          if (labelEl) labelEl.textContent = defaultLabel;
        }
      };

      document.addEventListener(
        'submit',
        (e) => {
          const formEl = e.target;
          if (!(formEl instanceof HTMLFormElement)) return;
          const productForm = formEl.closest?.('product-form-component[data-lumen-upsell-form]');
          if (!productForm) return;
          const btn = productForm.querySelector?.('[data-lumen-upsell-atc]');
          if (btn) setUpsellLoading(btn, true);
        },
        true
      );

      const resetAllUpsellButtons = () => {
        document.querySelectorAll('[data-lumen-upsell-atc][data-lumen-upsell-loading="true"]').forEach((btn) => {
          setUpsellLoading(btn, false);
        });
      };

      document.addEventListener('cart:update', resetAllUpsellButtons, { capture: true });
      document.addEventListener('cart:error', resetAllUpsellButtons, { capture: true });
      // Support any legacy/custom event names
      document.addEventListener('cart:updated', resetAllUpsellButtons, { capture: true });
    }
    
    // Fade-in animation on scroll
    const section = document.querySelector('.lumen-pdp-hero');
    if (!section) return;
    
    const animationEnabled = section.getAttribute('data-animation-enabled') === 'true';
    
    if (animationEnabled && 'IntersectionObserver' in window) {
      const animatedElements = section.querySelectorAll('.lumen-pdp-hero__left, .lumen-pdp-hero__content');
      
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -100px 0px',
        threshold: 0.1
      };
      
      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);
      
      animatedElements.forEach(element => {
        observer.observe(element);
      });
    } else if (animationEnabled) {
      // Fallback for browsers without IntersectionObserver
      const animatedElements = section.querySelectorAll('.lumen-pdp-hero__left, .lumen-pdp-hero__content');
      animatedElements.forEach(element => {
        element.classList.add('is-visible');
      });
    }
  });

  // Theme editor: re-init UGC + gallery on section reload
  document.addEventListener('shopify:section:load', function(event) {
    const sectionEl = event.target;
    if (!sectionEl) return;
    if (sectionEl.querySelector('.lumen-pdp-hero')) {
      try { initLumenGallery(); } catch (e) {}
      try { initLumenUgc(sectionEl); } catch (e) {}
      try { initLumenFaqPopups(); } catch (e) {}
    }
  });
</script>

{% schema %}
{
  "name": "⚡ Lumen PDP Hero",
  "class": "lumen-pdp-hero-section",
  "settings": [
