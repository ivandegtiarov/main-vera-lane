{% liquid
  assign section_product = section.settings.product

  if section_product == blank
    assign section_product = product
  endif

  if request.visual_preview_mode and section_product == blank
    assign section_product = collections.all.products.first
  endif

  if section_product
    assign selected_variant = section_product.selected_or_first_available_variant
  endif

  comment
    Selling plans (subscriptions) detection
  endcomment
  assign has_selling_plans = false
  assign selling_plan_group = nil
  assign selling_plans = nil

  if section_product.selling_plan_groups.size > 0
    assign has_selling_plans = true
    assign selling_plan_group = section_product.selling_plan_groups.first
    assign selling_plans = selling_plan_group.selling_plans
  endif

  comment
    Free shipping threshold for dynamic replacement.
    Use [threshold] in text fields to insert this value.
  endcomment
  assign free_shipping_threshold = settings.cart_goal_1_threshold | default: 60 | round
%}

<style>
