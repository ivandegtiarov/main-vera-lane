            width: 100%;
        }

        .lumen-pdp-hero__faq-image-img {
            width: 100%;
            height: auto;
            display: block;
            border-radius: 8px;
        }

        /* FAQ popup modal */
        html.lumen-faq-modal-open,
        body.lumen-faq-modal-open {
            overflow: hidden;
        }

        .lumen-faq-modal {
            position: fixed;
            inset: 0;
            z-index: 9999;
            display: none;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .lumen-faq-modal.is-open {
            display: flex;
        }

        .lumen-faq-modal__backdrop {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.45);
        }

        .lumen-faq-modal__panel {
            position: relative;
            width: 100%;
            max-width: 900px;
            background: #ffffff;
            border-radius: 10px;
            padding: 28px 32px;
            max-height: calc(100vh - 40px);
            overflow: auto;
        }

        .lumen-faq-modal__close {
            position: absolute;
            top: 16px;
            right: 16px;
            width: 36px;
            height: 36px;
            border-radius: 999px;
            border: 0;
            background: transparent;
            cursor: pointer;
            font-size: 24px;
            line-height: 1;
            color: #000000;
        }

        .lumen-faq-modal__title {
            margin: 0 40px 14px 0;
            font-family: 'Montserrat', sans-serif;
            font-weight: 600;
            font-size: 20px;
            line-height: 28px;
            text-transform: uppercase;
            color: #000000;
        }

        .lumen-faq-modal__divider {
            height: 1px;
            width: 100%;
            background: #E1DCD8;
            margin: 10px 0 18px;
        }

        .lumen-faq-modal__body {
            font-family: 'Montserrat', sans-serif;
            font-weight: 400;
            font-size: 14px;
            line-height: 22px;
            color: #000000;
        }

        /* Swiper base - minimal to avoid conflicts */
        .lumen-pdp-hero .swiper {
          /* width: 100%; */
          position: relative;
        }
        
        .lumen-pdp-hero .swiper-slide {
          flex-shrink: 0;
        }
        
        /* Screen reader only */
        .sr-only {
          position: absolute;
          width: 1px;
          height: 1px;
          padding: 0;
          margin: -1px;
          overflow: hidden;
          clip: rect(0, 0, 0, 0);
          white-space: nowrap;
          border-width: 0;
        }
        
        /* PDP Hero Button with hover effect */
        .lumen-pdp-hero__button {
          display: inline-block;
          padding: 16px 32px;
          border-radius: 10rem;
          color: #fff;
          text-transform: uppercase;
          font-size: 1rem;
          letter-spacing: 0.15rem;
          transition: all 0.3s;
          position: relative;
          overflow: hidden;
          z-index: 1;
          border: none;
          cursor: pointer;
          text-decoration: none;
        }
        
        .lumen-pdp-hero__button:after {
          content: '';
          position: absolute;
          bottom: 0;
          left: 0;
          width: 100%;
          height: 100%;
          background-color: #000000;
          border-radius: 10rem;
          z-index: -2;
        }
        
        .lumen-pdp-hero__button:before {
          content: '';
          position: absolute;
          bottom: 0;
          left: 0;
          width: 0%;
          height: 100%;
          background-color: #5A0028;
          transition: all 0.3s;
          border-radius: 10rem;
          z-index: -1;
        }
        
        .lumen-pdp-hero__button:hover {
          color: #fff;
        }
        
        .lumen-pdp-hero__button:hover:before {
          width: 100%;
        }
        
        /* Loading state for button */
        .lumen-pdp-hero__button {
          display: flex;
          align-items: center;
          justify-content: center;
          gap: 8px;
        }
        
        .lumen-pdp-hero__button--loading {
          pointer-events: none;
          opacity: 0.8;
        }
        
        .lumen-pdp-hero__button-spinner {
          display: none;
          width: 16px;
          height: 16px;
          border: 2px solid #ffffff;
          border-radius: 50%;
          border-top-color: transparent;
          animation: lumenSpinner 0.6s linear infinite;
        }
        
        .lumen-pdp-hero__button--loading .lumen-pdp-hero__button-spinner {
          display: block;
        }
        
        @keyframes lumenSpinner {
          to {
            transform: rotate(360deg);
          }
        }
        
        .lumen-pdp-hero__variant-badge--hidden {
          display: none !important;
        }
        
        /* Upsell (below UGC) - neutral styling */
        .lumen-pdp-hero__upsell {
          display: flex;
          flex-direction: column;
          gap: 20px;
          width: 100%;
          padding-top: 8px;
        }

        .lumen-pdp-hero__upsell-heading {
          font-family: 'Montserrat', sans-serif;
          font-weight: 600;
          font-size: 16px;
          line-height: 18px;
          color: #000000;
          text-transform: uppercase;
          letter-spacing: 0.06em;
        }

        .lumen-pdp-hero__upsell-list {
          display: flex;
          flex-direction: column;
          gap: 20px;
          width: 100%;
        }

        .lumen-pdp-hero__upsell-item {
          display: grid;
          grid-template-columns: 80px 1fr;
          gap: 10px;
          align-items: center;
          width: 100%;
        }

        .lumen-pdp-hero__upsell-image {
          /* width: 40px;
          height: 40px; */
          background-color: #F2F2F2;
          border-radius: 6px;
          overflow: hidden;
          display: flex;
          align-items: center;
          justify-content: center;
        }

        .lumen-pdp-hero__upsell-image img {
          width: 100%;
          height: 100%;
          object-fit: contain;
          display: block;
        }

        .lumen-pdp-hero__upsell-content {
          display: flex;
          flex-direction: column;
          gap: 6px;
          min-width: 0;
          width: 100%;
        }

        .lumen-pdp-hero__upsell-title {
          font-family: 'Montserrat', sans-serif;
          font-weight: 600;
          font-size: 14px;
          line-height: 18px;
          color: #000000;
          text-transform: uppercase;
          letter-spacing: 0.08em;
          overflow: hidden;
          text-overflow: ellipsis;
          white-space: nowrap;
        }

        .lumen-pdp-hero__upsell-price {
          font-family: 'Montserrat', sans-serif;
          font-weight: 600;
          font-size: 14px;
          line-height: 18px;
          color: #000000;
        }

        .lumen-pdp-hero__upsell-button {
          width: 100%;
          display: block;
          padding: 8px 12px;
          border-radius: 8px;
          border: 2px solid #000000;
          background: transparent;
          color: #000000;
          font-family: 'Montserrat', sans-serif;
          font-weight: 600;
          font-size: 12px;
          line-height: 18px;
          text-transform: uppercase;
          letter-spacing: 0.12em;
          cursor: pointer;
          transition: background-color 200ms ease, color 200ms ease, transform 200ms ease, border-color 200ms ease;
        }

        @media (hover: hover) and (pointer: fine) {
          .lumen-pdp-hero__upsell-button:not([disabled]):hover {
            background-color: #000000;
            color: #FFFFFF;
            transform: translateY(-1px);
          }
        }

        .lumen-pdp-hero__upsell-button:not([disabled]):active {
          transform: translateY(0);
        }

        .lumen-pdp-hero__upsell-button:focus-visible {
          outline: 2px solid #000000;
          outline-offset: 2px;
        }

        .lumen-pdp-hero__upsell-button[disabled] {
          opacity: 0.5;
          cursor: not-allowed;
        }

        /* Bundle Products List Styles */
        .lumen-pdp-hero__bundle-products {
          padding-top: 7px;
          border-top: 1px solid #E1DCD8;
          width: 100%;
        }
        
        .lumen-pdp-hero__bundle-products-label {
          font-family: 'Montserrat', sans-serif;
          font-weight: 500;
          font-size: 11px;
          line-height: 16px;
          color: #666666;
          margin-bottom: 8px;
          text-transform: uppercase;
          letter-spacing: 0.5px;
        }
        
        .lumen-pdp-hero__bundle-products-list {
          display: flex;
          flex-direction: column;
          gap: 8px;
          width: 100%;
        }
        
        .lumen-pdp-hero__bundle-product-item {
          display: flex;
          flex-direction: row;
          align-items: center;
          gap: 10px;
          width: 100%;
        }
        
        .lumen-pdp-hero__bundle-product-image {
          width: 40px;
          height: 40px;
          flex-shrink: 0;
          background-color: #F5F5F5;
          border-radius: 4px;
          overflow: hidden;
        }
        
        .lumen-pdp-hero__bundle-product-image img {
          width: 100%;
          height: 100%;
          object-fit: cover;
          display: block;
        }
        
        .lumen-pdp-hero__bundle-product-info {
          flex: 1;
          display: flex;
          justify-content: space-between;
          flex-direction: row;
          gap: 2px;
          min-width: 0;
        }
        
        .lumen-pdp-hero__bundle-product-name {
          font-family: 'Montserrat', sans-serif;
          font-weight: 500;
          font-size: 13px;
          line-height: 18px;
          color: #000000;
          overflow: hidden;
          text-overflow: ellipsis;
          white-space: nowrap;
        }
        
        .lumen-pdp-hero__bundle-product-quantity {
          font-family: 'Montserrat', sans-serif;
          font-weight: 400;
          font-size: 11px;
          line-height: 16px;
          color: #666666;
        }

        /* Bundle with Amazon Offer Styling */
        .lumen-pdp-hero__variant--amazon-offer {
          border-color: #7A0036;
          position: relative;
        }

        .lumen-pdp-hero__variant--amazon-offer .lumen-pdp-hero__variant-content {
          gap: 14px;
          align-items: flex-start;
        }

        .lumen-pdp-hero__variant--amazon-offer .lumen-pdp-hero__variant-info {
          flex: 1;
          gap: 0;
        }

        .lumen-pdp-hero__variant--amazon-offer .lumen-pdp-hero__variant-details {
          gap: 6px;
        }

        .lumen-pdp-hero__variant--amazon-offer .lumen-pdp-hero__variant-header {
          align-items: flex-start;
          justify-content: space-between;
          gap: 0;
          margin-bottom: 0;
        }

        .lumen-pdp-hero__variant--amazon-offer .lumen-pdp-hero__variant-header-left {
          padding: 0;
        }

        .lumen-pdp-hero__variant--amazon-offer .lumen-pdp-hero__variant-header-right {
          position: absolute;
          right: 12px;
          top: 12px;
          margin: 0;
        }

        .lumen-pdp-hero__variant--amazon-offer .lumen-pdp-hero__variant-price-row {
          display: flex;
          flex-direction: row;
          gap: 8px;
          margin-top: 4px;
        }

        .lumen-pdp-hero__amazon-button {
          display: inline-flex;
          align-items: center;
          justify-content: center;
          gap: 6px;
          padding: 10px 18px;
          border: 1px solid #000000;
          border-radius: 999px;
          background: #EFEFEF;
          text-decoration: none;
          font-family: 'Montserrat', sans-serif;
          font-weight: 600;
          font-size: 15px;
          color: #000000;
          white-space: nowrap;
          transition: background-color 0.2s, color 0.2s;
          cursor: pointer;
          flex-shrink: 0;
        }

        .lumen-pdp-hero__amazon-button:hover {
          background-color: #7a0036;
          color: #FFFFFF;
        }

        .lumen-pdp-hero__amazon-button svg {
          width: 20px;
          height: 20px;
          flex-shrink: 0;
        }

        .lumen-pdp-hero__amazon-button img {
          width: 20px;
          height: 20px;
          object-fit: contain;
        }

        .lumen-pdp-hero__amazon-banner {
          padding: 3px 14px;
          margin: 0 -12px -12px -12px;
          font-family: 'Montserrat', sans-serif;
          font-weight: 600;
          font-size: 13px;
          line-height: 20px;
          text-align: center;
          letter-spacing: 0.02em;
          width: calc(100% + 24px);
        }

        /* Subscribe & Save Styles */
        .lumen-pdp-hero__variant--subscription {
          border-color: #7A0036;
        }

        .lumen-pdp-hero__subscription-label {
          color: #7A0036;
          font-weight: 600;
        }

        .lumen-pdp-hero__frequency {
          display: none;
          margin-top: 12px;
          position: relative;
        }

        .lumen-pdp-hero__variant--selected .lumen-pdp-hero__frequency {
          display: block;
        }

        .lumen-pdp-hero__frequency-select {
          width: 100%;
          padding: 12px 40px 12px 16px;
          font-size: 14px;
          font-family: 'Montserrat', sans-serif;
          color: #333333;
          background-color: #fff;
          border: 1px solid #e5e5e5;
          border-radius: 6px;
          appearance: none;
          cursor: pointer;
        }

        .lumen-pdp-hero__frequency-select:focus {
          outline: none;
          border-color: #7A0036;
        }

        .lumen-pdp-hero__frequency-arrow {
          position: absolute;
          right: 12px;
          top: 50%;
          transform: translateY(-50%);
          pointer-events: none;
          color: #333333;
        }

        /* Fade-in animation */
        .lumen-pdp-hero--animate .lumen-pdp-hero__left,
        .lumen-pdp-hero--animate .lumen-pdp-hero__content {
          opacity: 0;
          transform: translateY(30px);
          transition: opacity 0.8s ease-out, transform 0.8s ease-out;
        }
        
        .lumen-pdp-hero--animate .lumen-pdp-hero__left.is-visible,
        .lumen-pdp-hero--animate .lumen-pdp-hero__content.is-visible {
          opacity: 1;
          transform: translateY(0);
        }
        
        /* Staggered animation delays */
        .lumen-pdp-hero--animate .lumen-pdp-hero__left {
          transition-delay: 0.1s;
        }
        
        .lumen-pdp-hero--animate .lumen-pdp-hero__content {
          transition-delay: 0.2s;
        }

        /* Mobile styles */
        @media screen and (max-width: 768px) {
            .lumen-pdp-hero {
                flex-direction: column;
                gap: 40px;
                padding: 20px 20px 56px;
            }
            
            .lumen-pdp-hero__left {
                width: 100%;
                gap: 16px;
            }
            
            .lumen-pdp-hero__gallery {
                width: 100%;
                flex-direction: column;
                gap: 16px;
                align-items: flex-start;
                min-height: auto;
            }

            .lumen-pdp-hero__upsell-heading {
              font-size: 14px;
            }
            
            .lumen-pdp-hero__gallery-thumbs-swiper {
                width: 100%;
                order: 2;
                height: auto;
                max-height: none;
                overflow-y: visible;
            }
            
            .lumen-pdp-hero__gallery-thumbs-swiper .swiper-slide {
                width: 59px;
                height: 59px;
                border-radius: 6px;
            }
            
            .lumen-pdp-hero__gallery-main-swiper {
                order: 1;
                min-height: 300px;
            }
            
            .lumen-pdp-hero__gallery-main-swiper .swiper-slide {
                border-radius: 10px;
            }
            
            /* Hide arrows on mobile */
            .lumen-pdp-hero__gallery-main-swiper .swiper-button-next,
            .lumen-pdp-hero__gallery-main-swiper .swiper-button-prev {
                display: none;
            }
            
            .lumen-pdp-hero__content {
                max-width: 100%;
            }
            
            .lumen-pdp-hero__title {
                font-size: 30px;
                line-height: 40px;
            }
            
            .lumen-pdp-hero__variants {
                gap: 10px;
            }
            
            .lumen-pdp-hero__variant {
                padding: 8px;
                border-radius: 8px;
            }
            
            .lumen-pdp-hero__variant-pill {
              padding: 5px 12px;
              font-size: 8px;
              line-height: 12px;
              letter-spacing: 0.06em;
            }

            .badge-container::after {
              right: 0px;
              bottom: -9px;
              width: 9px;
              height: 9px;
            }

            .lumen-pdp-hero__variant-header-left {
              padding-right: 12px;
            }

            .lumen-pdp-hero__variant-header-right {
              margin-top: 10px;
              margin-right: -18px;
            }
            
            .lumen-pdp-hero__variant-price {
                font-size: 14px;
                line-height: 22px;
            }
            
            .lumen-pdp-hero__variant-price-old {
                font-size: 12px;
                line-height: 24px;
            }
            
            .lumen-pdp-hero__payment-methods {
                justify-content: center;
                gap: 6px;
                flex-wrap: wrap;
            }
            
            .lumen-pdp-hero__trust-badges {
                gap: 16px;
                padding: 16px;
            }
            
            .lumen-pdp-hero__trust-badges-row {
                gap: 12px;
            }

            .lumen-pdp-hero__trust-badge {
                flex-direction: column;
                align-items: center;
                justify-content: center;
                gap: 14px;
            }
            
            .lumen-pdp-hero__trust-badge-text {
                font-size: 12px;
                line-height: 18px;
                text-align: center;
            }
            
            .lumen-pdp-hero__magazine-logos {
                padding: 16px 0 0;
                gap: 16px;
            }
            
            .lumen-pdp-hero__magazine-logo img {
                width: 54px;
                height: 17px;
            }
            
            /* Smaller main bundle image and more compact padding on mobile */
            .lumen-pdp-hero__variant--has-bundle-products {
                padding: 8px;
                gap: 12px;
            }
            
            .lumen-pdp-hero__variant--has-bundle-products .lumen-pdp-hero__variant-image {
                /* width: 40px;
                height: 40px; */
            }
            
            .lumen-pdp-hero__variant--has-bundle-products .lumen-pdp-hero__variant-content {
                gap: 10px;
            }
            
            .lumen-pdp-hero__bundle-products {
                padding-top: 5px;
            }
            
            .lumen-pdp-hero__bundle-products-label {
                font-size: 10px;
                line-height: 14px;
                margin-bottom: 8px;
            }
            
            .lumen-pdp-hero__bundle-products-list {
                gap: 6px;
            }
            
            .lumen-pdp-hero__bundle-product-item {
                gap: 8px;
            }
            
            .lumen-pdp-hero__bundle-product-image {
                width: 35px;
