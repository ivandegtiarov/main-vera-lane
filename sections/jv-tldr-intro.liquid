{%- comment -%} ── JV - TLDR INTRO ── {%- endcomment -%}
<div class="jv-tldr-intro" {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}>
  <div class="jv-tldr-intro__container">
    <p class="jv-tldr-intro__text">
      {%- if section.settings.prefix != blank -%}
        <span class="jv-tldr-intro__prefix">{{ section.settings.prefix }}</span>
      {%- endif -%}
      {{ section.settings.intro_text }}
      {%- if section.settings.suffix_icon != blank -%}
        <span class="jv-tldr-intro__icon">{{ section.settings.suffix_icon }}</span>
      {%- endif -%}
    </p>
  </div>
</div>

{% stylesheet %}
.jv-tldr-intro {
  background: #fff;
  padding-block: 1rem 1.5rem;
}

.jv-tldr-intro__container {
  max-width: 680px;
  margin: 0 auto;
  padding-inline: 1.5rem;
}

.jv-tldr-intro__text {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.9375rem;
  line-height: 1.6;
  color: #333;
  margin: 0;
}

.jv-tldr-intro__prefix {
  font-weight: 700;
  color: #1a1a1a;
  margin-right: 0.25rem;
}

.jv-tldr-intro__icon {
  margin-left: 0.25rem;
}
{% endstylesheet %}

{% schema %}
{
  "name": "JV - TLDR Intro",
  "tag": "section",
  "class": "jv-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "For anchor links (e.g., 'intro')"
    },
    {
      "type": "text",
      "id": "prefix",
      "label": "Prefix (e.g., TL;DR:)",
      "default": "TL;DR:"
    },
    {
      "type": "textarea",
      "id": "intro_text",
      "label": "Intro text",
      "default": "Drinking Javvy Protein Coffee has 11+ life changing benefits"
    },
    {
      "type": "text",
      "id": "suffix_icon",
      "label": "Suffix icon (emoji)",
      "default": "👇"
    }
  ],
  "presets": [
    {
      "name": "JV - TLDR Intro",
      "category": "t:categories.reasons_listicle"
    }
  ]
}
{% endschema %}
