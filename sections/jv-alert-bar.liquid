{%- comment -%} ── JV - ALERT BAR ── {%- endcomment -%}
<div class="jv-alert-bar" {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %} style="--alert-bg: {{ section.settings.bg_color }}; --alert-text: {{ section.settings.text_color }};">
  <div class="jv-alert-bar__container">
    {%- if section.settings.badge_text != blank -%}
      <span class="jv-alert-bar__badge">
        {%- if section.settings.badge_icon != blank -%}
          <span class="jv-alert-bar__badge-icon">{{ section.settings.badge_icon }}</span>
        {%- endif -%}
        {{ section.settings.badge_text }}
        {%- if section.settings.badge_icon != blank -%}
          <span class="jv-alert-bar__badge-icon">{{ section.settings.badge_icon }}</span>
        {%- endif -%}
      </span>
    {%- endif -%}

    {%- if section.settings.show_countdown -%}
      <div class="jv-alert-bar__countdown" data-countdown="{{ section.settings.countdown_minutes }}">
        <span class="jv-alert-bar__time" data-hours>00</span>
        <span class="jv-alert-bar__sep">:</span>
        <span class="jv-alert-bar__time" data-minutes>00</span>
        <span class="jv-alert-bar__sep">:</span>
        <span class="jv-alert-bar__time" data-seconds>00</span>
      </div>
    {%- endif -%}

    {%- if section.settings.promo_text != blank -%}
      <span class="jv-alert-bar__promo">{{ section.settings.promo_text }}</span>
    {%- endif -%}
  </div>
</div>

<script>
  (function() {
    const bar = document.querySelector('.jv-alert-bar__countdown');
    if (!bar) return;

    const minutes = parseInt(bar.dataset.countdown) || 120;
    const storageKey = 'jv_countdown_end';

    let endTime = localStorage.getItem(storageKey);
    if (!endTime || parseInt(endTime) < Date.now()) {
      endTime = Date.now() + (minutes * 60 * 1000);
      localStorage.setItem(storageKey, endTime);
    }

    const hoursEl = bar.querySelector('[data-hours]');
    const minsEl = bar.querySelector('[data-minutes]');
    const secsEl = bar.querySelector('[data-seconds]');

    function update() {
      const remaining = Math.max(0, parseInt(endTime) - Date.now());
      const hours = Math.floor(remaining / 3600000);
      const mins = Math.floor((remaining % 3600000) / 60000);
      const secs = Math.floor((remaining % 60000) / 1000);

      hoursEl.textContent = String(hours).padStart(2, '0');
      minsEl.textContent = String(mins).padStart(2, '0');
      secsEl.textContent = String(secs).padStart(2, '0');

      if (remaining <= 0) {
        localStorage.removeItem(storageKey);
      }
    }

    update();
    setInterval(update, 1000);
  })();
</script>

{% stylesheet %}
.jv-alert-bar {
  background: var(--alert-bg, #F5A623);
  color: var(--alert-text, #1a1a1a);
  padding: 0.625rem 1rem;
  position: sticky;
  top: 0;
  z-index: 100;
}

.jv-alert-bar__container {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 1rem;
  flex-wrap: wrap;
}

.jv-alert-bar__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.375rem;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.75rem;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.jv-alert-bar__badge-icon {
  font-size: 0.875rem;
}

.jv-alert-bar__countdown {
  display: flex;
  align-items: center;
  gap: 0.125rem;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-variant-numeric: tabular-nums;
}

.jv-alert-bar__time {
  background: rgba(0, 0, 0, 0.15);
  padding: 0.25rem 0.375rem;
  border-radius: 4px;
  font-size: 0.875rem;
  font-weight: 700;
  min-width: 1.75rem;
  text-align: center;
}

.jv-alert-bar__sep {
  font-weight: 700;
  opacity: 0.7;
}

.jv-alert-bar__promo {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.8125rem;
  font-weight: 600;
}

@media (max-width: 600px) {
  .jv-alert-bar__promo {
    display: none;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "JV - Alert Bar",
  "tag": "section",
  "class": "jv-section",
  "limit": 1,
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "For anchor links (e.g., 'alert')"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#F5A623"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "SPRING SPECIAL"
    },
    {
      "type": "text",
      "id": "badge_icon",
      "label": "Badge icon (emoji)",
      "default": "🌸"
    },
    {
      "type": "header",
      "content": "Countdown"
    },
    {
      "type": "checkbox",
      "id": "show_countdown",
      "label": "Show countdown timer",
      "default": true
    },
    {
      "type": "range",
      "id": "countdown_minutes",
      "label": "Countdown duration (minutes)",
      "min": 30,
      "max": 1440,
      "step": 30,
      "default": 120,
      "info": "Timer persists across page loads"
    },
    {
      "type": "header",
      "content": "Promo Text"
    },
    {
      "type": "text",
      "id": "promo_text",
      "label": "Promo text",
      "default": "UP TO 58% OFF WITH FREE GIFTS"
    }
  ],
  "presets": [
    {
      "name": "JV - Alert Bar",
      "category": "t:categories.reasons_listicle"
    }
  ]
}
{% endschema %}
