<div class="vl-feature-table" style="
  --section-bg: {{ section.settings.bg_color }};
  --heading-color: {{ section.settings.heading_color }};
  --text-color: {{ section.settings.text_color }};
  --check-color: {{ section.settings.check_color }};
  --row-border: {{ section.settings.row_border_color }};
">
  <div class="vl-feature-table__inner">
    {% if section.settings.heading != blank %}
      <h2 class="vl-feature-table__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.subheading != blank %}
      <p class="vl-feature-table__subheading">{{ section.settings.subheading }}</p>
    {% endif %}

    <div class="vl-feature-table__table">
      {% for block in section.blocks %}
        <div class="vl-feature-table__row" {{ block.shopify_attributes }}>
          <span class="vl-feature-table__icon {% if block.settings.has_feature %}vl-feature-table__icon--check{% else %}vl-feature-table__icon--x{% endif %}">
            {% if block.settings.has_feature %}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            {% else %}
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <line x1="18" y1="6" x2="6" y2="18"></line>
                <line x1="6" y1="6" x2="18" y2="18"></line>
              </svg>
            {% endif %}
          </span>
          <span class="vl-feature-table__text">{{ block.settings.feature_text }}</span>
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% stylesheet %}
  .vl-feature-table {
    background-color: var(--section-bg, #ffffff);
    padding: 32px 16px;
  }

  .vl-feature-table__inner {
    max-width: 402px;
    margin: 0 auto;
  }

  .vl-feature-table__heading {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 20px;
    font-weight: 700;
    color: var(--heading-color, #000000);
    text-align: center;
    margin: 0 0 8px;
    line-height: 1.3;
  }

  .vl-feature-table__subheading {
    font-size: 14px;
    color: var(--text-color, #666666);
    text-align: center;
    margin: 0 0 24px;
  }

  .vl-feature-table__table {
    border: 1px solid var(--row-border, #E5E5E5);
    border-radius: 12px;
    overflow: hidden;
  }

  .vl-feature-table__row {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 14px 16px;
    border-bottom: 1px solid var(--row-border, #E5E5E5);
  }

  .vl-feature-table__row:last-child {
    border-bottom: none;
  }

  .vl-feature-table__icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vl-feature-table__icon--check {
    color: var(--check-color, #5C1A33);
  }

  .vl-feature-table__icon--x {
    color: #CCCCCC;
  }

  .vl-feature-table__text {
    font-size: 14px;
    line-height: 1.4;
    color: var(--text-color, #333333);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "VL Feature Table",
  "tag": "section",
  "class": "vl-feature-table-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed Specifically for Mature Skin"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "info": "Optional text below heading"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "check_color",
      "label": "Checkmark color",
      "default": "#5C1A33"
    },
    {
      "type": "color",
      "id": "row_border_color",
      "label": "Row border color",
      "default": "#E5E5E5"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "feature_text",
          "label": "Feature text",
          "default": "Adapts to your unique skin tone"
        },
        {
          "type": "checkbox",
          "id": "has_feature",
          "label": "Has feature (checkmark)",
          "default": true
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VL Feature Table",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "feature_text": "Adapts to your unique skin tone",
            "has_feature": true
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Lightweight, breathable formula",
            "has_feature": true
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "SPF 15 protection",
            "has_feature": true
          }
        },
        {
          "type": "feature",
          "settings": {
            "feature_text": "Dermatologist approved",
            "has_feature": true
          }
        }
      ]
    }
  ]
}
{% endschema %}
