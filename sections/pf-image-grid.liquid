{%- comment -%} ── PF - IMAGE GRID ── {%- endcomment -%}
<section class="pf-image-grid" {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %} style="--pf-grid-bg: {{ section.settings.bg_color }};">
  <div class="pf-image-grid__container">
    {%- if section.settings.headline != blank -%}
      <h2 class="pf-image-grid__headline">{{ section.settings.headline }}</h2>
    {%- endif -%}

    {%- if section.settings.intro_text != blank -%}
      <p class="pf-image-grid__intro">{{ section.settings.intro_text }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="pf-image-grid__grid pf-image-grid__grid--{{ section.blocks.size }}">
        {%- for block in section.blocks -%}
          <figure class="pf-image-grid__item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 400 }}"
                alt="{{ block.settings.image.alt | default: block.settings.label | escape }}"
                class="pf-image-grid__image"
                loading="lazy"
              >
            {%- endif -%}
            {%- if block.settings.label != blank -%}
              <figcaption class="pf-image-grid__label">{{ block.settings.label }}</figcaption>
            {%- endif -%}
          </figure>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.pf-image-grid {
  background: var(--pf-grid-bg, #FAF9F6);
  padding: 3.5rem 1.5rem;
}

.pf-image-grid__container {
  max-width: 800px;
  margin: 0 auto;
}

.pf-image-grid__headline {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: clamp(1.25rem, 3vw, 1.5rem);
  font-weight: 400;
  line-height: 1.3;
  color: #1A1A1A;
  text-align: center;
  margin: 0 0 1rem;
}

.pf-image-grid__intro {
  font-family: Georgia, 'Times New Roman', serif;
  font-size: 1rem;
  font-style: italic;
  line-height: 1.6;
  color: #666;
  text-align: center;
  margin: 0 0 2.5rem;
  max-width: 600px;
  margin-left: auto;
  margin-right: auto;
}

.pf-image-grid__grid {
  display: grid;
  gap: 1.5rem;
}

.pf-image-grid__grid--2 {
  grid-template-columns: repeat(2, 1fr);
}

.pf-image-grid__grid--3 {
  grid-template-columns: repeat(3, 1fr);
}

.pf-image-grid__grid--4 {
  grid-template-columns: repeat(2, 1fr);
}

@media (min-width: 600px) {
  .pf-image-grid__grid--4 {
    grid-template-columns: repeat(4, 1fr);
  }
}

.pf-image-grid__item {
  margin: 0;
  text-align: center;
}

.pf-image-grid__image {
  width: 100%;
  height: auto;
  border: 1px solid #E8E6E3;
  background: #fff;
}

.pf-image-grid__label {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.6875rem;
  font-weight: 500;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #666;
  margin-top: 0.75rem;
}
{% endstylesheet %}

{% schema %}
{
  "name": "PF - Image Grid",
  "tag": "section",
  "class": "pf-section",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#FAF9F6"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Headline",
      "default": "The 60-day solution to your dog's allergy struggles"
    },
    {
      "type": "text",
      "id": "intro_text",
      "label": "Intro text"
    }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "PF - Image Grid",
      "category": "t:categories.pawfy_editorial",
      "blocks": [
        { "type": "image", "settings": { "label": "Week 1-2" } },
        { "type": "image", "settings": { "label": "Week 3-4" } },
        { "type": "image", "settings": { "label": "Week 5-6" } },
        { "type": "image", "settings": { "label": "Week 7-8" } }
      ]
    }
  ]
}
{% endschema %}
