<div class="vl-testimonial-centered" style="
  --section-bg: {{ section.settings.bg_color }};
  --heading-color: {{ section.settings.heading_color }};
  --card-bg: {{ section.settings.card_bg_color }};
  --quote-color: {{ section.settings.quote_color }};
  --star-color: {{ section.settings.star_color }};
">
  <div class="vl-testimonial-centered__inner">
    <h2 class="vl-testimonial-centered__heading">{{ section.settings.heading }}</h2>

    <div class="vl-testimonial-centered__carousel" data-testimonial-carousel>
      <div class="vl-testimonial-centered__track" data-testimonial-track>
        {% for block in section.blocks %}
          <div class="vl-testimonial-centered__card" {{ block.shopify_attributes }}>
            {% if block.settings.avatar != blank %}
              <div class="vl-testimonial-centered__avatar">
                <img
                  src="{{ block.settings.avatar | image_url: width: 160 }}"
                  alt="{{ block.settings.name }}"
                  width="80"
                  height="80"
                  loading="lazy"
                >
              </div>
            {% endif %}

            <p class="vl-testimonial-centered__quote">{{ block.settings.quote }}</p>

            <div class="vl-testimonial-centered__stars">
              {% for i in (1..5) %}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                </svg>
              {% endfor %}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>

    {% if section.blocks.size > 1 %}
      <div class="vl-testimonial-centered__dots" data-testimonial-dots>
        {% for block in section.blocks %}
          <button class="vl-testimonial-centered__dot {% if forloop.first %}is-active{% endif %}" data-dot="{{ forloop.index0 }}" aria-label="Go to testimonial {{ forloop.index }}"></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('[data-testimonial-carousel]');
    if (!section) return;

    const track = section.querySelector('[data-testimonial-track]');
    const cards = track.querySelectorAll('.vl-testimonial-centered__card');
    const dotsContainer = section.parentElement.querySelector('[data-testimonial-dots]');
    const dots = dotsContainer ? dotsContainer.querySelectorAll('[data-dot]') : [];

    if (cards.length <= 1) return;

    let currentIndex = 0;

    function updateCarousel() {
      const cardWidth = cards[0].offsetWidth + 16;
      track.style.transform = `translateX(-${currentIndex * cardWidth}px)`;

      dots.forEach((dot, i) => {
        dot.classList.toggle('is-active', i === currentIndex);
      });
    }

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        currentIndex = parseInt(dot.dataset.dot);
        updateCarousel();
      });
    });

    // Touch swipe support
    let touchStartX = 0;
    let touchEndX = 0;

    track.addEventListener('touchstart', (e) => {
      touchStartX = e.changedTouches[0].screenX;
    }, { passive: true });

    track.addEventListener('touchend', (e) => {
      touchEndX = e.changedTouches[0].screenX;
      const diff = touchStartX - touchEndX;

      if (Math.abs(diff) > 50) {
        if (diff > 0 && currentIndex < cards.length - 1) {
          currentIndex++;
        } else if (diff < 0 && currentIndex > 0) {
          currentIndex--;
        }
        updateCarousel();
      }
    }, { passive: true });
  });
</script>

{% stylesheet %}
  .vl-testimonial-centered {
    background-color: var(--section-bg, #F5EDE8);
    padding: 40px 0;
    overflow: hidden;
  }

  .vl-testimonial-centered__inner {
    max-width: 402px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .vl-testimonial-centered__heading {
    font-family: var(--font-heading--family, sans-serif);
    font-size: 20px;
    font-weight: 700;
    color: var(--heading-color, #000000);
    text-align: center;
    margin: 0 0 24px;
    text-transform: uppercase;
  }

  .vl-testimonial-centered__carousel {
    overflow: visible;
  }

  .vl-testimonial-centered__track {
    display: flex;
    gap: 16px;
    transition: transform 0.3s ease;
  }

  .vl-testimonial-centered__card {
    flex-shrink: 0;
    width: 100%;
    background-color: var(--card-bg, #ffffff);
    border-radius: 16px;
    padding: 24px;
    text-align: center;
  }

  .vl-testimonial-centered__avatar {
    width: 80px;
    height: 80px;
    margin: 0 auto 16px;
    border-radius: 50%;
    overflow: hidden;
  }

  .vl-testimonial-centered__avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .vl-testimonial-centered__quote {
    font-size: 14px;
    line-height: 1.6;
    color: var(--quote-color, #333333);
    margin: 0 0 16px;
  }

  .vl-testimonial-centered__stars {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    color: var(--star-color, #F7A81B);
  }

  .vl-testimonial-centered__dots {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  .vl-testimonial-centered__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: #CCCCCC;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background-color 0.2s ease;
  }

  .vl-testimonial-centered__dot.is-active {
    background-color: #5C1A33;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "VL Testimonial Centered",
  "tag": "section",
  "class": "vl-testimonial-centered-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "WHAT OUR CUSTOMER SAID"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#F5EDE8"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Quote text color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "star_color",
      "label": "Star color",
      "default": "#F7A81B"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "image_picker",
          "id": "avatar",
          "label": "Avatar image"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "\"Surprisingly lightweight but gives amazing coverage! It blends so easily and really adjusts to my skin tone. My makeup looks smoother and more even throughout the day.\""
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Sarah"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VL Testimonial Centered",
      "blocks": [
        {
          "type": "testimonial",
          "settings": {
            "quote": "\"Surprisingly lightweight but gives amazing coverage! It blends so easily and really adjusts to my skin tone. My makeup looks smoother and more even throughout the day.\""
          }
        }
      ]
    }
  ]
}
{% endschema %}
