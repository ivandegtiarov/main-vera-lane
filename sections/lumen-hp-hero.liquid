{% comment %}
  ---------------------------------------------------------------------------
  ⚡ Lumen HP Hero
  - Production-ready Shopify section
  - Scoped CSS (per-section ID) + CSS variables for editor controls
  - Scroll-triggered fade-in animation (IntersectionObserver + fallback)
  ---------------------------------------------------------------------------
{% endcomment %}

{%- liquid
  assign section_dom_id = 'vl-hp-hero-' | append: section.id
-%}

<section
  id="{{ section_dom_id }}"
  class="vl-hp-hero{% if section.settings.enable_animation %} vl-hp-hero--animate{% endif %}"
  aria-label="{{ section.settings.aria_label | escape }}"
  role="region"
  data-animation-enabled="{{ section.settings.enable_animation }}"
>
  <div class="vl-hp-hero__inner">
    <div class="vl-hp-hero__content">
      <div class="vl-hp-hero__content-inner">
        <h1 class="vl-hp-hero__title" data-vl-hp-hero-animate>
          {{ section.settings.heading | escape }}
        </h1>

        <p class="vl-hp-hero__sub" data-vl-hp-hero-animate>
          {{ section.settings.subheading | escape }}
        </p>
      </div>

      <div class="vl-hp-hero__ctaRow" data-vl-hp-hero-animate>
        <a
          class="vl-hp-hero__cta"
          href="{{ section.settings.cta_link }}"
          aria-label="{{ section.settings.cta_label | escape }}"
        >
          {{ section.settings.cta_label | escape }}
        </a>
      </div>

      <div class="vl-hp-hero__badges" aria-label="Trust badges" data-vl-hp-hero-animate>
        {%- for block in section.blocks -%}
          <div class="vl-hp-hero__badge" {{ block.shopify_attributes }}>
            {%- if block.settings.icon_image != blank -%}
              <img
                class="vl-hp-hero__badgeIcon"
                src="{{ block.settings.icon_image | image_url: width: 128 }}"
                alt="{{ block.settings.icon_alt | default: '' | escape }}"
                loading="lazy"
                width="64"
                height="64"
              >
            {%- else -%}
              <span class="vl-hp-hero__badgeIcon" aria-hidden="true"></span>
            {%- endif -%}

            <div class="vl-hp-hero__badgeText">
              {{ block.settings.text | escape }}
            </div>
          </div>

          {%- unless forloop.last -%}
            <div class="vl-hp-hero__divider" aria-hidden="true"></div>
          {%- endunless -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="vl-hp-hero__media" aria-hidden="true">
      {%- if section.settings.hero_image != blank -%}
        <img
          class="vl-hp-hero__image"
          src="{{ section.settings.hero_image | image_url: width: 1400 }}"
          alt="{{ section.settings.hero_image_alt | default: '' | escape }}"
          loading="eager"
          width="{{ section.settings.hero_image.width }}"
          height="{{ section.settings.hero_image.height }}"
        >
      {%- else -%}
        <div class="vl-hp-hero__imagePlaceholder" aria-hidden="true"></div>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  /* Scoped variables (all editor-controlled values live here) */
  #{{ section_dom_id }} {
    --vl-hp-hero-bg-solid: {{ section.settings.background_color }};
    --vl-hp-hero-bg-grad-start: {{ section.settings.background_gradient_start }};
    --vl-hp-hero-bg-grad-end: {{ section.settings.background_gradient_end }};

    --vl-hp-hero-heading-color: {{ section.settings.heading_color }};
    --vl-hp-hero-body-color: {{ section.settings.body_color }};
    --vl-hp-hero-cta-text-color: {{ section.settings.cta_text_color }};
    --vl-hp-hero-badge-text-color: {{ section.settings.badge_text_color }};

    --vl-hp-hero-padding-top-mobile: {{ section.settings.padding_top_mobile }}px;
    --vl-hp-hero-padding-bottom-mobile: {{ section.settings.padding_bottom_mobile }}px;
    --vl-hp-hero-padding-top-desktop: {{ section.settings.padding_top_desktop }}px;
    --vl-hp-hero-padding-bottom-desktop: {{ section.settings.padding_bottom_desktop }}px;

    --vl-hp-hero-title-size-mobile: {{ section.settings.title_font_size_mobile }}px;
    --vl-hp-hero-title-size-desktop: {{ section.settings.title_font_size_desktop }}px;
    --vl-hp-hero-sub-size-mobile: {{ section.settings.sub_font_size_mobile }}px;
    --vl-hp-hero-sub-size-desktop: {{ section.settings.sub_font_size_desktop }}px;
    --vl-hp-hero-cta-size-mobile: {{ section.settings.cta_font_size_mobile }}px;
    --vl-hp-hero-cta-size-desktop: {{ section.settings.cta_font_size_desktop }}px;
    --vl-hp-hero-badge-size-mobile: {{ section.settings.badge_font_size_mobile }}px;
    --vl-hp-hero-badge-size-desktop: {{ section.settings.badge_font_size_desktop }}px;
  }

  /* Base reset (scoped) */
  #{{ section_dom_id }} *,
  #{{ section_dom_id }} *::before,
  #{{ section_dom_id }} *::after {
    box-sizing: border-box;
  }

  /* Section */
  #{{ section_dom_id }}.vl-hp-hero {
    width: 100%;
    background-color: var(--vl-hp-hero-bg-solid);
    background-image: radial-gradient(
      circle at 91% 51%,
      var(--vl-hp-hero-bg-grad-start) 0%,
      var(--vl-hp-hero-bg-grad-end) 100%
    );
    overflow: hidden;
    color: var(--vl-hp-hero-body-color);
    font-family: Montserrat, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
  }

  /* Layout */
  #{{ section_dom_id }} .vl-hp-hero__inner {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
    padding:
      calc(var(--vl-hp-hero-padding-top-mobile) + 16px)
      28px
      var(--vl-hp-hero-padding-bottom-mobile)
      28px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
    align-items: start;
  }

  #{{ section_dom_id }} .vl-hp-hero__content {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  #{{ section_dom_id }} .vl-hp-hero__content-inner {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  /* Typography */
  #{{ section_dom_id }} .vl-hp-hero__title {
    margin: 0;
    font-family: "Playfair Display" !important;
    font-weight: 500;
    font-size: var(--vl-hp-hero-title-size-mobile);
    line-height: 1;
    letter-spacing: 0;
    text-transform: none;
    max-width: 720px;
    color: var(--vl-hp-hero-heading-color);
  }

  #{{ section_dom_id }} .vl-hp-hero__sub {
    margin: 0;
    font-weight: 400;
    font-size: var(--vl-hp-hero-sub-size-mobile);
    line-height: 1.56;
    max-width: 560px;
    color: var(--vl-hp-hero-body-color);
  }

  /* CTA */
  #{{ section_dom_id }} .vl-hp-hero__ctaRow {
    width: 100%;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 12px;
  }

  #{{ section_dom_id }} .vl-hp-hero__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #000000;
    color: var(--vl-hp-hero-cta-text-color);
    border-radius: 48px;
    text-decoration: none;
    height: 42px;
    padding: 0 48px;
    font-weight: 600;
    font-size: var(--vl-hp-hero-cta-size-mobile);
    line-height: 24px;
    letter-spacing: 0;
    white-space: nowrap;
    /* PDP-style hover fill animation */
    position: relative;
    overflow: hidden;
    z-index: 1;
    background: transparent;
    transition: color 0.3s ease;
  }

  #{{ section_dom_id }} .vl-hp-hero__cta:after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #000000;
    border-radius: 48px;
    z-index: -2;
  }

  #{{ section_dom_id }} .vl-hp-hero__cta:before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 100%;
    background-color: #5A0028;
    transition: all 0.3s;
    border-radius: 48px;
    z-index: -1;
  }

  #{{ section_dom_id }} .vl-hp-hero__cta:hover {
    color: var(--vl-hp-hero-cta-text-color);
  }

  #{{ section_dom_id }} .vl-hp-hero__cta:hover:before {
    width: 100%;
  }

  #{{ section_dom_id }} .vl-hp-hero__cta:focus-visible {
    outline: 2px solid #000000;
    outline-offset: 2px;
  }

  /* Badges */
  #{{ section_dom_id }} .vl-hp-hero__badges {
    width: 100%;
    max-width: 472px;
    display: grid;
    grid-template-columns: 1fr 1px 1fr 1px 1fr;
    align-items: baseline;
    gap: 0;
    margin-top: 8px;
  }

  #{{ section_dom_id }} .vl-hp-hero__divider {
    width: 1px;
    height: 34px;
    background: #A7BAC1;
    justify-self: center;
  }

  #{{ section_dom_id }} .vl-hp-hero__badge {
    width: 100%;
    min-width: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 0 10px;
    text-align: center;
  }

  @media screen and (max-width: 760px) {
    #{{ section_dom_id }} .vl-hp-hero__badge {
      padding: 0px;
    }
  }

  #{{ section_dom_id }} .vl-hp-hero__badgeIcon {
    width: 43px;
    height: 43px;
    display: block;
    object-fit: contain;
  }

  #{{ section_dom_id }} .vl-hp-hero__badgeText {
    font-weight: 500;
    font-size: var(--vl-hp-hero-badge-size-mobile);
    line-height: 1.2;
    color: var(--vl-hp-hero-badge-text-color);
  }

  /* Media */
  #{{ section_dom_id }} .vl-hp-hero__media {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: flex-end;
  }

  #{{ section_dom_id }} .vl-hp-hero__image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    border-radius: 0;
  }

  #{{ section_dom_id }} .vl-hp-hero__imagePlaceholder {
    width: 100%;
    max-width: 692px;
    aspect-ratio: 692 / 760;
    background: rgba(0, 0, 0, 0.08);
  }

  /* Desktop layout (text + image side-by-side) */
  @media screen and (min-width: 900px) {
    /* Ensure absolutely-positioned media is clipped to the hero section itself */
    #{{ section_dom_id }}.vl-hp-hero {
      position: relative;
      overflow: hidden;
      clip-path: inset(0);
    }

    #{{ section_dom_id }} .vl-hp-hero__inner {
      padding:
        calc(var(--vl-hp-hero-padding-top-desktop) + 17px)
        96px
        var(--vl-hp-hero-padding-bottom-desktop)
        96px;
      grid-template-columns: 672px minmax(0, 1fr);
      gap: 56px;
      align-items: end;
      overflow: hidden;
    }

    #{{ section_dom_id }} .vl-hp-hero__content {
      gap: 40px;
      padding-bottom: 52px;
    }

    #{{ section_dom_id }} .vl-hp-hero__cta {
      height: 56px;
      padding: 0 48px;
      font-size: var(--vl-hp-hero-cta-size-desktop);
      line-height: 24px;
    }

    #{{ section_dom_id }} .vl-hp-hero__media {
      justify-content: flex-end;
      align-items: flex-end;
      align-self: stretch;
      overflow: hidden;
    }

    #{{ section_dom_id }} .vl-hp-hero__image,
    #{{ section_dom_id }} .vl-hp-hero__imagePlaceholder {
      max-width: 692px;
      max-height: 100%;
      position: absolute;
      /* right: 0; */
    }

    #{{ section_dom_id }} .vl-hp-hero__divider {
      height: 50px;
    }

    #{{ section_dom_id }} .vl-hp-hero__badgeIcon {
      width: 64px;
      height: 64px;
    }

    #{{ section_dom_id }} .vl-hp-hero__title {
      font-size: var(--vl-hp-hero-title-size-desktop);
      max-width: 600px;
    }

    #{{ section_dom_id }} .vl-hp-hero__sub {
      font-size: var(--vl-hp-hero-sub-size-desktop);
    }

    #{{ section_dom_id }} .vl-hp-hero__badgeText {
      font-size: var(--vl-hp-hero-badge-size-desktop);
    }
  }

  /* Smaller desktop: keep identical styling, shift image further right */
  @media screen and (min-width: 900px) and (max-width: 1250px) {
    #{{ section_dom_id }} .vl-hp-hero__image,
    #{{ section_dom_id }} .vl-hp-hero__imagePlaceholder {
      right: -200px;
    }
  }

  /* Fade-in animation */
  #{{ section_dom_id }}.vl-hp-hero--animate [data-vl-hp-hero-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  #{{ section_dom_id }}.vl-hp-hero--animate [data-vl-hp-hero-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

</style>

<script>
  // Fade-in animation on scroll (single trigger per element)
  document.addEventListener('DOMContentLoaded', function() {
    const root = document.getElementById({{ section_dom_id | json }});
    if (!root) return;

    const animationEnabled = root.getAttribute('data-animation-enabled') === 'true';
    if (!animationEnabled) return;

    const animatedElements = root.querySelectorAll('[data-vl-hp-hero-animate]');
    if (!animatedElements || animatedElements.length === 0) return;

    if ('IntersectionObserver' in window) {
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -100px 0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      animatedElements.forEach(el => observer.observe(el));
    } else {
      // Fallback for browsers without IntersectionObserver support
      animatedElements.forEach(el => el.classList.add('is-visible'));
    }
  });
</script>

