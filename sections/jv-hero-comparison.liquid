    },
    {
      "type": "text",
      "id": "col3_header",
      "label": "Column 3 header",
      "default": "Protein Drinks"
    },
    {
      "type": "header",
      "content": "Calories Row"
    },
    {
      "type": "text",
      "id": "col1_calories",
      "label": "Product calories",
      "default": "120cal"
    },
    {
      "type": "text",
      "id": "col2_calories",
      "label": "Competitor 1 calories",
      "default": "150-400cal"
    },
    {
      "type": "text",
      "id": "col3_calories",
      "label": "Competitor 2 calories",
      "default": "160-200cal"
    },
    {
      "type": "header",
      "content": "Protein Row"
    },
    {
      "type": "text",
      "id": "col1_protein",
      "label": "Product protein",
      "default": "20g"
    },
    {
      "type": "text",
      "id": "col2_protein",
      "label": "Competitor 1 protein",
      "default": "2-12g"
    },
    {
      "type": "text",
      "id": "col3_protein",
      "label": "Competitor 2 protein",
      "default": "25g"
    },
    {
      "type": "header",
      "content": "Sugar Row"
    },
    {
      "type": "text",
      "id": "col1_sugar",
      "label": "Product sugar",
      "default": "<1g"
    },
    {
      "type": "text",
      "id": "col2_sugar",
      "label": "Competitor 1 sugar",
      "default": "20-30g"
    },
    {
      "type": "text",
      "id": "col3_sugar",
      "label": "Competitor 2 sugar",
      "default": "varies"
    },
    {
      "type": "header",
      "content": "Price Row"
    },
    {
      "type": "text",
      "id": "col1_price",
      "label": "Product price",
      "default": "💰"
    },
    {
      "type": "text",
      "id": "col2_price",
      "label": "Competitor 1 price",
      "default": "💰💰"
    },
    {
      "type": "text",
      "id": "col3_price",
      "label": "Competitor 2 price",
      "default": "💰💰💰"
    }
  ],
  "presets": [
    {
      "name": "JV - Hero Comparison",
      "category": "t:categories.reasons_listicle"
    }
  ]
}
