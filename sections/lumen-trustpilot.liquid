<style>
      /*
        Vera Lane – Trustpilot Rating
        Built from:
        - Desktop: https://www.figma.com/design/1M8lKf2fVA2oaHmvrircEx/Vera-Lane---Website-Design?node-id=1-1148&m=dev
        - Mobile:  https://www.figma.com/design/1M8lKf2fVA2oaHmvrircEx/Vera-Lane---Website-Design?node-id=1-1539&m=dev

        Mobile‑first, fully fluid layout using px-based spacing & typography.
        No fixed section widths: flexbox + gaps keep the badge layout responsive.
      */

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Inter", system-ui, -apple-system, BlinkMacSystemFont,
          "Segoe UI", sans-serif;
        background-color: #ffffff;
        color: #050505;
      }

      .trustpilot-section {
        width: 100%;
        background-color: #ffffff;
        padding: {{ section.settings.padding_top }}px {{ section.settings.padding_left_right }}px {{ section.settings.padding_bottom }}px;
      }

      .trustpilot-inner {
        width: 100%;
        max-width: 1440px;
        margin: 0 auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 27px;
      }

      .trustpilot-badge {
        width: 100%;
        display: flex;
        flex-direction: column; /* Mobile: logo above stars */
        align-items: center;
        justify-content: center;
        gap: 40px;
        text-align: center;
      }

      .trustpilot-logo {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
      }

      .trustpilot-logo-star {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 38px;
        height: 36px;
        border-radius: 4px;
        background-color: #00b67a;
        box-shadow: inset 0 0 0 2px #005128;
        color: #ffffff;
        font-size: 22px;
        line-height: 1;
      }

      .trustpilot-logo-text {
        font-weight: 700;
        font-size: 22px;
        line-height: 1.3;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: #050505;
      }

      .trustpilot-stars-wrapper {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
      }

      .trustpilot-stars {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 12px;
      }

      .trustpilot-stars img {
        width: 288px;
        height: auto;
      }

      .trustpilot-star-box {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 34px;
        height: 34px;
        border-radius: 6px;
        background-color: #219653;
        color: #ffffff;
        font-size: 18px;
        line-height: 1;
      }

      .trustpilot-star-box--half {
        background: linear-gradient(
          90deg,
          #219653 0%,
          #219653 50%,
          #d9d9d9 50%,
          #d9d9d9 100%
        );
      }

      .trustpilot-rating-text {
        margin-top: 0;
        font-weight: 500;
        font-size: 20px;
        line-height: 1.3;
        text-transform: uppercase;
        text-align: center;
        color: #6a6a6a;
      }

      /* Fade-in animation */
      .trustpilot-section--animate .trustpilot-badge,
      .trustpilot-section--animate .trustpilot-rating-text {
        opacity: 0;
        transform: translateY(30px);
        transition: opacity 0.8s ease-out, transform 0.8s ease-out;
      }

      .trustpilot-section--animate .trustpilot-badge.is-visible,
      .trustpilot-section--animate .trustpilot-rating-text.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      /* Staggered animation delays */
      .trustpilot-section--animate .trustpilot-badge {
        transition-delay: 0.1s;
      }

      .trustpilot-section--animate .trustpilot-rating-text {
        transition-delay: 0.2s;
      }

      /* Tablet and up – bring paddings closer to desktop frame */
      @media (min-width: 768px) {
        .trustpilot-section {
          padding: {{ section.settings.padding_top }}px 40px {{ section.settings.padding_bottom }}px;
        }
      }

      /* Desktop – horizontal logo + stars as in Figma */
      @media (min-width: 1024px) {
        .trustpilot-section {
          padding: {{ section.settings.padding_top }}px 50px {{ section.settings.padding_bottom }}px;
        }

        .trustpilot-badge {
          flex-direction: row;
          text-align: left;
        }

        .trustpilot-stars-wrapper {
          align-items: flex-start;
        }
      }
    </style>

