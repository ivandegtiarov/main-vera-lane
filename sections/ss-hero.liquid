<!-- SS Hero — rebuilt from star-story-theme/sections/main-product.liquid -->
<!-- All settings hardcoded from product.json; product/cart references replaced with static HTML -->

<style>
  .ss-hero {
    padding-top: 27px;
    padding-bottom: 9px;
  }
  @media screen and (min-width: 750px) {
    .ss-hero {
      padding-top: 36px;
      padding-bottom: 12px;
    }
  }

  .ss-hero .page-width {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .ss-hero .product {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }
  @media screen and (min-width: 750px) {
    .ss-hero .product {
      grid-template-columns: 60% 1fr;
      gap: 3rem;
      align-items: start;
    }
  }

  /* ── Gallery ── */
  .ss-hero .product__media-wrapper {
    position: relative;
  }
  .ss-hero .product__media-main {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
    margin-bottom: 12px;
    aspect-ratio: 1 / 1;
  }
  .ss-hero .product__media-main img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: contain;
  }
  .ss-hero .product__media-thumbs {
    display: flex;
    gap: 8px;
    overflow-x: auto;
  }
  .ss-hero .product__media-thumb {
    flex: 0 0 80px;
    width: 80px;
    height: 80px;
    border-radius: 6px;
    overflow: hidden;
    cursor: pointer;
    border: 2px solid transparent;
    transition: border-color 0.2s;
  }
  .ss-hero .product__media-thumb.active {
    border-color: #00354B;
  }
  .ss-hero .product__media-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* ── Product Info ── */
  .ss-hero .product__info-container {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Rating block */
  .ss-hero .product__rating {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .ss-hero .product__rating-people {
    height: 28px;
    width: auto;
  }
  .ss-hero .product__rating-stars {
    height: 16px;
    width: auto;
  }
  .ss-hero .product__rating-text {
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    color: #1a3050;
    line-height: 1.4;
  }
  .ss-hero .product__rating-text strong {
    font-weight: 700;
  }

  /* Title */
  .ss-hero .product__title h1 {
    font-family: "Noto Serif", serif;
    font-size: 28px;
    font-weight: 500;
    line-height: 1.2;
    color: #1a3050;
    margin: 0;
  }
  @media screen and (min-width: 750px) {
    .ss-hero .product__title h1 {
      font-size: 36px;
    }
  }

  /* Icon with text */
  .ss-hero .icon-with-text {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
  }
  .ss-hero .icon-with-text__item {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }
  .ss-hero .icon-with-text__item img {
    width: 24px;
    height: 24px;
    flex-shrink: 0;
    margin-top: 2px;
  }
  .ss-hero .icon-with-text__item .h4 {
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: #1a3050;
    margin: 0;
  }
  .ss-hero .icon-with-text__item .h4 strong {
    font-weight: 700;
  }

  /* Price */
  .ss-hero .price {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }
  .ss-hero .price__current {
    font-family: "DM Sans", sans-serif;
    font-size: 24px;
    font-weight: 700;
    color: #1a3050;
  }
  .ss-hero .price__compare {
    font-family: "DM Sans", sans-serif;
    font-size: 18px;
    color: #999;
    text-decoration: line-through;
  }
  .ss-hero .price__badge {
    background: #c4383b;
    color: #fff;
    font-family: "DM Sans", sans-serif;
    font-size: 12px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
  }

  /* CTA */
  .ss-hero .product__cta {
    display: block;
    width: 100%;
    padding: 16px 24px;
    border: none;
    border-radius: 8px;
    background: linear-gradient(103deg, rgba(0, 116, 165, 1) 108.34%, rgba(0, 53, 75, 1) 223.24%);
    color: #fff;
    font-family: "DM Sans", sans-serif;
    font-size: 16px;
    font-weight: 700;
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: opacity 0.2s;
    box-sizing: border-box;
  }
  .ss-hero .product__cta:hover {
    opacity: 0.9;
  }

  /* Trust icons */
  .ss-hero .product__trust {
    display: flex;
    justify-content: center;
    gap: 24px;
    padding-top: 8px;
    flex-wrap: wrap;
  }
  .ss-hero .product__trust-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-family: "DM Sans", sans-serif;
    font-size: 12px;
    color: #1a3050;
  }
  .ss-hero .product__trust-item img {
    width: 16px;
    height: 16px;
  }
</style>

<section class="ss-hero" id="product-id">
  <div class="page-width">
    <div class="product">
      <!-- Media / Gallery -->
      <div class="product__media-wrapper">
        <div class="product__media-main">
          <img id="ss-hero-main-img" src="{{ 'ss-lifestyle-5.webp' | asset_url }}" alt="Personalized Astrology Book">
        </div>
        <div class="product__media-thumbs">
          <div class="product__media-thumb active" onclick="ssHeroThumb(this)">
            <img src="{{ 'ss-lifestyle-5.webp' | asset_url }}" alt="Lifestyle photo">
          </div>
          <div class="product__media-thumb" onclick="ssHeroThumb(this)">
            <img src="{{ 'ss-lifestyle-6.webp' | asset_url }}" alt="Lifestyle photo">
          </div>
          <div class="product__media-thumb" onclick="ssHeroThumb(this)">
            <img src="{{ 'ss-lifestyle-1.webp' | asset_url }}" alt="Lifestyle photo">
          </div>
          <div class="product__media-thumb" onclick="ssHeroThumb(this)">
            <img src="{{ 'ss-lifestyle-4.webp' | asset_url }}" alt="Lifestyle photo">
          </div>
          <div class="product__media-thumb" onclick="ssHeroThumb(this)">
            <img src="{{ 'ss-lifestyle-3.webp' | asset_url }}" alt="Lifestyle photo">
          </div>
          <div class="product__media-thumb" onclick="ssHeroThumb(this)">
            <img src="{{ 'ss-lifestyle-2.webp' | asset_url }}" alt="Lifestyle photo">
          </div>
          <div class="product__media-thumb" onclick="ssHeroThumb(this)">
            <img src="{{ 'ss-product-main.png' | asset_url }}" alt="Product shot">
          </div>
        </div>
      </div>

      <!-- Product Info -->
      <div class="product__info-container">
        <!-- Rating -->
        <div class="product__rating">
          <img class="product__rating-people" src="{{ 'ss-group-299.png' | asset_url }}" alt="Happy customers" loading="lazy">
          <img class="product__rating-stars" src="{{ 'ss-icon-stars.svg' | asset_url }}" alt="4.88 stars" loading="lazy">
          <span class="product__rating-text">4.88 &mdash; Loved By <strong>98+</strong> Astrology Enthusiasts</span>
        </div>

        <!-- Title -->
        <div class="product__title">
          <h1>Personalized Astrology Book</h1>
        </div>

        <!-- Icon with text -->
        <ul class="icon-with-text icon-with-text--vertical">
          <li class="icon-with-text__item">
            <img src="{{ 'ss-icon-book.svg' | asset_url }}" alt="" role="presentation" loading="lazy" height="auto" width="auto">
            <span class="h4 inline-richtext"><strong>Discover Yourself: </strong>Dive deep into your character, strengths, and life's path with a book that's uniquely yours, based on your astrological birth chart.</span>
          </li>
          <li class="icon-with-text__item">
            <img src="{{ 'ss-icon-group-234.svg' | asset_url }}" alt="" role="presentation" loading="lazy" height="auto" width="auto">
            <span class="h4 inline-richtext"><strong>Unlock Your Potential: </strong>Use this book as a key to unlocking the deeper aspects of yourself, discovering untapped potential along the way.</span>
          </li>
          <li class="icon-with-text__item">
            <img src="{{ 'ss-icon-group-233.svg' | asset_url }}" alt="" role="presentation" loading="lazy" height="auto" width="auto">
            <span class="h4 inline-richtext"><strong>Guide Your Decisions:</strong> Let the insights from your horoscope reading enlighten your decision-making, illuminating paths in personal and professional realms.</span>
          </li>
        </ul>

        <!-- Price -->
        <div class="price">
          <span class="price__current">A$119.00</span>
          <span class="price__compare">A$145.00</span>
          <span class="price__badge">Sale</span>
        </div>

        <!-- CTA -->
        <a href="#product-id" class="product__cta">start personalizing for A$119</a>

        <!-- Trust badges -->
        <div class="product__trust">
          <div class="product__trust-item">
            <img src="{{ 'ss-icon-vector-12.svg' | asset_url }}" alt="" loading="lazy">
            <span>Printed in Australia</span>
          </div>
          <div class="product__trust-item">
            <img src="{{ 'ss-icon-vector-13.svg' | asset_url }}" alt="" loading="lazy">
            <span>Astrologer approved</span>
          </div>
          <div class="product__trust-item">
            <img src="{{ 'ss-icon-vector-14.svg' | asset_url }}" alt="" loading="lazy">
            <span>Secure checkout</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function ssHeroThumb(el) {
    var thumbs = el.parentElement.querySelectorAll('.product__media-thumb');
    thumbs.forEach(function(t) { t.classList.remove('active'); });
    el.classList.add('active');
    var mainImg = document.getElementById('ss-hero-main-img');
    mainImg.src = el.querySelector('img').src;
  }
</script>

{% schema %}
{
  "name": "SS Hero",
  "settings": []
}
{% endschema %}
