{% comment %}
  ---------------------------------------------------------------------------
  ⚡ Lumen Beauty
  - Production-ready Shopify section
  - Mobile-first, scoped CSS (per-section ID) + CSS variables for editor controls
  - Scroll-triggered fade-in animation (IntersectionObserver + fallback)
  - Matches the provided HTML layout 1:1 (structure + breakpoints + spacing)
  ---------------------------------------------------------------------------
{% endcomment %}

{%- liquid
  assign section_dom_id = 'vl-beauty-' | append: section.id
-%}

<section
  id="{{ section_dom_id }}"
  class="vl-beauty"
  aria-label="{{ section.settings.aria_label | escape }}"
  role="region"
>
  {%- comment -%} Decorative assets (optional) {%- endcomment -%}
  {%- if section.settings.bg_texture_image != blank -%}
    <img
      class="vl-beauty__bg-texture"
      src="{{ section.settings.bg_texture_image | image_url: width: 1200 }}"
      alt=""
      aria-hidden="true"
      loading="lazy"
      width="{{ section.settings.bg_texture_image.width }}"
      height="{{ section.settings.bg_texture_image.height }}"
    >
  {%- endif -%}

  {%- if section.settings.bg_blur_image != blank -%}
    <img
      class="vl-beauty__bg-blur"
      src="{{ section.settings.bg_blur_image | image_url: width: 1400 }}"
      alt=""
      aria-hidden="true"
      loading="lazy"
      width="{{ section.settings.bg_blur_image.width }}"
      height="{{ section.settings.bg_blur_image.height }}"
    >
  {%- endif -%}

  <div class="vl-beauty__inner">
    {%- comment -%} Top block {%- endcomment -%}
    <div class="vl-beauty__top">
      <h2 class="vl-beauty__title" data-vl-beauty-animate>
        {{ section.settings.heading | escape }}
      </h2>

      <div class="vl-beauty__top-content">
        <div class="vl-beauty__product-wrap" data-vl-beauty-animate>
          {%- if section.settings.product_image != blank -%}
            <img
              class="vl-beauty__product"
              src="{{ section.settings.product_image | image_url: width: 1200 }}"
              alt="{{ section.settings.product_image_alt | escape }}"
              loading="lazy"
              width="{{ section.settings.product_image.width }}"
              height="{{ section.settings.product_image.height }}"
            >
          {%- else -%}
            <div class="vl-beauty__productPlaceholder" aria-hidden="true"></div>
          {%- endif -%}
        </div>

        <div class="vl-beauty__copy" data-vl-beauty-animate>
          <div class="vl-beauty__copy-text">
            <p class="vl-beauty__p">{{ section.settings.paragraph_1 | escape }}</p>
            <p class="vl-beauty__p">{{ section.settings.paragraph_2 | escape }}</p>
          </div>

          <a class="vl-beauty__cta" href="{{ section.settings.cta_link }}" aria-label="{{ section.settings.cta_label | escape }}">
            {{ section.settings.cta_label | escape }}
          </a>
        </div>
      </div>
    </div>

    {%- comment -%} Bottom block {%- endcomment -%}
    <div class="vl-beauty__bottom">
      <div class="vl-beauty__bottom-header" data-vl-beauty-animate>
        <h2 class="vl-beauty__subtitle">{{ section.settings.subtitle | escape }}</h2>
        <p class="vl-beauty__bottom-text">{{ section.settings.bottom_text | escape }}</p>
      </div>

      <div class="vl-beauty__photo" data-vl-beauty-animate>
        {%- if section.settings.bottom_photo != blank -%}
          <img
            src="{{ section.settings.bottom_photo | image_url: width: 1600 }}"
            alt=""
            aria-hidden="true"
            loading="lazy"
            width="{{ section.settings.bottom_photo.width }}"
            height="{{ section.settings.bottom_photo.height }}"
          >
        {%- else -%}
          <div class="vl-beauty__photoPlaceholder" aria-hidden="true"></div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  /* Section-scoped editor variables */
  #{{ section_dom_id }} {
    --vl-beauty-bg-solid: {{ section.settings.background_color }};
    --vl-beauty-fade-grad-start: {{ section.settings.background_gradient_start }};
    --vl-beauty-fade-grad-end: {{ section.settings.background_gradient_end }};

    --vl-beauty-heading-color: {{ section.settings.heading_color }};
    --vl-beauty-body-color: {{ section.settings.body_color }};
    --vl-beauty-cta-text-color: {{ section.settings.cta_text_color }};
    --vl-beauty-subtitle-color: {{ section.settings.subtitle_color }};
    --vl-beauty-bottom-text-color: {{ section.settings.bottom_text_color }};

    --vl-beauty-pad-top-m: {{ section.settings.padding_top_mobile }}px;
    --vl-beauty-pad-bot-m: {{ section.settings.padding_bottom_mobile }}px;
    --vl-beauty-pad-top-d: {{ section.settings.padding_top_desktop }}px;
    --vl-beauty-pad-bot-d: {{ section.settings.padding_bottom_desktop }}px;

    --vl-beauty-title-size-m: {{ section.settings.title_font_size_mobile }}px;
    --vl-beauty-title-size-d: {{ section.settings.title_font_size_desktop }}px;
    --vl-beauty-body-size-m: {{ section.settings.body_font_size_mobile }}px;
    --vl-beauty-body-size-d: {{ section.settings.body_font_size_desktop }}px;
    --vl-beauty-cta-size-m: {{ section.settings.cta_font_size_mobile }}px;
    --vl-beauty-cta-size-d: {{ section.settings.cta_font_size_desktop }}px;
    --vl-beauty-subtitle-size-m: {{ section.settings.subtitle_font_size_mobile }}px;
    --vl-beauty-subtitle-size-d: {{ section.settings.subtitle_font_size_desktop }}px;
    --vl-beauty-bottom-size-m: {{ section.settings.bottom_font_size_mobile }}px;
    --vl-beauty-bottom-size-d: {{ section.settings.bottom_font_size_desktop }}px;
  }

  /* Scoped base reset */
  #{{ section_dom_id }} *,
  #{{ section_dom_id }} *::before,
  #{{ section_dom_id }} *::after {
    box-sizing: border-box;
  }

  #{{ section_dom_id }}.vl-beauty {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: var(--vl-beauty-bg-solid);
    color: var(--vl-beauty-body-color);
    font-family: Montserrat, -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
  }

  /* Soft fade into the next background (matches provided HTML) */
  #{{ section_dom_id }}.vl-beauty::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    height: 28%;
    background: linear-gradient(
      180deg,
      {{ section.settings.background_gradient_start | color_modify: 'alpha', 0 }} 0%,
      {{ section.settings.background_gradient_end }} 100%
    );
    pointer-events: none;
  }

  #{{ section_dom_id }} .vl-beauty__bg-texture,
  #{{ section_dom_id }} .vl-beauty__bg-blur {
    position: absolute;
    display: block;
    pointer-events: none;
    user-select: none;
  }

  /* Mobile background placements (from provided HTML) */
  #{{ section_dom_id }} .vl-beauty__bg-texture {
    top: 0;
    /* Full-bleed on mobile (avoid looking like it's constrained by section padding) */
    left: 50%;
    transform: translateX(-50%);
    width: 100vw;
    max-width: none;
    height: auto;
    opacity: 1;
    object-fit: cover;
  }

  #{{ section_dom_id }} .vl-beauty__bg-blur {
    top: 809px;
    width: 506px;
    max-width: 90vw;
    height: auto;
    right: 0;
  }

  #{{ section_dom_id }} .vl-beauty__inner {
    width: 100%;
    max-width: 1440px;
    margin: 0 auto;
  }

  /* Top block */
  #{{ section_dom_id }} .vl-beauty__top {
    width: 100%;
    padding: 40px 24px;
    display: flex;
    flex-direction: column;
    gap: 40px;
    position: relative;
    z-index: 1;
  }

  #{{ section_dom_id }} .vl-beauty__title {
    margin: 0;
    font-family: "Playfair Display";
    font-style: italic;
    font-weight: 600;
    font-size: var(--vl-beauty-title-size-m);
    line-height: 38px;
    color: var(--vl-beauty-heading-color);
    text-transform: capitalize;
  }

  #{{ section_dom_id }} .vl-beauty__top-content {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  #{{ section_dom_id }} .vl-beauty__product-wrap {
    position: relative;
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    background: #e5dbd7;
  }

  #{{ section_dom_id }} .vl-beauty__product {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 20px;
  }

  #{{ section_dom_id }} .vl-beauty__productPlaceholder {
    width: 100%;
    aspect-ratio: 4 / 3;
    background: #e5dbd7;
  }

  #{{ section_dom_id }} .vl-beauty__decor {
    display: none;
  }

  #{{ section_dom_id }} .vl-beauty__copy {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  #{{ section_dom_id }} .vl-beauty__copy-text {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #{{ section_dom_id }} .vl-beauty__p {
    margin: 0;
    font-weight: 400;
    font-size: var(--vl-beauty-body-size-m);
    line-height: 28px;
    color: var(--vl-beauty-body-color);
  }

  #{{ section_dom_id }} .vl-beauty__cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 16px 48px;
    border-radius: 48px;
    border: 1px solid #000000;
    text-decoration: none;

    font-weight: 600;
    font-size: var(--vl-beauty-cta-size-m);
    line-height: 24px;
    color: var(--vl-beauty-cta-text-color);
    text-transform: uppercase;
    /* PDP-style hover fill animation (matches lumen-hp-hero) */
    position: relative;
    overflow: hidden;
    z-index: 1;
    background: transparent;
    transition: color 0.3s ease;
  }

  #{{ section_dom_id }} .vl-beauty__cta:after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #000000;
    border-radius: 48px;
    z-index: -2;
  }

  #{{ section_dom_id }} .vl-beauty__cta:before {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0%;
    height: 100%;
    background-color: #5A0028;
    transition: all 0.3s;
    border-radius: 48px;
    z-index: -1;
  }

  #{{ section_dom_id }} .vl-beauty__cta:hover {
    color: var(--vl-beauty-cta-text-color);
  }

  #{{ section_dom_id }} .vl-beauty__cta:hover:before {
    width: 100%;
  }

  #{{ section_dom_id }} .vl-beauty__cta:focus-visible {
    outline: 2px solid #000000;
    outline-offset: 2px;
  }

  /* Bottom block */
  #{{ section_dom_id }} .vl-beauty__bottom {
    width: 100%;
    padding: 40px 24px calc(var(--vl-beauty-pad-bot-m) + 16px) 24px;
    display: flex;
    flex-direction: column;
    gap: 40px;
    position: relative;
    z-index: 1;
  }

  #{{ section_dom_id }} .vl-beauty__subtitle {
    margin: 0;
    font-family: "Playfair Display";
    font-style: italic;
    font-weight: 600;
    font-size: var(--vl-beauty-subtitle-size-m);
    line-height: 38px;
    color: var(--vl-beauty-subtitle-color);
    text-transform: capitalize;
  }

  #{{ section_dom_id }} .vl-beauty__bottom-text {
    margin: 0;
    font-weight: 400;
    font-size: var(--vl-beauty-bottom-size-m);
    line-height: 28px;
    color: var(--vl-beauty-bottom-text-color);
  }

  /* Mobile spacing between subtitle + bottom text */
  #{{ section_dom_id }} .vl-beauty__bottom-header {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  @media (max-width: 768px) {
    #{{ section_dom_id }} .vl-beauty__bottom-header {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  }

  #{{ section_dom_id }} .vl-beauty__photo {
    width: 100%;
    border-radius: 12px;
    overflow: hidden;
    background: rgba(240, 206, 184, 0.2);
  }

  #{{ section_dom_id }} .vl-beauty__photo img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  #{{ section_dom_id }} .vl-beauty__photoPlaceholder {
    width: 100%;
    aspect-ratio: 16 / 9;
    background: rgba(240, 206, 184, 0.2);
  }

  /* Animation (fade-in + translateY) */
  #{{ section_dom_id }} [data-vl-beauty-animate] {
    opacity: 0;
    transform: translateY(20px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
    will-change: opacity, transform;
  }

  #{{ section_dom_id }} [data-vl-beauty-animate].is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    #{{ section_dom_id }} [data-vl-beauty-animate] {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }

  @media (min-width: 768px) {
    #{{ section_dom_id }} .vl-beauty__top,
    #{{ section_dom_id }} .vl-beauty__bottom {
      padding-left: 40px;
      padding-right: 40px;
    }
  }

  /* Desktop layout (from provided HTML) */
  @media (min-width: 1024px) {
    #{{ section_dom_id }} .vl-beauty__bg-texture {
      top: -1px;
      transform: none;
      left: auto;
      right: 0;
      width: 607px;
      height: 369px;
    }

    #{{ section_dom_id }} .vl-beauty__bg-blur {
      top: 539px;
      left: auto;
      right: -69px;
      width: 736px;
      max-width: 52vw;
    }

    #{{ section_dom_id }} .vl-beauty__top {
      padding: calc(var(--vl-beauty-pad-top-d) + 86px) 96px 110px 96px;
      gap: 50px;
    }

    #{{ section_dom_id }} .vl-beauty__title {
      font-size: var(--vl-beauty-title-size-d);
      line-height: 58px;
      max-width: 677px;
    }

    #{{ section_dom_id }} .vl-beauty__top-content {
      grid-template-columns: 1fr min(444px, 100%);
      column-gap: 40px;
      align-items: start;
    }

    #{{ section_dom_id }} .vl-beauty__product-wrap {
      border-radius: 0;
      background: transparent;
      overflow: visible;
    }

    #{{ section_dom_id }} .vl-beauty__product {
      width: 100%;
      max-width: 864px;
    }

    #{{ section_dom_id }} .vl-beauty__decor {
      display: block;
      position: absolute;
      top: -126px;
      right: -298px;
      width: 273px;
      height: 164px;
      pointer-events: none;
      user-select: none;
    }

    #{{ section_dom_id }} .vl-beauty__copy {
      gap: 80px;
    }

    #{{ section_dom_id }} .vl-beauty__p {
      font-size: var(--vl-beauty-body-size-d);
    }

    #{{ section_dom_id }} .vl-beauty__cta {
      width: fit-content;
      font-size: var(--vl-beauty-cta-size-d);
      line-height: 24px;
      padding: 13px 48px;
    }

    #{{ section_dom_id }} .vl-beauty__bottom {
      padding: 80px 96px calc(var(--vl-beauty-pad-bot-d) + 40px) 96px;
      gap: 80px;
    }

    #{{ section_dom_id }} .vl-beauty__bottom-header {
      display: flex;
      justify-content: center;
      gap: 32px;
      flex-direction: row;
      width: 100%;
      max-width: 1248px;
      margin: 0 auto;
    }

    #{{ section_dom_id }} .vl-beauty__subtitle {
      font-weight: 700;
      font-size: var(--vl-beauty-subtitle-size-d);
      line-height: 58px;
      max-width: 513px;
      flex: 0 1 513px;
    }

    #{{ section_dom_id }} .vl-beauty__bottom-text {
      flex: 1 1 auto;
      text-align: right;
      max-width: 703px;
      font-size: var(--vl-beauty-bottom-size-d);
    }

    #{{ section_dom_id }} .vl-beauty__photo {
      max-width: 1248px;
      margin: 0 auto;
    }
  }
</style>

<script>
  // Fade-in animation on scroll (single trigger per element)
  document.addEventListener('DOMContentLoaded', function() {
    const root = document.getElementById({{ section_dom_id | json }});
    if (!root) return;

    const animatedElements = root.querySelectorAll('[data-vl-beauty-animate]');
    if (!animatedElements || animatedElements.length === 0) return;

    // Respect reduced motion
    if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      animatedElements.forEach(el => el.classList.add('is-visible'));
      return;
    }

    if ('IntersectionObserver' in window) {
      const observerOptions = {
        root: null,
        rootMargin: '0px 0px -100px 0px',
        threshold: 0.1
      };

      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      animatedElements.forEach(el => observer.observe(el));
    } else {
      // Fallback for browsers without IntersectionObserver support
      animatedElements.forEach(el => el.classList.add('is-visible'));
    }
  });
</script>

{% schema %}
{
  "name": "⚡ Lumen Beauty",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "aria_label",
      "label": "Accessibility label",
      "default": "Beauty section"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Top heading",
      "default": "Beauty That Grows With You"
    },
    {
      "type": "text",
      "id": "paragraph_1",
      "label": "Paragraph 1",
      "default": "Effortlessly achieve nourished, healthy lashes and refreshed, radiant eyes with our expertly formulated solution."
    },
    {
      "type": "text",
      "id": "paragraph_2",
      "label": "Paragraph 2",
      "default": "Designed to deeply care for the delicate eye area, this product revitalizes your appearance, enhances natural beauty, and provides the nourishment your lashes need for strength and vitality."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "SHOP NOW"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Top product image"
    },
    {
      "type": "text",
      "id": "product_image_alt",
      "label": "Top product image alt text",
      "default": "Product image"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Bottom heading",
      "default": "Redefining what it means to age"
    },
    {
      "type": "text",
      "id": "bottom_text",
      "label": "Bottom body text",
      "default": "We know how frustrating it is to find products that actually work for thinning, dry, or changing skin. That is why we’ve created a selection specifically formulated to nourish your complexion, helping you embrace your authentic beauty with confidence and a natural glow."
    },
    {
      "type": "image_picker",
      "id": "bottom_photo",
      "label": "Bottom photo"
    },
    {
      "type": "image_picker",
      "id": "bg_texture_image",
      "label": "Background texture (decorative)"
    },
    {
      "type": "image_picker",
      "id": "bg_blur_image",
      "label": "Background blur (decorative)"
    },
    {
      "type": "header",
      "content": "Color controls"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color (solid)",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "background_gradient_start",
      "label": "Background gradient start",
      "default": "#fbf8f6"
    },
    {
      "type": "color",
      "id": "background_gradient_end",
      "label": "Background gradient end",
      "default": "#fbf8f6"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Top heading text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Top body text color",
      "default": "#4c4c4c"
    },
    {
      "type": "color",
      "id": "cta_text_color",
      "label": "Button text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Bottom heading text color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "bottom_text_color",
      "label": "Bottom body text color",
      "default": "#4c4c4c"
    },
    {
      "type": "header",
      "content": "Spacing controls"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "label": "Padding top - desktop",
      "min": 0,
      "max": 120,
