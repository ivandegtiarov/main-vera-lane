<div class="dr-faq">
  <div class="dr-faq__container">
    <h2 class="dr-faq__heading">{{ section.settings.heading }}</h2>
    <div class="dr-faq__list">
      {% for block in section.blocks %}
        <div class="dr-faq__item" {{ block.shopify_attributes }}>
          <input type="checkbox" id="dr-faq-{{ section.id }}-{{ forloop.index }}" class="dr-faq__checkbox">
          <label for="dr-faq-{{ section.id }}-{{ forloop.index }}" class="dr-faq__question">
            <span>{{ block.settings.question }}</span>
            <span class="dr-faq__icon">+</span>
          </label>
          <div class="dr-faq__answer">
            <div class="dr-faq__answer-inner">
              {{ block.settings.answer }}
            </div>
          </div>
        </div>
      {% endfor %}
    </div>
    {% if section.settings.disclosure_text != blank %}
      <div class="dr-faq__disclosure">
        {{ section.settings.disclosure_text }}
      </div>
    {% endif %}
  </div>
</div>

{% stylesheet %}
.dr-faq {
  background: #fff;
  padding: 48px 24px;
}

.dr-faq__container {
  max-width: 720px;
  margin: 0 auto;
}

.dr-faq__heading {
  font-family: Georgia, serif;
  font-size: 28px;
  text-align: center;
  color: #1a1a1a;
  margin: 0 0 32px;
  font-weight: normal;
}

.dr-faq__item {
  border-bottom: 1px solid #e5e5e5;
}

.dr-faq__checkbox {
  display: none;
}

.dr-faq__question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 18px 0;
  cursor: pointer;
  font-size: 16px;
  font-weight: 700;
  color: #1a1a1a;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
}

.dr-faq__icon {
  font-size: 20px;
  font-weight: 300;
  transition: transform 0.3s ease;
}

.dr-faq__checkbox:checked + .dr-faq__question .dr-faq__icon {
  transform: rotate(45deg);
}

.dr-faq__answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.4s ease;
}

.dr-faq__checkbox:checked ~ .dr-faq__answer {
  max-height: 500px;
}

.dr-faq__answer-inner {
  padding: 0 0 18px;
  font-size: 15px;
  line-height: 1.7;
  color: #666;
  font-family: -apple-system, BlinkMacSystemFont, sans-serif;
}

.dr-faq__disclosure {
  margin-top: 32px;
  font-size: 12px;
  color: #999;
  font-style: italic;
  text-align: center;
  line-height: 1.6;
}
{% endstylesheet %}

{% schema %}
{
  "name": "DR - FAQ",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "textarea",
      "id": "disclosure_text",
      "label": "Affiliate Disclosure Text",
      "default": "This article contains affiliate links. We may earn a small commission if you make a purchase through our links, at no additional cost to you."
    }
  ],
  "blocks": [
    {
      "type": "faq",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How does it work?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "The formula adapts to your unique skin tone upon application."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DR - FAQ",
      "blocks": [
        {
          "type": "faq",
          "settings": {
            "question": "How does the color-changing formula work?",
            "answer": "The formula contains micro-pigments that react with your skin's unique pH level and undertone, adapting to create a seamless match within 60 seconds of application."
          }
        },
        {
          "type": "faq",
          "settings": {
            "question": "Is there a money-back guarantee?",
            "answer": "Yes, Vera Lane offers a 30-day money-back guarantee. If you're not satisfied with the results, you can return the product for a full refund."
          }
        }
      ]
    }
  ]
}
{% endschema %}
