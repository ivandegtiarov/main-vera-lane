{% stylesheet %}
.ss-logos {
  background: #ffffff;
  padding: 27px 0;
  overflow: hidden;
  width: 100%;
}

@media (min-width: 750px) {
  .ss-logos {
    padding: 36px 0;
  }
}

.ss-logos__heading {
  font-family: "DM Sans", sans-serif;
  font-size: 11px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.15em;
  text-align: center;
  color: #888;
  margin: 0 0 16px;
}

.ss-logos__marquee {
  overflow: hidden;
  width: 100%;
}

.ss-logos__track {
  display: flex;
  align-items: center;
  gap: 48px;
  width: max-content;
  animation: marquee-scroll 20s linear infinite;
}

.ss-logos__item {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.ss-logos__item img {
  height: 40px;
  width: auto;
  object-fit: contain;
  filter: grayscale(100%);
  opacity: 0.7;
  transition: filter 0.3s, opacity 0.3s;
}

.ss-logos__item img:hover {
  filter: grayscale(0%);
  opacity: 1;
}

@keyframes marquee-scroll {
  0% {
    transform: translateX(0);
  }
  100% {
    transform: translateX(-50%);
  }
}
{% endstylesheet %}

