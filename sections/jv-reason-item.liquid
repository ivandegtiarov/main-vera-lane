{%- comment -%} ── JV - REASON ITEM ── {%- endcomment -%}
<div class="jv-reason-item jv-reason-item--{{ section.settings.image_position }}" {% if section.settings.section_id != blank %}id="{{ section.settings.section_id }}"{% endif %}>
  <div class="jv-reason-item__container">
    <div class="jv-reason-item__content">
      <h2 class="jv-reason-item__title">
        <span class="jv-reason-item__number">{{ section.settings.number }}.</span>
        {{ section.settings.title }}
      </h2>

      <div class="jv-reason-item__body">
        {{ section.settings.body_text }}
      </div>

      {%- if section.settings.badge_text != blank -%}
        <div class="jv-reason-item__badge" style="--badge-bg: {{ section.settings.badge_bg }}; --badge-text: {{ section.settings.badge_text_color }};">
          {%- if section.settings.badge_icon != blank -%}
            <span class="jv-reason-item__badge-icon">{{ section.settings.badge_icon }}</span>
          {%- endif -%}
          <span class="jv-reason-item__badge-label">{{ section.settings.badge_text }}</span>
        </div>
      {%- endif -%}

      {%- if section.settings.link_text != blank -%}
        {%- liquid
          if section.settings.link_type == 'anchor' and section.settings.link_anchor != blank
            assign link_href = '#' | append: section.settings.link_anchor
          else
            assign link_href = section.settings.link_url
          endif
        -%}
        {%- if link_href != blank -%}
          <a href="{{ link_href }}" class="jv-reason-item__link">
            {{ section.settings.link_text }}
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- if section.settings.image != blank -%}
      <figure class="jv-reason-item__figure">
        <img
          src="{{ section.settings.image | image_url: width: 500 }}"
          alt="{{ section.settings.image.alt | default: section.settings.title | escape }}"
          loading="lazy"
          class="jv-reason-item__image"
        >
      </figure>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
.jv-reason-item {
  background: #fff;
  padding-block: 2rem;
  border-block-end: 1px solid #f0f0f0;
}

.jv-reason-item__container {
  max-width: 680px;
  margin: 0 auto;
  padding-inline: 1.5rem;
  display: grid;
  gap: 1.5rem;
}

@media (min-width: 600px) {
  .jv-reason-item--left .jv-reason-item__container,
  .jv-reason-item--right .jv-reason-item__container {
    grid-template-columns: 1fr 1fr;
    align-items: start;
  }

  .jv-reason-item--right .jv-reason-item__figure {
    order: 2;
  }

  .jv-reason-item--right .jv-reason-item__content {
    order: 1;
  }

  .jv-reason-item--left .jv-reason-item__figure {
    order: 1;
  }

  .jv-reason-item--left .jv-reason-item__content {
    order: 2;
  }
}

.jv-reason-item__title {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 1.125rem;
  font-weight: 700;
  line-height: 1.3;
  color: #1a1a1a;
  margin: 0 0 1rem;
}

.jv-reason-item__number {
  color: #F5A623;
  font-weight: 800;
}

.jv-reason-item__body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.9375rem;
  line-height: 1.7;
  color: #444;
}

.jv-reason-item__body p {
  margin-bottom: 1rem;
}

.jv-reason-item__body p:last-child {
  margin-bottom: 0;
}

.jv-reason-item__body strong {
  font-weight: 700;
  color: #1a1a1a;
}

.jv-reason-item__badge {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--badge-bg, #F5A623);
  color: var(--badge-text, #1a1a1a);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.8125rem;
  font-weight: 600;
  padding: 0.5rem 1rem;
  border-radius: 999px;
  margin-top: 1.25rem;
}

.jv-reason-item__badge-icon {
  font-size: 1rem;
}

.jv-reason-item__badge-label {
  white-space: nowrap;
}

.jv-reason-item__link {
  display: inline-block;
  margin-top: 1rem;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
  font-size: 0.875rem;
  font-weight: 600;
  color: #6B5B2A;
  text-decoration: underline;
  text-underline-offset: 2px;
}

.jv-reason-item__link:hover {
  color: #1a1a1a;
}

.jv-reason-item__figure {
  margin: 0;
}

.jv-reason-item__image {
  width: 100%;
  height: auto;
  border-radius: 8px;
  object-fit: cover;
}

@media (min-width: 600px) {
  .jv-reason-item__title {
    font-size: 1.25rem;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "JV - Reason Item",
  "tag": "section",
  "class": "jv-section",
  "settings": [
    {
      "type": "text",
      "id": "section_id",
      "label": "Section ID",
      "info": "For anchor links (e.g., 'reason-1')"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "number",
      "label": "Item number",
      "default": "1"
    },
    {
      "type": "textarea",
      "id": "title",
      "label": "Title",
      "default": "NEW innovative guilt-free formula designed to kick your body into shape"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Body text",
      "default": "<p>Javvy created the perfect Iced Coffee that works for your body instead of against it. The combination of protein, caffeine, and three key functional ingredients are <strong>essential to feeling your best, recovering faster, and boosting your youthfulness.</strong></p>"
    },
    {
      "type": "header",
      "content": "Badge"
    },
    {
      "type": "text",
      "id": "badge_icon",
      "label": "Badge icon (emoji)",
      "default": "☕"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge text",
      "default": "Coffee, Reinvented."
    },
    {
      "type": "color",
      "id": "badge_bg",
      "label": "Badge background",
      "default": "#F5A623"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Badge text color",
      "default": "#1a1a1a"
    },
    {
      "type": "header",
      "content": "Link (optional)"
    },
    {
      "type": "text",
      "id": "link_text",
      "label": "Link text",
      "info": "e.g., 'Better Digestion Support Starts Here'"
    },
    {
      "type": "select",
      "id": "link_type",
      "label": "Link type",
      "options": [
        { "value": "anchor", "label": "Scroll to section on page" },
        { "value": "url", "label": "Link to URL" }
      ],
      "default": "anchor"
    },
    {
      "type": "text",
      "id": "link_anchor",
      "label": "Section ID to scroll to",
      "info": "Enter the Section ID from the target section (e.g., 'offer')"
    },
    {
      "type": "url",
      "id": "link_url",
      "label": "Link URL",
      "info": "Used when link type is 'Link to URL'"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" },
        { "value": "full", "label": "Full width below" }
      ],
      "default": "right"
    }
  ],
  "presets": [
    {
      "name": "JV - Reason Item",
      "category": "t:categories.reasons_listicle"
    }
  ]
}
{% endschema %}
