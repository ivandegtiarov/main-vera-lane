{%- comment -%}
  Lumen Product FAQ

  Reads FAQs from product metafields when available, otherwise uses section blocks.

  METAFIELD SETUP:
  1. Go to Settings > Custom data > Products > Add definition
  2. Name: FAQs
  3. Namespace and key: custom.faqs
  4. Type: JSON
  5. Example value:
     [
       {"question": "How do I apply this?", "answer": "Apply evenly to clean skin..."},
       {"question": "Is it waterproof?", "answer": "Yes, it's water-resistant..."}
     ]
{%- endcomment -%}

{%- liquid
  assign section_root_class = 'lumen-pfaq--' | append: section.id

  # Check for product metafield FAQs
  assign has_product_faqs = false
  assign product_faqs = null

  if product != blank and product.metafields.custom.faqs != blank
    assign product_faqs = product.metafields.custom.faqs.value
    if product_faqs.size > 0
      assign has_product_faqs = true
    endif
  endif

  # Determine data source
  assign use_metafield = has_product_faqs
  assign use_blocks = false
  if has_product_faqs == false and section.blocks.size > 0
    assign use_blocks = true
  endif
-%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400;1,700&family=Montserrat:wght@400;600;700&display=swap" rel="stylesheet">
<script defer src="https://cdn.jsdelivr.net/npm/@alpinejs/collapse@3.x.x/dist/cdn.min.js"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>

<style>
  #lumen-pfaq-{{ section.id }} {
    max-width: 1440px;
    margin: 0 auto;
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top_mobile }}px {{ section.settings.padding_horizontal_mobile }}px {{ section.settings.padding_bottom_mobile }}px;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-container {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-heading {
    font-family: "Playfair Display", Georgia, 'Times New Roman', Times, serif;
    font-style: italic;
    font-size: {{ section.settings.heading_font_size_mobile }}px;
    line-height: 1.2;
    color: {{ section.settings.heading_color }};
    font-weight: 400;
    margin: 0;
  }

  /* Fade-in animation */
  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-heading,
  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-item {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out;
  }

  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-heading.is-visible,
  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-item.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Staggered animation delays */
  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-heading {
    transition-delay: 0.1s;
  }

  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-item:nth-child(1) { transition-delay: 0.2s; }
  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-item:nth-child(2) { transition-delay: 0.3s; }
  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-item:nth-child(3) { transition-delay: 0.4s; }
  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-item:nth-child(4) { transition-delay: 0.5s; }
  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-item:nth-child(5) { transition-delay: 0.6s; }
  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-item:nth-child(6) { transition-delay: 0.7s; }
  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-item:nth-child(7) { transition-delay: 0.8s; }
  #lumen-pfaq-{{ section.id }}.lumen-pfaq--animate .pfaq-item:nth-child(8) { transition-delay: 0.9s; }

  #lumen-pfaq-{{ section.id }} .pfaq-list {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-item {
    border-bottom: 1px solid {{ section.settings.border_color }};
  }

  #lumen-pfaq-{{ section.id }} .pfaq-item:last-child {
    border-bottom: none;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-question {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 24px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: inherit;
    transition: all 0.3s ease;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-question:hover {
    opacity: 0.7;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-question-text {
    font-family: "Montserrat", -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    font-size: {{ section.settings.question_font_size_mobile }}px;
    font-weight: 600;
    color: {{ section.settings.question_color }};
    letter-spacing: 0.5px;
    text-transform: {{ section.settings.question_text_transform }};
    flex: 1;
    padding-right: 20px;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-icon {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    font-weight: 300;
    color: {{ section.settings.icon_color }};
    flex-shrink: 0;
    transition: transform 0.3s ease;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-answer {
    overflow: hidden;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-answer-content {
    font-family: "Montserrat", -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
    padding: 0 0 24px 0;
    font-size: {{ section.settings.answer_font_size_mobile }}px;
    line-height: 1.6;
    color: {{ section.settings.answer_color }};
  }

  /* Desktop layout - two columns */
  @media (min-width: 768px) {
    #lumen-pfaq-{{ section.id }} {
      padding: {{ section.settings.padding_top_desktop }}px {{ section.settings.padding_horizontal_desktop }}px {{ section.settings.padding_bottom_desktop }}px;
    }

    #lumen-pfaq-{{ section.id }} .pfaq-container {
      grid-template-columns: 35% 1fr;
      gap: 60px;
      align-items: start;
    }

    #lumen-pfaq-{{ section.id }} .pfaq-heading {
      font-size: {{ section.settings.heading_font_size_desktop }}px;
      {% if section.settings.sticky_heading %}
      position: sticky;
      top: 20px;
      {% endif %}
    }

    #lumen-pfaq-{{ section.id }} .pfaq-question-text {
      font-size: {{ section.settings.question_font_size_desktop }}px;
    }

    #lumen-pfaq-{{ section.id }} .pfaq-answer-content {
      font-size: {{ section.settings.answer_font_size_desktop }}px;
      padding-right: 40px;
    }
  }

  @media (min-width: 1024px) {
    #lumen-pfaq-{{ section.id }} .pfaq-container {
      gap: 80px;
    }
  }

  /* Empty state for editor */
  #lumen-pfaq-{{ section.id }} .pfaq-empty {
    text-align: center;
    padding: 40px 20px;
    color: #666;
    font-size: 14px;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-source-badge {
    display: inline-block;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 8px;
    border-radius: 4px;
    margin-bottom: 16px;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-source-badge--metafield {
    background-color: #e8f5e9;
    color: #2e7d32;
  }

  #lumen-pfaq-{{ section.id }} .pfaq-source-badge--blocks {
    background-color: #e3f2fd;
    color: #1565c0;
  }
</style>

<script>
document.addEventListener('DOMContentLoaded', function() {
  const section = document.getElementById('lumen-pfaq-{{ section.id }}');
  if (!section) return;

  const animationEnabled = section.getAttribute('data-animation-enabled') === 'true';

  // Fade-in animation on scroll
  if (animationEnabled && 'IntersectionObserver' in window) {
    const animatedElements = section.querySelectorAll('.pfaq-heading, .pfaq-item');

    const observerOptions = {
      root: null,
      rootMargin: '0px 0px -100px 0px',
      threshold: 0.1
    };

    const observer = new IntersectionObserver(function(entries) {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, observerOptions);

    animatedElements.forEach(element => {
      observer.observe(element);
    });
  } else if (animationEnabled) {
    const animatedElements = section.querySelectorAll('.pfaq-heading, .pfaq-item');
    animatedElements.forEach(element => {
      element.classList.add('is-visible');
    });
  }
});
</script>

<div id="lumen-pfaq-{{ section.id }}" class="pfaq-section{% if section.settings.enable_animation %} lumen-pfaq--animate{% endif %}" data-animation-enabled="{{ section.settings.enable_animation }}">
  <div class="pfaq-container">
    {% if section.settings.main_heading != blank %}
      <h2 class="pfaq-heading">{{ section.settings.main_heading }}</h2>
    {% endif %}

    <div class="pfaq-list" x-data="{ activeItem: {{ section.settings.first_item_open | default: 0 }} }">
      {%- if use_metafield -%}
        {%- comment -%} Render FAQs from product metafield {%- endcomment -%}
        {% if request.design_mode %}
          <span class="pfaq-source-badge pfaq-source-badge--metafield">Source: Product Metafield</span>
        {% endif %}

        {% for faq in product_faqs %}
          <div class="pfaq-item">
            <button
              class="pfaq-question"
              @click="activeItem = activeItem === {{ forloop.index0 }} ? null : {{ forloop.index0 }}"
              :aria-expanded="activeItem === {{ forloop.index0 }}"
            >
              <span class="pfaq-question-text">{{ faq.question }}</span>
              <span class="pfaq-icon" x-text="activeItem === {{ forloop.index0 }} ? '−' : '+'"></span>
            </button>
            <div
              class="pfaq-answer"
              x-show="activeItem === {{ forloop.index0 }}"
              x-collapse
            >
              <div class="pfaq-answer-content">
                {{ faq.answer }}
              </div>
            </div>
          </div>
        {% endfor %}

      {%- elsif use_blocks -%}
        {%- comment -%} Render FAQs from section blocks (fallback) {%- endcomment -%}
        {% if request.design_mode %}
          <span class="pfaq-source-badge pfaq-source-badge--blocks">Source: Section Blocks</span>
        {% endif %}

        {% for block in section.blocks %}
          <div class="pfaq-item" {{ block.shopify_attributes }}>
            <button
              class="pfaq-question"
              @click="activeItem = activeItem === {{ forloop.index0 }} ? null : {{ forloop.index0 }}"
              :aria-expanded="activeItem === {{ forloop.index0 }}"
            >
              <span class="pfaq-question-text">{{ block.settings.question }}</span>
              <span class="pfaq-icon" x-text="activeItem === {{ forloop.index0 }} ? '−' : '+'"></span>
            </button>
            <div
              class="pfaq-answer"
              x-show="activeItem === {{ forloop.index0 }}"
              x-collapse
            >
              <div class="pfaq-answer-content">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        {% endfor %}

      {%- else -%}
        {%- comment -%} No FAQs found - show helper message in editor {%- endcomment -%}
        {% if request.design_mode %}
          <div class="pfaq-empty">
            <p><strong>No FAQs found.</strong></p>
            <p>Add FAQs via:</p>
            <ol style="text-align: left; display: inline-block;">
              <li>Product metafield: <code>custom.faqs</code> (JSON array)</li>
              <li>Or add FAQ blocks below</li>
            </ol>
          </div>
        {% endif %}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "⚡Product FAQ",
  "tag": "section",
  "class": "lumen-product-faq-section",
  "settings": [
    {
      "type": "paragraph",
      "content": "This section reads FAQs from the product's custom.faqs metafield when available. If no metafield exists, it falls back to section blocks."
    },
    {
      "type": "text",
      "id": "section_label",
      "label": "Section Label",
      "default": "Product FAQ"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "header",
      "content": "Layout Settings"
    },
    {
      "type": "checkbox",
      "id": "sticky_heading",
      "label": "Sticky Heading (Desktop)",
      "default": true,
      "info": "Makes the heading stick to the top when scrolling on desktop"
    },
    {
      "type": "number",
      "id": "first_item_open",
      "label": "First Item Open by Default",
      "default": 0,
      "info": "Enter 0 for first item, 1 for second, etc. Enter -1 for all closed."
    },
    {
      "type": "header",
      "content": "Animation"
    },
    {
      "type": "checkbox",
      "id": "enable_animation",
      "label": "Enable fade-in animation",
      "info": "Elements will fade in when scrolled into view",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "question_color",
      "label": "Question Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "answer_color",
      "label": "Answer Color",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "icon_color",
      "label": "Icon Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border Color",
      "default": "#e5e5e5"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "min": 24,
      "max": 80,
      "step": 2,
      "unit": "px",
      "label": "Heading Font Size (Mobile)",
      "default": 40
    },
    {
      "type": "range",
      "id": "heading_font_size_desktop",
      "min": 24,
      "max": 120,
      "step": 2,
      "unit": "px",
      "label": "Heading Font Size (Desktop)",
      "default": 64
    },
    {
      "type": "range",
      "id": "question_font_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Question Font Size (Mobile)",
      "default": 16
    },
    {
      "type": "range",
      "id": "question_font_size_desktop",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Question Font Size (Desktop)",
      "default": 18
    },
    {
      "type": "select",
      "id": "question_text_transform",
      "label": "Question Text Transform",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "uppercase", "label": "Uppercase" },
        { "value": "lowercase", "label": "Lowercase" },
        { "value": "capitalize", "label": "Capitalize" }
      ],
      "default": "uppercase"
    },
    {
      "type": "range",
      "id": "answer_font_size_mobile",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Answer Font Size (Mobile)",
      "default": 16
    },
    {
      "type": "range",
      "id": "answer_font_size_desktop",
      "min": 12,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Answer Font Size (Desktop)",
      "default": 16
    },
    {
      "type": "header",
      "content": "Spacing - Mobile"
    },
    {
      "type": "range",
      "id": "padding_top_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom_mobile",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal_mobile",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding Horizontal",
      "default": 24
    },
    {
      "type": "header",
      "content": "Spacing - Desktop"
    },
    {
      "type": "range",
      "id": "padding_top_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_bottom_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding_horizontal_desktop",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Horizontal",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item (Fallback)",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "Lorem ipsum dolor sit amet?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Answer",
          "default": "Nunc imperdiet posuere tempus. Aenean dictum congue nulla, eu dapibus ipsum tincidunt in."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "⚡Product FAQ",
      "settings": {
        "enable_animation": true
      },
      "blocks": []
    }
  ]
}
{% endschema %}
