<div class="dr-intro">
  <div class="dr-intro__body">
    {{ section.settings.body }}
  </div>
</div>

{% stylesheet %}
.dr-intro {
  padding: 0 24px 24px;
}

.dr-intro__body {
  max-width: 700px;
  margin: 0 auto;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  font-size: 16px;
  line-height: 1.7;
  color: #444;
  text-align: left;
}

.dr-intro__body p {
  margin: 0 0 16px;
}

.dr-intro__body a {
  color: #4A90D9;
  text-decoration: underline;
}

.dr-intro__body strong,
.dr-intro__body b {
  font-weight: 700;
  color: #333;
}

.dr-intro__body ul {
  padding-left: 24px;
  margin: 0 0 16px;
  list-style-type: disc;
}

.dr-intro__body li {
  margin-bottom: 8px;
}
{% endstylesheet %}

{% schema %}
{
  "name": "DR - Intro Text",
  "settings": [
    {
      "type": "richtext",
      "id": "body",
      "label": "Body Text"
    }
  ],
  "presets": [
    {
      "name": "DR - Intro Text"
    }
  ]
}
{% endschema %}
