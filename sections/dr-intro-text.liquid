<div class="dr-intro">
  <div class="dr-intro__body">
    {{ section.settings.body }}
  </div>
</div>

{% stylesheet %}
.dr-intro {
  background: #ffffff;
  padding: 32px 24px;
}

.dr-intro__body {
  max-width: 680px;
  margin: 0 auto;
  font-family: Georgia, serif;
  font-size: 17px;
  line-height: 1.8;
  color: #333;
}

.dr-intro__body p {
  margin-bottom: 24px;
}

.dr-intro__body p:first-of-type::first-letter {
  float: left;
  font-family: Georgia, serif;
  font-size: 3.5em;
  font-weight: bold;
  color: #222;
  line-height: 0.8;
  margin-right: 8px;
}

.dr-intro__body a {
  color: #333;
  text-decoration: underline;
}
{% endstylesheet %}

{% schema %}
{
  "name": "DR - Intro Text",
  "settings": [
    {
      "type": "richtext",
      "id": "body",
      "label": "Body Text"
    }
  ],
  "presets": [
    {
      "name": "DR - Intro Text"
    }
  ]
}
{% endschema %}
