<div class="ss-gift-reasons">
  <div class="ss-gift-reasons__container">
    <div class="ss-gift-reasons__text">
      <h2 class="ss-gift-reasons__heading">3 Reasons Why Star Story Book Makes the Most Thoughtful Gift</h2>
      <ol class="ss-gift-reasons__list">
        <li class="ss-gift-reasons__item">
          <span class="ss-gift-reasons__number">1</span>
          <div class="ss-gift-reasons__item-content">
            <strong class="ss-gift-reasons__item-title">It's Deeply Personal</strong>
            <p class="ss-gift-reasons__item-desc">Unlike generic gifts, a Star Story book is crafted from their unique birth chart, making it a one-of-a-kind treasure.</p>
          </div>
        </li>
        <li class="ss-gift-reasons__item">
          <span class="ss-gift-reasons__number">2</span>
          <div class="ss-gift-reasons__item-content">
            <strong class="ss-gift-reasons__item-title">It Shows You Care</strong>
            <p class="ss-gift-reasons__item-desc">Giving someone their personalized astrology book shows you've put thought into understanding what makes them special.</p>
          </div>
        </li>
        <li class="ss-gift-reasons__item">
          <span class="ss-gift-reasons__number">3</span>
          <div class="ss-gift-reasons__item-content">
            <strong class="ss-gift-reasons__item-title">It Lasts Forever</strong>
            <p class="ss-gift-reasons__item-desc">A beautifully printed book they'll return to again and again, discovering new insights about themselves.</p>
          </div>
        </li>
      </ol>
      <a href="#" class="ss-gift-reasons__cta">Order Now and Gift the Stars</a>
    </div>
    <div class="ss-gift-reasons__image">
      <img
        src="{{ 'ss-group-299.png' | asset_url }}"
        alt="Star Story personalized astrology books"
        class="ss-gift-reasons__img"
        loading="lazy"
      >
    </div>
  </div>
</div>

{% stylesheet %}
.ss-gift-reasons {
  background-color: #1A3050;
  padding: 80px 20px;
}

.ss-gift-reasons__container {
  max-width: 1200px;
  margin: 0 auto;
  display: flex;
  align-items: center;
  gap: 60px;
}

.ss-gift-reasons__image {
  flex: 1;
  display: flex;
  justify-content: center;
}

.ss-gift-reasons__img {
  max-width: 450px;
  width: 100%;
  height: auto;
  border-radius: 8px;
}

.ss-gift-reasons__text {
  flex: 1;
}

.ss-gift-reasons__heading {
  font-family: "Noto Serif", serif;
  font-size: 32px;
  color: #ffffff;
  margin: 0 0 36px;
  line-height: 1.3;
}

.ss-gift-reasons__list {
  list-style: none;
  padding: 0;
  margin: 0 0 40px;
  display: flex;
  flex-direction: column;
  gap: 28px;
}

.ss-gift-reasons__item {
  display: flex;
  align-items: flex-start;
  gap: 16px;
}

.ss-gift-reasons__number {
  flex-shrink: 0;
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 2px solid #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: "Noto Serif", serif;
  font-size: 16px;
  color: #ffffff;
  font-weight: 700;
  margin-top: 2px;
}

.ss-gift-reasons__item-title {
  font-family: "DM Sans", sans-serif;
  font-size: 15px;
  color: #ffffff;
  display: block;
  margin-bottom: 4px;
}

.ss-gift-reasons__item-desc {
  font-family: "DM Sans", sans-serif;
  font-size: 15px;
  color: #ffffff;
  margin: 0;
  line-height: 1.6;
  opacity: 0.85;
}

.ss-gift-reasons__cta {
  display: inline-block;
  background-color: #ffffff;
  color: #1A3050;
  font-family: "DM Sans", sans-serif;
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 1px;
  padding: 14px 32px;
  border-radius: 50px;
  text-decoration: none;
  transition: opacity 0.2s ease;
}

.ss-gift-reasons__cta:hover {
  opacity: 0.9;
}

@media (max-width: 768px) {
  .ss-gift-reasons {
    padding: 60px 20px;
  }

  .ss-gift-reasons__container {
    flex-direction: column;
    gap: 40px;
  }

  .ss-gift-reasons__image {
    order: -1;
  }

  .ss-gift-reasons__img {
    max-width: 350px;
  }

  .ss-gift-reasons__heading {
    font-size: 26px;
    text-align: center;
  }

  .ss-gift-reasons__cta {
    display: block;
    text-align: center;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "SS - Gift Reasons",
  "settings": []
}
{% endschema %}
