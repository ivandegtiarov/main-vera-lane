<section class="dr-rankings">
  <div class="dr-rankings__container">
    <div class="dr-rankings__badges">
      <span class="dr-rankings__badge dr-rankings__badge--winner">★ Winner ★</span>
      <span class="dr-rankings__badge dr-rankings__badge--runner-up">Runner Up</span>
    </div>
    <div class="dr-rankings__scroll">
      {% for block in section.blocks %}
        <div class="dr-rankings__card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            <div class="dr-rankings__image-wrap">
              {{ block.settings.image | image_url: width: 240 | image_tag: class: 'dr-rankings__image', loading: 'lazy' }}
            </div>
          {% elsif block.settings.image_asset != blank %}
            <div class="dr-rankings__image-wrap">
              <img class="dr-rankings__image" src="{{ block.settings.image_asset | asset_url }}" loading="lazy" alt="{{ block.settings.product_name }}">
            </div>
          {% endif %}
          <div class="dr-rankings__name">{{ block.settings.product_name }}</div>
          <div class="dr-rankings__stars">
            {% assign rating_float = block.settings.rating | plus: 0 %}
            {% assign full_stars = rating_float | floor %}
            {% for i in (1..full_stars) %}★{% endfor %}{% if full_stars < 5 %}{% assign empty = 5 | minus: full_stars %}{% for i in (1..empty) %}☆{% endfor %}{% endif %}
          </div>
          <div class="dr-rankings__rating-number">{{ block.settings.rating }}</div>
          {% if block.settings.anchor_id != blank %}
            <a href="#{{ block.settings.anchor_id }}" class="dr-rankings__link">See details</a>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
.dr-rankings {
  background: #fff;
  padding: 24px;
}

.dr-rankings__container {
  max-width: 700px;
  margin: 0 auto;
}

.dr-rankings__badges {
  display: flex;
  gap: 8px;
  margin-bottom: 16px;
}

.dr-rankings__badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 700;
  padding: 4px 12px;
  border-radius: 999px;
  line-height: 1.4;
}

.dr-rankings__badge--winner {
  background: #FFD700;
  color: #333;
}

.dr-rankings__badge--runner-up {
  background: #4A90D9;
  color: #fff;
}

.dr-rankings__scroll {
  display: flex;
  gap: 12px;
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  padding-bottom: 8px;
}

.dr-rankings__scroll::-webkit-scrollbar {
  height: 4px;
}

.dr-rankings__scroll::-webkit-scrollbar-thumb {
  background: #ccc;
  border-radius: 2px;
}

.dr-rankings__card {
  flex: 0 0 140px;
  width: 140px;
  text-align: center;
}

.dr-rankings__image-wrap {
  width: 100%;
  height: 120px;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 8px;
}

.dr-rankings__image {
  max-width: 100%;
  max-height: 120px;
  object-fit: contain;
}

.dr-rankings__name {
  font-size: 13px;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.3;
  margin-bottom: 4px;
}

.dr-rankings__stars {
  color: #FFB800;
  font-size: 13px;
  letter-spacing: 1px;
  margin-bottom: 2px;
}

.dr-rankings__rating-number {
  font-size: 12px;
  color: #666;
  margin-bottom: 6px;
}

.dr-rankings__link {
  font-size: 12px;
  color: #4A90D9;
  text-decoration: none;
}

.dr-rankings__link:hover {
  text-decoration: underline;
}
{% endstylesheet %}

{% schema %}
{
  "name": "DR - Rankings Bar",
  "settings": [],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        {
          "type": "text",
          "id": "product_name",
          "label": "Product Name",
          "default": "Color Changing Foundation"
        },
        {
          "type": "text",
          "id": "rating",
          "label": "Rating (e.g. 4.9)",
          "default": "4.9"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product Image"
        },
        {
          "type": "text",
          "id": "image_asset",
          "label": "Image asset filename",
          "info": "Fallback if no image uploaded. e.g. dr-product-vera-lane.jpg"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge Text (optional)"
        },
        {
          "type": "text",
          "id": "anchor_id",
          "label": "Anchor ID (for See details link)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "DR - Rankings Bar",
      "blocks": [
        {
          "type": "product",
          "settings": {
            "product_name": "Color Changing Foundation",
            "rating": "4.9",
            "badge_text": "Winner",
            "anchor_id": "review-1"
          }
        },
        {
          "type": "product",
          "settings": {
            "product_name": "Adaptive Tint SPF",
            "rating": "4.5",
            "badge_text": "Runner Up",
            "anchor_id": "review-2"
          }
        },
        {
          "type": "product",
          "settings": {
            "product_name": "Smart Shade Serum",
            "rating": "4.2",
            "badge_text": "",
            "anchor_id": "review-3"
          }
        }
      ]
    }
  ]
}
{% endschema %}
