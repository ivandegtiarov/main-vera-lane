{% stylesheet %}
.ss-before-after {
  background: #ffffff;
  padding: 80px 20px;
}

.ss-before-after__container {
  max-width: 1000px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
}

.ss-before-after__column {
  padding: 30px;
  border-radius: 12px;
}

.ss-before-after__column--before {
  background: rgba(219, 24, 24, 0.05);
}

.ss-before-after__column--after {
  background: rgba(134, 162, 50, 0.05);
}

.ss-before-after__heading {
  font-family: "Noto Serif", serif;
  font-size: 24px;
  font-weight: 700;
  margin: 0 0 24px 0;
}

.ss-before-after__heading--before {
  color: #DB1818;
}

.ss-before-after__heading--after {
  color: #86A232;
}

.ss-before-after__list {
  list-style: none;
  margin: 0;
  padding: 0;
  display: flex;
  flex-direction: column;
  gap: 16px;
}

.ss-before-after__item {
  display: flex;
  flex-direction: row;
  align-items: flex-start;
  gap: 12px;
}

.ss-before-after__icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 20px;
  height: 20px;
  margin-top: 1px;
}

.ss-before-after__text {
  font-family: "DM Sans", sans-serif;
  font-size: 15px;
  color: #292929;
  line-height: 1.4;
}

@media screen and (max-width: 749px) {
  .ss-before-after__container {
    grid-template-columns: 1fr;
  }
}
{% endstylesheet %}

