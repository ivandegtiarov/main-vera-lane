<style>
.ws-before-after-shopify-section {
    background: linear-gradient(135deg, #2a1a3a 0%, #1a2a4a 50%, #0a2030 100%);
    background-repeat: no-repeat;
    background-position: center center;
    background-size: cover;
}
.ws-before-after-inner.before {
    background-repeat: no-repeat;
    padding-top: 75px;
    padding-bottom: 135px;
    background-position: right bottom;
}
.ws-before-after-inner h1 {
    margin-bottom: 50px;
}
.ws-before-after-inner.after {
    background-repeat: no-repeat;
    padding-top: 75px;
    padding-bottom: 135px;
    background-position: left bottom;
    background-color: rgba(240, 235, 225, 0.95);
}
.ws-before-after-container-item.after {
    text-align: right;
}
.ws-before-after-container {
    display: flex;
    justify-content: center;
    margin: 0 auto;
    max-width: 1470px;
    left: -8px;
    position: relative;
}
.ws-before-after-header {
    color: #fff;
    text-align: left;
    font-feature-settings: 'clig' off, 'liga' off;
    font-family: "DM Sans";
    font-size: 16px;
    font-style: normal;
    font-weight: 700;
    line-height: 27px;
    letter-spacing: normal;
}
.ws-before-after-inner {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-direction: column;
    width: 100%;
    gap: 6px;
}
.ws-before-after-container-item {
    width: 100%;
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 18px;
    margin-bottom: 6px;
}
.ws-before-after-container-item svg {
    flex-shrink: 0;
}
.ws-before-after-inner.before .ws-before-after-container-item {
    justify-content: flex-start;
}
.ws-before-after-inner.after .ws-before-after-container-item {
    justify-content: flex-end;
}
@media screen and (max-width: 990px) {
    .ws-before-after-shopify-section {
        padding-top: 0;
    }
    .ws-before-after-container {
        flex-direction: column;
    }
    .ws-before-after-inner.before {
        background-image: unset;
        padding-top: 0;
        padding-bottom: 0;
    }
    .ws-before-after-inner.after {
        background-image: unset;
        padding-top: 10px;
        padding-bottom: 40px;
    }
    .ws-before-after-container-item.after {
        flex-direction: row-reverse;
    }
    .ws-before-after-container-item {
        gap: 10px;
    }
    .ws-before-after-inner--wrapper {
        padding-left: 15px;
    }
}
</style>

