<div class="vl-step-visual" style="
  --step-bg: {{ section.settings.bg_color }};
  --heading-color: {{ section.settings.heading_color }};
  --label-color: {{ section.settings.label_color }};
  --title-color: {{ section.settings.title_color }};
  --text-color: {{ section.settings.text_color }};
  --arrow-bg: {{ section.settings.arrow_bg_color }};
  --arrow-color: {{ section.settings.arrow_color }};
  --arrow-active-bg: {{ section.settings.arrow_active_bg_color }};
  --arrow-active-color: {{ section.settings.arrow_active_color }};
">
  <div class="vl-step-visual__inner">
    <h2 class="vl-step-visual__heading">{{ section.settings.heading }}</h2>

    <div class="vl-step-visual__carousel" data-step-carousel>
      {% for block in section.blocks %}
        <div class="vl-step-visual__slide {% if forloop.first %}is-active{% endif %}" data-slide="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
          <div class="vl-step-visual__media">
            {% if block.settings.image != blank %}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                alt="{{ block.settings.title }}"
                class="vl-step-visual__image"
                loading="lazy"
              >
            {% else %}
              <div class="vl-step-visual__placeholder">
                {{ 'image' | placeholder_svg_tag: 'vl-step-visual__placeholder-svg' }}
              </div>
            {% endif %}
          </div>
          <div class="vl-step-visual__content">
            <span class="vl-step-visual__label">STEP {{ forloop.index }}</span>
            <h3 class="vl-step-visual__title">{{ block.settings.title }}</h3>
            <p class="vl-step-visual__text">{{ block.settings.text }}</p>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if section.blocks.size > 1 %}
      <div class="vl-step-visual__nav">
        <button class="vl-step-visual__arrow vl-step-visual__arrow--prev" data-prev aria-label="Previous step">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M15 18l-6-6 6-6"/>
          </svg>
        </button>
        <button class="vl-step-visual__arrow vl-step-visual__arrow--next is-active" data-next aria-label="Next step">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M9 18l6-6-6-6"/>
          </svg>
        </button>
      </div>
    {% endif %}
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.querySelector('.vl-step-visual');
    if (!section) return;

    const slides = section.querySelectorAll('[data-slide]');
    const prevBtn = section.querySelector('[data-prev]');
    const nextBtn = section.querySelector('[data-next]');

    if (slides.length <= 1) return;

    let currentIndex = 0;

    function updateSlides() {
      slides.forEach((slide, i) => {
        slide.classList.toggle('is-active', i === currentIndex);
      });

      if (prevBtn && nextBtn) {
        prevBtn.classList.toggle('is-active', currentIndex > 0);
        nextBtn.classList.toggle('is-active', currentIndex < slides.length - 1);
      }
    }

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        if (currentIndex > 0) {
          currentIndex--;
          updateSlides();
        }
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', () => {
        if (currentIndex < slides.length - 1) {
          currentIndex++;
          updateSlides();
        }
      });
    }
  });
</script>

{% stylesheet %}
  .vl-step-visual {
    background-color: var(--step-bg, #ffffff);
    padding: 40px 0;
  }

  .vl-step-visual__inner {
    max-width: 402px;
    margin: 0 auto;
    padding: 0 16px;
  }

  .vl-step-visual__heading {
    font-family: var(--font-heading--family, serif);
    font-size: 24px;
    font-weight: 400;
    color: var(--heading-color, #000000);
    margin: 0 0 20px;
  }

  .vl-step-visual__carousel {
    position: relative;
  }

  .vl-step-visual__slide {
    display: none;
  }

  .vl-step-visual__slide.is-active {
    display: block;
  }

  .vl-step-visual__media {
    border-radius: 12px;
    overflow: hidden;
    margin-bottom: 16px;
  }

  .vl-step-visual__image {
    width: 100%;
    height: auto;
    display: block;
    aspect-ratio: 1 / 1;
    object-fit: cover;
  }

  .vl-step-visual__placeholder {
    aspect-ratio: 1 / 1;
    background-color: #E5E5E5;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vl-step-visual__placeholder-svg {
    width: 30%;
    height: auto;
    opacity: 0.5;
  }

  .vl-step-visual__content {
    padding: 0;
  }

  .vl-step-visual__label {
    display: inline-block;
    font-size: 12px;
    font-weight: 700;
    color: var(--label-color, #5C1A33);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }

  .vl-step-visual__title {
    font-family: var(--font-heading--family, serif);
    font-size: 18px;
    font-weight: 600;
    color: var(--title-color, #000000);
    margin: 0 0 8px;
  }

  .vl-step-visual__text {
    font-size: 14px;
    line-height: 1.6;
    color: var(--text-color, #666666);
    margin: 0;
  }

  .vl-step-visual__nav {
    display: flex;
    gap: 8px;
    margin-top: 16px;
  }

  .vl-step-visual__arrow {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background-color: var(--arrow-bg, #F5F5F5);
    color: var(--arrow-color, #CCCCCC);
    border: none;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .vl-step-visual__arrow.is-active {
    background-color: var(--arrow-active-bg, #F7A81B);
    color: var(--arrow-active-color, #000000);
  }

  .vl-step-visual__arrow:not(.is-active) {
    cursor: default;
  }
{% endstylesheet %}

