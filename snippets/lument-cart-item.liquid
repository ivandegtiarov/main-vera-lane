{%- doc -%}
  Renders a single cart item with Lument design styling.

  @param {object} item - The cart line item object
  @param {number} line_index - The index of the cart item
  @param {boolean} [can_update_quantity] - Whether quantity can be updated (defaults to true)
  @param {boolean} [can_remove] - Whether item can be removed (defaults to true)
{%- enddoc -%}

{% liquid
  assign can_update_quantity = can_update_quantity | default: true, allow_false: true
  assign can_remove = can_remove | default: true, allow_false: true
  
  # Check if item has bundle_id property with value 'vera_bundle' to disable quantity increase
  assign has_vera_bundle = false
  for property in item.properties
    if property.first == 'bundle_id' and property.last == 'vera_bundle'
      assign has_vera_bundle = true
      break
    endif
  endfor
  
  # Check if item has bundle_id property with value 'vera2_bundle' to disable quantity increase
  assign has_vera2_bundle = false
  for property in item.properties
    if property.first == 'bundle_id' and property.last == 'vera2_bundle'
      assign has_vera2_bundle = true
      break
    endif
  endfor
  
  # Check if item is a free gift
  assign is_free_gift = false
  for property in item.properties
    if property.first == '_is_free_gift' and property.last == 'true'
      assign is_free_gift = true
      assign can_update_quantity = false
      assign can_remove = false
      break
    endif
  endfor
  
  # Determine minus button state based on quantity
  assign is_quantity_one = false
  if item.quantity == 1
    assign is_quantity_one = true
  endif
%}

<div 
  class="lument-cart-item"
  role="row"
  ref="cartItemRows[]"
  data-parent-key="{{ item.parent_relationship.parent.key }}"
  data-key="{{ item.key }}"
>
  {%- comment -%} Product Image {%- endcomment -%}
  <div class="lument-cart-item__image">
    {% if item.image %}
      <a href="{{ item.url }}" class="lument-cart-item__image-link">
        {{- item.image | image_url: width: 208 | image_tag: loading: 'lazy', class: 'lument-cart-item__img' -}}
      </a>
    {% endif %}
  </div>

  {%- comment -%} Product Details {%- endcomment -%}
  <div class="lument-cart-item__content">
    {%- comment -%} Title and Price {%- endcomment -%}
    <div class="lument-cart-item__header">
      <div class="lument-cart-item__title-wrapper">
        <h3 class="lument-cart-item__title">
          <a href="{{ item.url }}">{{ item.product.title }}</a>
        </h3>
        {% if is_free_gift %}
          <span class="lument-cart-item__free-badge">FREE GIFT 🎁</span>
        {% endif %}
      </div>

      <div class="lument-cart-item__price-wrapper">
        {% if is_free_gift %}
          <span class="lument-cart-item__price lument-cart-item__price--free">FREE</span>
        {% elsif item.original_price != item.final_price %}
          {%- comment -%} Sale price {%- endcomment -%}
          <span class="lument-cart-item__price">{{ item.final_price | money }}</span>
          <s class="lument-cart-item__compare-price">
            {% if item.variant.compare_at_price > item.original_price %}
              {{ item.variant.compare_at_price | money }}
            {% else %}
              {{ item.original_price | money }}
            {% endif %}
          </s>
        {% else %}
          {%- comment -%} Regular price {%- endcomment -%}
          <span class="lument-cart-item__price">{{ item.original_price | money }}</span>
          {% if item.variant.compare_at_price > item.original_price %}
            <s class="lument-cart-item__compare-price">{{ item.variant.compare_at_price | money }}</s>
          {% endif %}
        {% endif %}
      </div>
    </div>

    {%- comment -%} Variant Information {%- endcomment -%}
    {%- if item.product.has_only_default_variant == false and item.item_components.size == 0 -%}
      <div class="lument-cart-item__variants">
        {%- for option in item.options_with_values -%}
          <span class="lument-cart-item__variant">{{ option.value }}</span>
          {%- unless forloop.last -%}, {% endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Discount Information {%- endcomment -%}
    {%- if item.line_level_discount_allocations.size > 0 -%}
      <div class="lument-cart-item__discounts">
        {%- for discount_allocation in item.line_level_discount_allocations -%}
          <div class="lument-cart-item__discount">
            <svg class="lument-cart-item__discount-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M14 5L6 13L2 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span class="lument-cart-item__discount-text">
              {{ discount_allocation.discount_application.title }} (-{{ discount_allocation.amount | money }})
            </span>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} Quantity Selector {%- endcomment -%}
    <div class="lument-cart-item__quantity-wrapper">
      <quantity-selector-component
        class="lument-cart-item__quantity-selector"
        ref="quantitySelectors[]"
      >
        <button
          class="lument-cart-item__qty-button lument-cart-item__qty-button--minus{% if is_quantity_one %} lument-cart-item__qty-button--grey{% endif %}"
          type="button"
          name="minus"
          on:click="/decreaseQuantity"
          ref="quantityButtons[]"
          aria-label="{{ 'accessibility.decrease_quantity' | t }}"
          {% if can_update_quantity == false %}disabled{% endif %}
        >
          <span class="lument-cart-item__qty-icon lument-cart-item__qty-icon--minus{% if is_free_gift %} lument-cart-item__qty-icon--free-gift{% elsif is_quantity_one %} lument-cart-item__qty-icon--grey{% endif %}"></span>
        </button>

        <input
          type="number"
          name="updates[]"
          value="{{ item.quantity }}"
          min="0"
          on:blur="/setQuantity"
          on:focus="/selectInputValue"
          ref="quantityInput"
          class="lument-cart-item__qty-input"
          aria-label="{{ 'accessibility.quantity' | t }}"
          data-cart-line="{{ line_index | plus: 1 }}"
          {% if item.variant.quantity_rule.max %}max="{{ item.variant.quantity_rule.max }}"{% endif %}
          step="{{ item.variant.quantity_rule.increment | default: 1 }}"
          {% if can_update_quantity == false or item.variant.available == false %}disabled{% endif %}
        >

        <button
          class="lument-cart-item__qty-button lument-cart-item__qty-button--plus"
          type="button"
          name="plus"
          on:click="/increaseQuantity"
          ref="quantityButtons[]"
          aria-label="{{ 'accessibility.increase_quantity' | t }}"
          {% if can_update_quantity == false or has_vera_bundle or has_vera2_bundle %}disabled{% endif %}
        >
          <span class="lument-cart-item__qty-icon lument-cart-item__qty-icon--plus{% if is_free_gift %} lument-cart-item__qty-icon--free-gift{% elsif can_update_quantity == false %} lument-cart-item__qty-icon--plus-grey{% endif %}"></span>
        </button>
      </quantity-selector-component>

      {%- comment -%} Remove Button {%- endcomment -%}
      <button
        class="lument-cart-item__remove"
        type="button"
        aria-label="{{ 'accessibility.remove_item' | t: title: item.title | escape }}"
        on:click="/onLineItemRemove/{{ line_index | plus: 1 }}"
        {% if can_remove == false %}hidden{% endif %}
      >
        {{- 'icon-delete.svg' | inline_asset_content -}}
      </button>
    </div>

    {%- comment -%} Error Container {%- endcomment -%}
    <div
      class="lument-cart-item__error hidden"
      role="alert"
      ref="cartItemErrorContainer-{{ line_index | plus: 1 }}"
    >
      <span class="svg-wrapper">
        {{- 'icon-error.svg' | inline_asset_content -}}
      </span>
      <small
        class="lument-cart-item__error-text"
        ref="cartItemError-{{ line_index | plus: 1 }}"
      ></small>
    </div>
  </div>
</div>

{% stylesheet %}
  .lument-cart-item {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 20px;
    padding: 20px;
    background-color: #FBF8F6;
    border-bottom: 1px solid #E1DCD8;
    width: 100%;
  }

  .lument-cart-item__image {
    flex-shrink: 0;
    width: 104px;
    height: 104px;
  }

  .lument-cart-item__image-link {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 8px;
    border: 1px solid #E1DCD8;
    overflow: hidden;
  }

  .lument-cart-item__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .lument-cart-item__content {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 16px;
    min-width: 0;
  }

  .lument-cart-item__header {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .lument-cart-item__title-wrapper {
    flex: 1;
    min-width: 0;
  }

  .lument-cart-item__title {
    margin: 0;
    font-family: 'Playfair Display', serif;
    font-weight: 600;
    font-size: 20px;
    line-height: 1.5em;
    color: #000000;
  }

  .lument-cart-item__title a {
    text-decoration: none;
    color: inherit;
  }

  .lument-cart-item__title a:hover {
    opacity: 0.7;
  }

  .lument-cart-item__price-wrapper {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  .lument-cart-item__price {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 16px;
    line-height: 1.5em;
    color: #000000;
  }

  .lument-cart-item__compare-price {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 14px;
    line-height: 1.714em;
    color: #000000;
    opacity: 0.4;
    text-decoration: line-through;
  }

  .lument-cart-item__variants {
    font-family: 'Montserrat', sans-serif;
    font-size: 14px;
    color: rgba(0, 0, 0, 0.7);
  }

  .lument-cart-item__discounts {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .lument-cart-item__discount {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 10px;
    background-color: rgba(122, 0, 54, 0.05);
    border-radius: 4px;
    width: fit-content;
  }

  .lument-cart-item__discount-icon {
    width: 16px;
    height: 16px;
    color: #7A0036;
    flex-shrink: 0;
  }

  @media screen and (max-width: 749px) {
    .lument-cart-item__discount-icon svg{
      width: 12px !important;
      height: 12px !important;
    }
    .lument-cart-item__discount-text {
      font-size: 12px !important;
    }
  }

  .lument-cart-item__discount-text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 500;
    font-size: 13px;
    line-height: 1.4em;
    color: #7A0036;
  }

  .lument-cart-item__quantity-wrapper {
    display: flex;
    align-items: center;
    gap: 12px;
    justify-content: space-between;
  }

  .lument-cart-item__quantity-selector {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .lument-cart-item__qty-button {
    background: transparent;
    border: none;
    padding: 0;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 16.25px;
    height: 16.25px;
    transition: opacity 0.2s ease;
  }

  .lument-cart-item__qty-button:hover:not(:disabled) {
    opacity: 0.7;
  }

  .lument-cart-item__qty-button:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .lument-cart-item__qty-button:disabled .lument-cart-item__qty-icon {
    opacity: 0.3;
  }

  .lument-cart-item__qty-icon {
    display: block;
    width: 16.25px;
    height: 16.25px;
    aspect-ratio: 1/1;
    background-size: contain;
    background-repeat: no-repeat;
    background-position: center;
  }

  /* Red/Burgundy minus button (default - for quantity 2+) */
  .lument-cart-item__qty-icon--minus {
    background-image: url('data:image/svg+xml;base64,');
  }

  /* Grey minus button (when quantity is 1) */
  .lument-cart-item__qty-icon--grey {
    background-image: url('data:image/svg+xml;base64,') !important;
  }

  /* Red/Burgundy plus button */
  .lument-cart-item__qty-icon--plus {
    background-image: url('data:image/svg+xml;base64,');
  }

  /* Grey plus button (when quantity cannot be updated) */
  .lument-cart-item__qty-icon--plus-grey {
    background-image: url('data:image/svg+xml;base64,');
  }

  /* Free gift quantity icons - grey and disabled */
  .lument-cart-item__qty-icon--free-gift {
    background-image: url('data:image/svg+xml;base64,') !important;
    opacity: 1 !important;
    cursor: not-allowed;
  }

  .lument-cart-item__qty-icon--plus.lument-cart-item__qty-icon--free-gift {
    background-image: url('data:image/svg+xml;base64,') !important;
    opacity: 1 !important;
    cursor: not-allowed;
  }

  /* Desktop sizes */
  @media screen and (min-width: 750px) {
    .lument-cart-item__qty-button {
      width: 20px;
      height: 20px;
    }

    .lument-cart-item__qty-icon {
      width: 20px;
      height: 20px;
    }
  }

  .lument-cart-item__qty-input {
    width: 32px;
    height: auto;
    text-align: center;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.571em;
    color: #000000;
    border: none;
    background: transparent;
    padding: 0;
    -moz-appearance: textfield;
  }

  .lument-cart-item__qty-input::-webkit-outer-spin-button,
  .lument-cart-item__qty-input::-webkit-inner-spin-button {
    -webkit-appearance: none;
    margin: 0;
  }

  .lument-cart-item__qty-input:focus {
    outline: none;
  }

  .lument-cart-item__remove {
    background: transparent;
    border: none;
    padding: 4px;
    cursor: pointer;
    color: #000000;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.2s ease;
  }

  .lument-cart-item__remove:hover {
    opacity: 0.7;
  }

  .lument-cart-item__remove svg {
    width: 20px;
    height: 20px;
  }

  .lument-cart-item__error {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    margin-top: 8px;
    color: #DC2626;
    font-size: 14px;
  }

  .lument-cart-item__error.hidden {
    display: none;
  }

  .lument-cart-item__error .svg-wrapper {
    width: 16px;
    height: 16px;
    flex-shrink: 0;
  }

  .lument-cart-item__error-text {
    flex: 1;
  }

  /* Desktop Layout - 750px and above */
  @media screen and (min-width: 750px) {
    .lument-cart-item__header {
      flex-direction: row;
      align-items: flex-start;
      gap: 8px;
    }
  }


  @media screen and (max-width: 749px) {
    .lument-cart-item__price-wrapper {
      display: flex;
      flex-direction: row;
      align-items: flex-start;
      justify-content: flex-start;
      gap: 10px;
    }
  }
  /* Free Gift Badge */
  .lument-cart-item__free-badge {
    display: inline-block;
    background: linear-gradient(135deg, #7A0036 0%, #A0004A 100%);
    color: #FFFFFF;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 11px;
    line-height: 1.2;
    padding: 4px 8px;
    border-radius: 4px;
    /* margin-left: 8px; */
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  @media screen and (max-width: 749px) {
    .lument-cart-item__free-badge {
      display: none;
    }
  }

  .lument-cart-item__price--free {
    color: #7A0036;
    font-weight: 700;
    font-size: 16px;
  }

  /* Animation for item removal */
  .lument-cart-item.removing {
    overflow: hidden;
    animation: lumentRemoveItem 0.4s ease-out forwards;
  }

  @keyframes lumentRemoveItem {
    0% {
      opacity: 1;
      max-height: 200px;
      padding: 20px;
    }
    50% {
      opacity: 0;
      padding: 20px;
    }
    100% {
      opacity: 0;
      max-height: 0;
      padding: 0;
      border-bottom-width: 0;
    }
  }
{% endstylesheet %}

