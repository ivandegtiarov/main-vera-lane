{%- capture unique_id -%}star-grad-{{ product.id | default: 'default' }}-{{ 'now' | date: '%N' }}{%- endcapture -%}

{%- comment -%} Full stars {%- endcomment -%}
{%- for i in (1..full_stars) -%}
<svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 18 18" fill="none"><path d="{{ star_path }}" fill="{{ star_color }}"/></svg>
{%- endfor -%}
{%- comment -%} Half star {%- endcomment -%}
{%- if has_half_star -%}
<svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 18 18" fill="none"><defs><linearGradient id="{{ unique_id }}"><stop offset="50%" stop-color="{{ star_color }}"/><stop offset="50%" stop-color="{{ empty_color }}"/></linearGradient></defs><path d="{{ star_path }}" fill="url(#{{ unique_id }})"/></svg>
{%- endif -%}
{%- comment -%} Empty stars {%- endcomment -%}
{%- for i in (1..empty_stars) -%}
<svg xmlns="http://www.w3.org/2000/svg" width="{{ size }}" height="{{ size }}" viewBox="0 0 18 18" fill="none"><path d="{{ star_path }}" fill="{{ empty_color }}"/></svg>
{%- endfor -%}
