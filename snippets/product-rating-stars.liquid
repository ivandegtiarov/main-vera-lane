{% comment %}
  Product Rating Stars Snippet

  Renders dynamic star ratings from product metafields.
  Outputs only SVGs (no wrapper) for easy integration with existing CSS.

  Usage:
    {% render 'product-rating-stars', product: product %}

  Parameters:
    - product: The product object (required)
    - star_color: Color for filled stars (default: #EDB04F)
    - empty_color: Color for empty stars (default: #D1D1D1)
    - size: Size of star SVGs in pixels (default: 18)
    - fallback_rating: Rating to use if metafield not set (default: 4.5)

  Metafields expected:
    - product.metafields.custom.star_rating (decimal, e.g., 4.6)
{% endcomment %}

{%- liquid
  assign star_color = star_color | default: '#EDB04F'
  assign empty_color = empty_color | default: '#D1D1D1'
  assign size = size | default: 18
  assign fallback_rating = fallback_rating | default: 4.5

  # Get rating from metafield or fallback
  assign rating = product.metafields.custom.star_rating.value | default: fallback_rating | times: 1.0

  # Calculate full stars, partial star, and empty stars
  assign full_stars = rating | floor
  assign decimal_part = rating | modulo: 1

  # Determine if we need a half star (anything from 0.25 to 0.75 shows as half)
  assign has_half_star = false
  if decimal_part >= 0.25 and decimal_part < 0.75
    assign has_half_star = true
  elsif decimal_part >= 0.75
    assign full_stars = full_stars | plus: 1
  endif

  # Calculate empty stars
  assign stars_used = full_stars
  if has_half_star
    assign stars_used = stars_used | plus: 1
  endif
  assign empty_stars = 5 | minus: stars_used
-%}

