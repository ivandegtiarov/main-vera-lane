{%- doc -%}
  Renders the cart drawer, a slide-out panel that displays the contents of the cart. It includes the cart icon that acts as a trigger.

  @param {object} [settings] - An object containing theme settings.

  @param {boolean} [settings.auto_open_cart_drawer] - If `true`, the cart drawer opens automatically after an item is
  added.
  @param {string} [settings.drawer_color_scheme] - The color scheme for the drawer.
{%- enddoc -%}

<script
  src="{{ 'cart-drawer.js' | asset_url }}"
  type="module"
  fetchpriority="low"
></script>

<cart-drawer-component
  class="cart-drawer"
  {{ block.shopify_attributes }}
  {% if settings.auto_open_cart_drawer %}
    auto-open
  {% endif %}
>
  <button
    class="button header-actions__action button-unstyled"
    on:click="/open"
    aria-label="{{ 'accessibility.open_cart_drawer' | t }} {{ 'accessibility.cart_count' | t}}: {{ cart.item_count }}"
  >
    {% render 'cart-icon-component' %}
  </button>

  <dialog
    ref="dialog"
    class="cart-drawer__dialog dialog-modal dialog-drawer color-{{ settings.drawer_color_scheme }}{% if cart.empty? %} cart-drawer--empty{%endif%}"
    scroll-lock
  >
    <div class="cart-drawer__inner">
      <div class="cart-drawer__loading" aria-hidden="true">
        <div class="cart-drawer__loading-spinner"></div>
      </div>
      <cart-items-component
        class="cart-items-component"
        data-section-id="{{ section.id }}"
      >
        {%- if cart.empty? -%}
          <div class="cart-drawer__header">
            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button close-button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
          >
            <div class="cart-drawer__empty-main">
              <span class="cart-drawer__heading h3 cart-drawer__heading--empty">
                {{ 'content.your_cart_is_empty' | t }}
              </span>

              <div class="cart-drawer__items">
                {% render 'cart-products' %}
              </div>
            </div>

            {% if settings.empty_cart_upsell_enabled %}
              <div class="cart-drawer__empty-upsell">
                {% render 'empty-cart-upsells',
                  enabled: settings.empty_cart_upsell_enabled,
                  heading: settings.empty_cart_upsell_heading,
                  product_1: settings.empty_cart_upsell_product_1,
                  product_2: settings.empty_cart_upsell_product_2,
                  product_3: settings.empty_cart_upsell_product_3
                %}
              </div>
            {% endif %}
          </div>
        {%- else -%}
          <div
            class="cart-drawer__header"
            id="cart-drawer-header"
          >
            <span class="cart-drawer__heading h3">
              {% comment %} {{ 'content.cart_title' | t }} {% endcomment %}
               Shipping Cart
              {% comment %} {% render 'cart-bubble' %} {% endcomment %}
            </span>

            <button
              ref="closeButton"
              on:click="cart-drawer-component/close"
              class="button close-button cart-drawer__close-button button-unstyled"
              aria-label="{{ 'actions.close_dialog' | t }}"
            >
              <span class="svg-wrapper">
                {{- 'icon-close.svg' | inline_asset_content -}}
              </span>
            </button>
          </div>

          <div
            class="cart-drawer__content motion-reduce"
            aria-label="{{ 'accessibility.cart' | t }}"
            style="--header-height: 60px;"
          >
              <scroll-hint
              class="cart-drawer__items"
            >
              {%- comment -%} Rewards Progress Section {%- endcomment -%}
              <div
                class="cart-drawer__rewards"
                style="--cart-goal-text-padding-mobile: {{ settings.cart_goal_text_padding_mobile | default: 0 }}px; --cart-goal-text-padding-desktop: {{ settings.cart_goal_text_padding_desktop | default: 0 }}px;"
              >
              {% liquid
                  comment
                    Cart goals thresholds are stored in theme settings
                    as dollar amounts (e.g. "30"). Convert them to cents
                    so they can be compared directly to cart.total_price,
                    which is also in cents.
                  endcomment

                  assign free_shipping_threshold = settings.cart_goal_1_threshold | default: 30 | times: 100
                  assign free_bag_threshold = settings.cart_goal_2_threshold | default: 45 | times: 100
                  assign free_mascara_threshold = settings.cart_goal_3_threshold | default: 60 | times: 100

                  assign cart_total_cents = cart.total_price
                  
                  assign shipping_progress = cart_total_cents | times: 100 | divided_by: free_shipping_threshold
                  if shipping_progress > 100
                    assign shipping_progress = 100
                  endif
                  
                  assign bag_progress = cart_total_cents | times: 100 | divided_by: free_bag_threshold
                  if bag_progress > 100
                    assign bag_progress = 100
                  endif
                  
                  assign mascara_progress = cart_total_cents | times: 100 | divided_by: free_mascara_threshold
                  if mascara_progress > 100
                    assign mascara_progress = 100
                  endif

                  comment
                    Determine if any cart items should disable specific goals
                    based on a line-item property `bundle_id` matching a
                    value configured in theme settings (for example `vera_bundle`).
                  endcomment

                  assign goal_1_exclude_value = settings.cart_goal_1_exclude_property_value | default: '' | strip
                  assign goal_2_exclude_value = settings.cart_goal_2_exclude_property_value | default: '' | strip
                  assign goal_3_exclude_value = settings.cart_goal_3_exclude_property_value | default: '' | strip

                  assign cart_has_goal_1_excluded_item = false
                  assign cart_has_goal_2_excluded_item = false
                  assign cart_has_goal_3_excluded_item = false

                  if goal_1_exclude_value != '' or goal_2_exclude_value != '' or goal_3_exclude_value != ''
                    for line_item in cart.items
                      if goal_1_exclude_value != '' and cart_has_goal_1_excluded_item == false
                        for property in line_item.properties
                          if property.first == 'bundle_id' and property.last == goal_1_exclude_value
                            assign cart_has_goal_1_excluded_item = true
                            break
                          endif
                        endfor
                      endif

                      if goal_2_exclude_value != '' and cart_has_goal_2_excluded_item == false
                        for property in line_item.properties
                          if property.first == 'bundle_id' and property.last == goal_2_exclude_value
                            assign cart_has_goal_2_excluded_item = true
                            break
                          endif
                        endfor
                      endif

                      if goal_3_exclude_value != '' and cart_has_goal_3_excluded_item == false
                        for property in line_item.properties
                          if property.first == 'bundle_id' and property.last == goal_3_exclude_value
                            assign cart_has_goal_3_excluded_item = true
                            break
                          endif
                        endfor
                      endif

                      if cart_has_goal_1_excluded_item and cart_has_goal_2_excluded_item and cart_has_goal_3_excluded_item
                        break
                      endif
                    endfor
                  endif

                  comment
                    Always exclude goal_2 (Free Travel Bag/Free makeup bag) when cart has vera2_bundle items
                  endcomment
                  if cart_has_goal_2_excluded_item == false
                    for line_item in cart.items
                      for property in line_item.properties
                        if property.first == 'bundle_id' and property.last == 'vera2_bundle'
                          assign cart_has_goal_2_excluded_item = true
                          break
                        endif
                      endfor
                      if cart_has_goal_2_excluded_item
                        break
                      endif
                    endfor
                  endif

                  assign goal_1_effective_enabled = settings.cart_goal_1_enabled
                  assign goal_2_effective_enabled = settings.cart_goal_2_enabled
                  assign goal_3_effective_enabled = settings.cart_goal_3_enabled

                  assign free_shipping_threshold = settings.cart_goal_1_threshold | default: 60 | round
                  assign goal_1_reward_text = settings.cart_goal_1_text | default: 'Free Shipping <strong class="cart-drawer__reward-amount">$30</strong>' | replace: '[threshold]', free_shipping_threshold
                  assign goal_2_reward_text = settings.cart_goal_2_text | default: 'Free Travel Bag <strong class="cart-drawer__reward-amount">$45</strong>'
                  assign goal_3_reward_text = settings.cart_goal_3_text | default: 'Free Mini Mascara <strong class="cart-drawer__reward-amount">$60</strong>'

                  if cart_has_goal_1_excluded_item and goal_1_effective_enabled
                    assign goal_1_effective_enabled = false
                  endif

                  if cart_has_goal_2_excluded_item and goal_2_effective_enabled
                    assign goal_2_effective_enabled = false
                  endif

                  if cart_has_goal_3_excluded_item and goal_3_effective_enabled
                    assign goal_3_effective_enabled = false
                  endif
                %}

                {% if goal_1_effective_enabled %}
                  <div class="cart-drawer__reward-item">
                    <svg class="cart-drawer__reward-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M23.667 10.418L22.658 7.394C22.18 5.962 20.846 5 19.338 5H16.95C16.698 2.756 14.811 1 12.501 1H4.5C2.445 1 0.653 2.388 0.142 4.375C0.074 4.643 0.234 4.915 0.501 4.984C0.772 5.052 1.041 4.891 1.11 4.625C1.507 3.079 2.902 2 4.5 2H12.5C14.43 2 16 3.57 16 5.5V18H3.5C2.121 18 1 16.879 1 15.5C1 15.224 0.776 15 0.5 15C0.224 15 0 15.224 0 15.5C0 16.891 0.822 18.085 2 18.649V20C2 21.654 3.346 23 5 23C6.654 23 8 21.654 8 20V19H16V20C16 21.654 17.346 23 19 23C20.654 23 22 21.654 22 20V18.649C23.178 18.085 24 16.891 24 15.5V12.474C24 11.774 23.888 11.081 23.667 10.418ZM21.709 7.71L22.718 10.734C22.747 10.821 22.759 10.912 22.783 11H17V6H19.338C20.416 6 21.368 6.688 21.709 7.71ZM7 20C7 21.103 6.103 22 5 22C3.897 22 3 21.103 3 20V18.949C3.165 18.973 3.329 19 3.5 19H7V20ZM21 20C21 21.103 20.103 22 19 22C17.897 22 17 21.103 17 20V19H20.5C20.671 19 20.835 18.973 21 18.949V20ZM23 15.5C23 16.879 21.879 18 20.5 18H17V12H22.962C22.976 12.158 23 12.314 23 12.474V15.5ZM9 8V9.5H10C10.276 9.5 10.5 9.724 10.5 10C10.5 10.276 10.276 10.5 10 10.5H9V12H10C10.276 12 10.5 12.224 10.5 12.5C10.5 12.776 10.276 13 10 13H9C8.448 13 8 12.552 8 12V8C8 7.448 8.448 7 9 7H10C10.276 7 10.5 7.224 10.5 7.5C10.5 7.776 10.276 8 10 8H9ZM12.5 8V9.5H13.5C13.776 9.5 14 9.724 14 10C14 10.276 13.776 10.5 13.5 10.5H12.5V12H13.5C13.776 12 14 12.224 14 12.5C14 12.776 13.776 13 13.5 13H12.5C11.948 13 11.5 12.552 11.5 12V8C11.5 7.448 11.948 7 12.5 7H13.5C13.776 7 14 7.224 14 7.5C14 7.776 13.776 8 13.5 8H12.5ZM7 9C7 7.916 6.104 7 5.042 7H4.5C3.948 7 3.5 7.448 3.5 8V12.5C3.5 12.776 3.724 13 4 13C4.276 13 4.5 12.776 4.5 12.5V11H5.042C5.155 11 5.265 10.985 5.373 10.965L6.033 12.68C6.109 12.878 6.299 13 6.5 13C6.56 13 6.62 12.989 6.68 12.967C6.938 12.867 7.066 12.578 6.967 12.321L6.277 10.528C6.712 10.158 7 9.609 7 9.001V9ZM4.5 10V8H5.042C5.562 8 6 8.458 6 9C6 9.542 5.562 10 5.042 10H4.5ZM0 12.5V8C0 7.448 0.448 7 1 7H2C2.276 7 2.5 7.224 2.5 7.5C2.5 7.776 2.276 8 2 8H1V9.5H2C2.276 9.5 2.5 9.724 2.5 10C2.5 10.276 2.276 10.5 2 10.5H1V12.5C1 12.776 0.776 13 0.5 13C0.224 13 0 12.776 0 12.5Z" fill="#7A0036"/>
                    </svg>
                    <div class="cart-drawer__reward-content">
                      <span class="cart-drawer__reward-text">{{ goal_1_reward_text | raw }}</span>
                    </div>
                    <div class="cart-drawer__reward-progress">
                      <div class="cart-drawer__reward-progress-bar" style="width: {{ shipping_progress }}%;"></div>
                    </div>
                  </div>
                {% endif %}

                {% if goal_2_effective_enabled %}
                  <div class="cart-drawer__reward-item">
                    <svg class="cart-drawer__reward-icon" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <g clip-path="url(#clip0_1_2081)">
                        <path d="M23.552 9.862C23.077 9.314 22.388 9 21.663 9H21C21 4.038 16.962 0 12 0C7.038 0 3 4.038 3 9H2.5C1.774 9 1.086 9.314 0.611001 9.862C0.136001 10.41 -0.0769989 11.136 0.0250011 11.854L1.208 20.137C1.523 22.34 3.438 24 5.663 24H18.499C20.724 24 22.639 22.339 22.954 20.137L24.137 11.854C24.24 11.136 24.027 10.41 23.552 9.862ZM12 1C16.411 1 20 4.589 20 9H4C4 4.589 7.589 1 12 1ZM23.148 11.712L21.965 19.995C21.72 21.708 20.231 23 18.5 23H5.664C3.934 23 2.444 21.708 2.199 19.995L1.016 11.712C0.954001 11.281 1.082 10.846 1.368 10.518C1.653 10.189 2.066 10 2.501 10H21.663C22.098 10 22.511 10.188 22.796 10.517C23.081 10.846 23.21 11.281 23.148 11.712ZM16 16C16 16.276 15.776 16.5 15.5 16.5H8.5C8.224 16.5 8 16.276 8 16C8 15.724 8.224 15.5 8.5 15.5H15.5C15.776 15.5 16 15.724 16 16Z" fill="#7A0036"/>
                      </g>
                      <defs>
                        <clipPath id="clip0_1_2081">
                          <rect width="24" height="24" fill="white"/>
                        </clipPath>
                      </defs>
                    </svg>
                    <div class="cart-drawer__reward-content">
                      <span class="cart-drawer__reward-text">{{ goal_2_reward_text | raw }}</span>
                    </div>
                    <div class="cart-drawer__reward-progress">
                      <div class="cart-drawer__reward-progress-bar" style="width: {{ bag_progress }}%;"></div>
                    </div>
                  </div>
                {% endif %}

                {% if goal_3_effective_enabled %}
                  <div class="cart-drawer__reward-item">
                    <svg class="cart-drawer__reward-icon"  xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none">
