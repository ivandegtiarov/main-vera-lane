                    </svg>
                    <div class="cart-drawer__reward-content">
                      <span class="cart-drawer__reward-text">{{ goal_3_reward_text | raw }}</span>
                    </div>
                    <div class="cart-drawer__reward-progress">
                      <div class="cart-drawer__reward-progress-bar" style="width: {{ mascara_progress }}%;"></div>
                    </div>
                  </div>
                {% endif %}
              </div>

              {% render 'cart-goals-countdown-banner' %}

              <!-- cart-upsell-debug enabled={{ settings.cart_upsell_enabled | json }}
                p1={{ settings.cart_upsell_product_1 | json }} p1_title={{ settings.cart_upsell_product_1.title | default: '' | json }}
                p2={{ settings.cart_upsell_product_2 | json }} p2_title={{ settings.cart_upsell_product_2.title | default: '' | json }}
                p3={{ settings.cart_upsell_product_3 | json }} p3_title={{ settings.cart_upsell_product_3.title | default: '' | json }}
              -->

              {% render 'cart-products' %}
              {% render 'cart-upsell' %}
            </scroll-hint>

            <div
              class="cart-drawer__summary"
            >
              {% render 'cart-summary', is_cart_drawer: true %}
            </div>
          </div>
        {%- endif -%}
      </cart-items-component>
    </div>
  </dialog>
</cart-drawer-component>

{%- comment -%}
  Cart goals data for cart-drawer.js

  Thresholds are output in cents so that they can be
  compared directly against cart.total_price (which is
  also in cents in the AJAX cart API).
{%- endcomment -%}
{%- liquid
  assign goal_1_product = settings.cart_goal_1_product
  assign goal_2_product = settings.cart_goal_2_product
  assign goal_3_product = settings.cart_goal_3_product

  assign goal_1_threshold_cents = settings.cart_goal_1_threshold | default: 30 | times: 100
  assign goal_2_threshold_cents = settings.cart_goal_2_threshold | default: 45 | times: 100
  assign goal_3_threshold_cents = settings.cart_goal_3_threshold | default: 60 | times: 100

  comment
    Use the same effective enabled flags that account for bundle
    exclusions when outputting data for cart-drawer.js. This keeps
    the visual goals and the auto-add logic in sync.
  endcomment
  
  if goal_1_effective_enabled == nil
    assign goal_1_enabled_effective_for_js = settings.cart_goal_1_enabled
  else
    assign goal_1_enabled_effective_for_js = goal_1_effective_enabled
  endif

  if goal_2_effective_enabled == nil
    assign goal_2_enabled_effective_for_js = settings.cart_goal_2_enabled
  else
    assign goal_2_enabled_effective_for_js = goal_2_effective_enabled
  endif

  if goal_3_effective_enabled == nil
    assign goal_3_enabled_effective_for_js = settings.cart_goal_3_enabled
  else
    assign goal_3_enabled_effective_for_js = goal_3_effective_enabled
  endif

  if goal_1_product
    assign goal_1_product_id = goal_1_product.id
    assign goal_1_variant_id = goal_1_product.selected_or_first_available_variant.id
  endif

  if goal_2_product
    assign goal_2_product_id = goal_2_product.id
    assign goal_2_variant_id = goal_2_product.selected_or_first_available_variant.id
  endif

  if goal_3_product
    assign goal_3_product_id = goal_3_product.id
    assign goal_3_variant_id = goal_3_product.selected_or_first_available_variant.id
  endif
-%}
<script id="cart-goals-data" type="application/json">
  {
    "countdown": {
      "enabled": {{ settings.cart_goal_countdown_enabled | default: false | json }},
      "durationMs": {{ settings.cart_goal_countdown_duration_minutes | default: 15 | times: 60000 | json }}
    },
    "goals": [
      {
        "name": "Free Shipping",
        "enabled": {{ goal_1_enabled_effective_for_js | default: false | json }},
        "threshold": {{ goal_1_threshold_cents | json }},
        "excludePropertyValue": {{ settings.cart_goal_1_exclude_property_value | default: '' | json }},
        "productId": {{ goal_1_product_id | default: nil | json }},
        "variantId": {{ goal_1_variant_id | default: nil | json }}
      },
      {
        "name": "Free Travel Bag",
        "enabled": {{ goal_2_enabled_effective_for_js | default: false | json }},
        "threshold": {{ goal_2_threshold_cents | json }},
        "excludePropertyValue": {{ settings.cart_goal_2_exclude_property_value | default: '' | json }},
        "productId": {{ goal_2_product_id | default: nil | json }},
        "variantId": {{ goal_2_variant_id | default: nil | json }}
      },
      {
        "name": "Free Mini Mascara",
        "enabled": {{ goal_3_enabled_effective_for_js | default: false | json }},
        "threshold": {{ goal_3_threshold_cents | json }},
        "excludePropertyValue": {{ settings.cart_goal_3_exclude_property_value | default: '' | json }},
        "productId": {{ goal_3_product_id | default: nil | json }},
        "variantId": {{ goal_3_variant_id | default: nil | json }}
      }
    ]
  }
</script>

{% stylesheet %}
  .cart-items-component {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  .cart-drawer__heading .cart-bubble {
    width: fit-content;
    border-radius: var(--style-border-radius-buttons-primary);
    aspect-ratio: auto;
    padding: var(--cart-padding);
  }

  .cart-drawer__heading .cart-bubble[data-maintain-ratio] {
    aspect-ratio: 1;
    min-width: 26px;
  }

  .cart-drawer__header {
    background-color: var(--color-background);
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: var(--cart-drawer-padding);
    border-bottom: var(--style-border-width) solid none;
    position: sticky;
    top: 0;
    z-index: 1;
    color: #7A0036;
    font-family: "Playfair Display" !important;
    font-style: italic !important;

    @media screen and (min-width: 750px) {
      padding: var(--cart-drawer-padding-desktop);
      font-size: 20px;
    }
  }

  @media screen and (max-width: 749px) {
    .cart-drawer__header .h3 {
      font-size: 20px;
    }

    .cart-drawer__close-button {
      display: none;
    }
  }

  .cart-drawer__header .cart-drawer__heading h3 {
    font-family: "Playfair Display" !important;
    font-style: italic !important;
  }

  .cart-drawer__dialog {
    overflow: hidden;

    @media screen and (max-width: 749px) {
      --animation-speed: 0.24s;
      --dialog-drawer-opening-animation: cart-drawer-slide-in-vertical;
      --dialog-drawer-closing-animation: cart-drawer-slide-out-vertical;

      width: 100%;
      max-height: 90vh;
      height: fit-content;
      margin: auto 0 0 0;
      inset-block-end: 0;
      inset-block-start: auto;
      border-radius: 16px 16px 0 0;
    }

    @media screen and (min-width: 750px) {
      width: 540px !important;
      max-width: 540px;
      border-radius: 16px 0 0 16px !important;
    }
  }

  @media screen and (max-width: 749px) {
    .cart-drawer__dialog:modal::backdrop {
      background: transparent;
      animation: none;
    }
  }

  /* Ensure the dialog inner content respects border radius */
  .cart-drawer__dialog .cart-drawer__inner {
    @media screen and (min-width: 750px) {
      border-radius: 16px 0 0 16px;
    }
  }

  .cart-drawer__inner {
    height: 100%;
    overflow: hidden;
  }

  .cart-drawer__loading {
    position: absolute;
    inset: 0;
    display: none;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.75);
    z-index: 10;
  }

  .cart-drawer__loading--active {
    display: flex;
  }

  .cart-drawer__loading-spinner {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 3px solid #f3e8ef;
    border-top-color: #7A0036;
    animation: cartDrawerSpinner 0.6s linear infinite;
  }

  @keyframes cartDrawerSpinner {
    to {
      transform: rotate(360deg);
    }
  }

  .cart-drawer__content {
    --header-height: 60px;
    height: calc(100% - var(--header-height));
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    -webkit-overflow-scrolling: touch;
  }

  /* Empty cart layout: keep CTAs in the main area, push upsell to the bottom */
  .cart-drawer__empty-upsell {
    padding-top: 24px;
    padding-bottom: 24px;
        border-top: 1px solid #DADADA;
  }

  .cart-drawer__summary {
    background-color: var(--color-background);
    position: sticky;
    bottom: 0;
    z-index: 1;
  }

  /* Rewards Progress Section */
  .cart-drawer__rewards {
    background-color: #FFFFFF;
    padding: 20px;
    display: flex;
    flex-direction: row;
    gap: 8px;
    border-bottom: 1px solid #E1DCD8;
  }

  .cart-drawer__reward-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    /* Make each reward item stretch to fill available width
       on all viewports so that if only one reward is visible,
       it will take the full width (matches desktop behavior). */
    flex: 1;
  }

  .cart-drawer__reward-icon {
    width: 24px;
    height: 24px;
    color: #000000;
    flex-shrink: 0;
  }

  .cart-drawer__reward-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  .cart-drawer__reward-text {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 12px;
    line-height: 1.667em;
    color: #000000;
    text-align: center;
    padding: var(--cart-goal-text-padding-mobile, 0);
  }


  .cart-drawer__reward-amount {
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.571em;
    color: #000000;
  }

  .cart-drawer__reward-progress {
    width: 100%;
    height: 6px;
    background-color: #EEE8E3;
    border-radius: 6px;
    overflow: hidden;
  }

  .cart-drawer__reward-progress-bar {
    height: 100%;
    background: #7A0036;
    transition: width 0.3s ease;
  }

  @keyframes cart-drawer-slide-in-vertical {
    from {
      transform: translateY(100%);
    }

    to {
      transform: translateY(0);
    }
  }

  @keyframes cart-drawer-slide-out-vertical {
    from {
      transform: translateY(0);
    }

    to {
      transform: translateY(100%);
    }
  }

  /* Desktop Layout for Rewards */
  @media screen and (min-width: 750px) {
    .cart-drawer__rewards {
      flex-direction: row;
      gap: 8px;
    }

    .cart-drawer__reward-text {
      font-size: 14px;
      line-height: 1.571em;
      padding: var(--cart-goal-text-padding-desktop, 0);
    }

  }
{% endstylesheet %}
