    "lumen_grid_benefits_section": {
      "type": "lumen-grid-benefits",
      "blocks": {
        "benefit_1": {
          "type": "benefit_item",
          "settings": {
            "title": "Adaptive Color Technology",
            "description": "Our Intelligent Capsule Technology recognizes your unique undertones on contact. The white cream breaks down as you blend, releasing pigments that mirror your exact skin tone for a match that is yours and yours alone."
          }
        },
        "benefit_2": {
          "type": "benefit_item",
          "settings": {
            "title": "Engineered for Mature Texture",
            "description": "Traditional makeup often highlights what you want to hide. Our formula is specifically designed to float over fine lines and enlarged pores rather than settling into them, creating a lifted, soft-focus effect that lasts all day."
          }
        },
        "benefit_3": {
          "type": "benefit_item",
          "settings": {
            "title": "The \"Second Skin\" Glow",
            "description": "Conceal redness, age spots, and uneven patches without the heavy \"mask\" feel of full-coverage foundation. This breathable, lightweight finish allows your natural radiance to shine through while providing a balanced, uniform complexion."
          }
        },
        "benefit_4": {
          "type": "benefit_item",
          "settings": {
            "title": "16-Hour Hydration Lock",
            "description": "Formulated to combat the \"mid-day dry out\" common with aging skin. This long-wear formula stays flexible and luminous for up to 16 hours, ensuring your skin looks as fresh in the evening as it did in the morning."
          }
        },
        "benefit_5": {
          "type": "benefit_item",
          "settings": {
            "title": "Clean & Breathable Pore Care",
            "description": "A skin-first approach that won't lead to breakouts or irritation. Our non-comedogenic ingredients nourish the skin barrier while letting your pores breathe, making it safe and comfortable for daily wear."
          }
        },
        "benefit_6": {
          "type": "benefit_item",
          "settings": {
            "title": "Cruelty-Free",
            "description": "Kindness is beautiful. We are proud to be 100% cruelty-free, meaning we never test our products or ingredients on animals at any stage of production."
          }
        }
      },
      "block_order": [
        "benefit_1",
