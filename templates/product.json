          "settings": {
            "image_mode": "single",
            "image_single": "shopify://shop_images/Untitled_design_68.png",
            "image_before": "shopify://shop_images/Untitled_design_68.png",
            "card_name": "Linda, 54",
            "card_description": "I stopped wearing foundation because it always settled into my fine lines or looked the wrong color—usually too orange. This formula matched my skin tone instantly and feels so light. It doesn't look like makeup; it just looks like I have great skin again."
          }
        },
        "testimonial_card_WAUUWU": {
          "type": "testimonial_card",
          "settings": {
            "image_mode": "single",
