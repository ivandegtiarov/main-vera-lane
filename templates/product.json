      "blocks": {
        "faq_item_1": {
          "type": "faq_item",
          "settings": {
            "question": "What is your return policy?",
            "answer": "We offer a 60-day money-back guarantee on all products. If you're not completely satisfied with your purchase, contact us for a full refund."
          }
        },
        "faq_item_2": {
          "type": "faq_item",
          "settings": {
            "question": "How long does shipping take?",
            "answer": "Standard shipping takes 4-5 business days. Express shipping is available for 2-3 business day delivery."
          }
        },
        "faq_item_3": {
          "type": "faq_item",
          "settings": {
            "question": "Is this product suitable for sensitive skin?",
            "answer": "Yes, our products are dermatologist-tested and formulated for all skin types, including sensitive skin."
          }
        },
        "faq_item_4": {
          "type": "faq_item",
          "settings": {
            "question": "How do I know which shade to choose?",
            "answer": "Our foundation adapts to your skin tone within seconds. It works for fair to medium skin tones."
          }
        },
        "faq_item_5": {
          "type": "faq_item",
          "settings": {
            "question": "What ingredients are in this product?",
            "answer": "Our products contain nourishing ingredients like Glycerin, Sodium Hyaluronate, and Vitamin E for healthy, hydrated skin."
          }
        },
        "faq_item_6": {
          "type": "faq_item",
          "settings": {
            "question": "Do you offer free shipping?",
            "answer": "Yes, we offer free shipping on all orders over $49. Orders under $49 have a flat shipping rate."
          }
        }
      },
