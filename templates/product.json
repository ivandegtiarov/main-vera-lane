            "image_before": "shopify://shop_images/2.png",
            "image_after": "shopify://shop_images/image_2_2.png",
            "card_name": "Michelle, 27",
            "card_description": "I have tricky undertones and struggling with redness, so buying makeup online terrified me. I took a chance on this, and I'm shocked. It neutralized my redness immediately and blended right into my neck. No more 'floating head' effect!"
          }
        },
        "testimonial_card_pkT3Gh": {
          "type": "testimonial_card",
          "settings": {
