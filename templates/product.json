            "image_after": "shopify://shop_images/image_2_2.png",
            "card_name": "Diane, 49",
            "card_description": "Being very fair, 'universal' shades usually turn dark or orange on me within an hour. This one actually stayed true to my pale complexion. It gives me a healthy, warm glow without looking fake. Finally, a perfect match for fair skin."
          }
        },
        "testimonial_card_BGPEhn": {
          "type": "testimonial_card",
          "settings": {
