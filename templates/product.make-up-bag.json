    "lumen_benefits_section": {
      "type": "lumen-benefits",
      "disabled": true,
      "name": "⚡Benefits Section",
      "settings": {
        "section_label": "Key benefits of Vera Lane",
        "image": "shopify://shop_images/AdaptstoYourSkinToneInstantly_1.png",
        "benefit_1_title": "Custom-Fit Color Technology",
        "benefit_1_text": "Say goodbye to the guesswork of shade matching. Our innovative formula releases micro-encapsulated pigments upon application, seamlessly transforming from white to your exact skin tone for a match that feels uniquely yours.",
        "benefit_2_title": "Flawless, Ageless Finish",
        "benefit_2_text": "Designed specifically for mature skin, this lightweight foundation glides over fine lines and wrinkles rather than settling into them. It instantly neutralizes redness and blurs imperfections, leaving you with a smooth, radiant, and youthful complexion.",
        "benefit_3_title": "Protective Skincare Hybrid",
        "benefit_3_text": "More than just makeup, this is daily defense. Enriched with SPF 15 and hydrating botanicals, it shields your delicate skin from sun damage while locking in moisture, ensuring you look fresh and feel nourished all day long.",
        "benefit_4_title": "16-Hour Weightless Wear",
        "benefit_4_text": "Enjoy confidence that lasts from morning to night. Our breathable, non-comedogenic formula resists heat and humidity for up to 16 hours, delivering durable coverage that never feels heavy, cakey, or mask-like.",
        "enable_animation": true,
        "title_font_size_mobile": 22,
        "title_font_size_desktop": 28,
        "text_font_size_mobile": 14,
        "text_font_size_desktop": 14,
        "show_pointers_mobile": "none",
        "show_pointers_tablet": "none",
        "show_pointers_desktop": "block",
        "padding_top_mobile": 56,
        "padding_bottom_mobile": 56,
        "padding_top_desktop": 80,
        "padding_bottom_desktop": 80
      }
    },
    "lumen_grid_benefits_section": {
      "type": "lumen-grid-benefits",
      "blocks": {
        "benefit_1": {
          "type": "benefit_item",
          "settings": {
            "title": "Suitable For Your Skin Color",
            "description": "Expertly formulated to adapt to your unique undertones. Our pigment technology ensures a seamless blend that enhances your natural complexion rather than masking it."
          }
        },
        "benefit_2": {
          "type": "benefit_item",
          "settings": {
            "title": "Long-Lasting Formula",
            "description": "Go from morning coffee to evening dinner without a touch-up. Our resilient formula resists fading and settling into fine lines, keeping you looking radiant all day."
          }
        },
        "benefit_3": {
          "type": "benefit_item",
          "settings": {
            "title": "Dermatologist Tested",
            "description": "Your skin’s health is our priority. Every product is rigorously tested by skincare experts to ensure it is gentle, non-irritating, and safe for even the most sensitive skin types."
          }
        },
        "benefit_4": {
          "type": "benefit_item",
          "settings": {
            "title": "Natural Ingredients",
            "description": "Powered by nature, not chemicals. We infuse our cosmetics with high-quality botanicals and skin-loving vitamins to nourish your complexion while you wear them."
          }
