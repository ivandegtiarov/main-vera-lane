        "benefit_3": {
          "type": "benefit_item",
          "settings": {
            "title": "Dermatologist Tested",
            "description": "Your skin’s health is our priority. Every product is rigorously tested by skincare experts to ensure it is gentle, non-irritating, and safe for even the most sensitive skin types."
