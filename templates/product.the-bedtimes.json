    "lumen_benefits_section": {
      "type": "lumen-benefits",
      "name": "⚡Benefits Section",
      "settings": {
        "section_label": "Key benefits of Vera Lane",
        "image": "shopify://shop_images/AdaptstoYourSkinToneInstantly_1.png",
        "benefit_1_title": "Custom-Fit Color Technology",
        "benefit_1_text": "Say goodbye to the guesswork of shade matching. Our innovative formula releases micro-encapsulated pigments upon application, seamlessly transforming from white to your exact skin tone for a match that feels uniquely yours.",
        "benefit_2_title": "Flawless, Ageless Finish",
        "benefit_2_text": "Designed specifically for mature skin, this lightweight foundation glides over fine lines and wrinkles rather than settling into them. It instantly neutralizes redness and blurs imperfections, leaving you with a smooth, radiant, and youthful complexion.",
        "benefit_3_title": "Protective Skincare Hybrid",
        "benefit_3_text": "More than just makeup, this is daily defense. Enriched with SPF 15 and hydrating botanicals, it shields your delicate skin from sun damage while locking in moisture, ensuring you look fresh and feel nourished all day long.",
        "benefit_4_title": "16-Hour Weightless Wear",
        "benefit_4_text": "Enjoy confidence that lasts from morning to night. Our breathable, non-comedogenic formula resists heat and humidity for up to 16 hours, delivering durable coverage that never feels heavy, cakey, or mask-like.",
